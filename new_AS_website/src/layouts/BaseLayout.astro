---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Schema from '../components/Schema.astro';
import Analytics from '@vercel/analytics/astro';
import '../styles/variant.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	schema?: Record<string, any> | Record<string, any>[];
	schemaData?: Record<string, any> | Record<string, any>[];
	noindex?: boolean;
}

const {
	title,
	description = "AI Automation for SMEs and Professional Services. Scale your business, not your payroll with custom AI agents.",
	image = "/AS%20logos/logo-square-dark-initials-removebg-preview.webp",
	schema,
	schemaData,
	noindex = false
} = Astro.props;

const combinedSchema = schema || schemaData;

const sanitizedPath = Astro.url.pathname.endsWith('/') && Astro.url.pathname.length > 1 
	? Astro.url.pathname.slice(0, -1) 
	: Astro.url.pathname;
const canonicalURL = new URL(sanitizedPath, "https://autoflow-solutions.com");

const getLocale = (path: string) => {
	if (path.startsWith('/ms')) return 'ms';
	if (path.startsWith('/my')) return 'my';
	if (path.startsWith('/uk')) return 'uk';
	return 'default';
};

const htmlLangByLocale = {
	default: 'en',
	my: 'en-MY',
	ms: 'ms-MY',
	uk: 'en-GB'
};

const currentLocale = getLocale(sanitizedPath);
const htmlLang = htmlLangByLocale[currentLocale];
const basePath = sanitizedPath.replace(/^\/(my|ms|uk)(?=\/|$)/, '') || '/';

const routeMap = {
	default: new Set([
		'/', '/about', '/ai-self-audit', '/blog', '/careers', '/case-studies',
		'/cookies', '/disclaimer', '/ecommerce-automation', '/healthcare-automation',
		'/legal-automation', '/logistics-automation', '/privacy', '/process',
		'/professional-services-automation', '/resources', '/seo-report', '/services',
		'/terms', '/tools/automation-roi-calculator', '/services/ai-task-execution',
		'/services/lead-handling', '/services/workflow-automation'
	]),
	my: new Set([
		'/', '/about', '/ai-self-audit', '/blog', '/careers', '/case-studies',
		'/cookies', '/disclaimer', '/ecommerce-automation', '/healthcare-automation',
		'/legal-automation', '/logistics-automation', '/privacy', '/process',
		'/professional-services-automation', '/resources', '/seo-report', '/services',
		'/terms', '/tools/automation-roi-calculator', '/services/ai-task-execution',
		'/services/lead-handling', '/services/workflow-automation', '/tools/highlevel',
		'/tools/make', '/tools/n8n', '/tools/voiceflow', '/tools/zoho'
	]),
	ms: new Set([
		'/', '/about', '/ai-self-audit', '/blog', '/careers', '/case-studies',
		'/cookies', '/disclaimer', '/ecommerce-automation', '/healthcare-automation',
		'/legal-automation', '/logistics-automation', '/privacy', '/process',
		'/professional-services-automation', '/resources', '/seo-report', '/services',
		'/terms', '/tools/automation-roi-calculator', '/tools/highlevel', '/tools/make',
		'/tools/n8n', '/tools/voiceflow', '/tools/zoho'
	]),
	uk: new Set([
		'/', '/about', '/ai-self-audit', '/blog', '/careers', '/case-studies',
		'/cookies', '/disclaimer', '/ecommerce-automation', '/healthcare-automation',
		'/legal-automation', '/logistics-automation', '/privacy', '/process',
		'/professional-services-automation', '/resources', '/seo-report', '/services',
		'/terms', '/tools/automation-roi-calculator', '/services/ai-task-execution',
		'/services/lead-handling', '/services/workflow-automation', '/tools/highlevel',
		'/tools/make', '/tools/n8n', '/tools/voiceflow', '/tools/zoho'
	])
};

const localeUrl = (locale: keyof typeof routeMap, path: string) => {
	if (locale === 'default') return `https://autoflow-solutions.com${path === '/' ? '' : path}`;
	return `https://autoflow-solutions.com/${locale}${path === '/' ? '' : path}`;
};

const alternateLinks = ([
	{ locale: 'my', hreflang: 'en-MY' },
	{ locale: 'ms', hreflang: 'ms-MY' },
	{ locale: 'uk', hreflang: 'en-GB' },
	{ locale: 'default', hreflang: 'en' }
] as const)
	.filter(({ locale }) => routeMap[locale].has(basePath))
	.map(({ locale, hreflang }) => ({ hreflang, href: localeUrl(locale, basePath) }));

const defaultAlternate = routeMap.default.has(basePath)
	? localeUrl('default', basePath)
	: undefined;

const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"name": "Autoflow Solutions",
	"url": "https://autoflow-solutions.com",
	"logo": "https://autoflow-solutions.com/AS%20logos/logo-square-dark-initials-removebg-preview.webp",
	"description": "AI Automation Agency providing custom AI agents and automation pipelines for SMEs and Professional Services.",
	"sameAs": [
		"https://www.linkedin.com/company/autoflow-solutions"
	],
	"contactPoint": {
		"@type": "ContactPoint",
		"contactType": "customer service",
		"url": "https://autoflow-solutions.com/services#request"
	}
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Autoflow Solutions",
	"url": "https://autoflow-solutions.com"
};
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/webp" href="/AS%20logos/logo-square-dark-initials-removebg-preview.webp" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title} | Autoflow Solutions</title>
		<meta name="title" content={`${title} | Autoflow Solutions`} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		{noindex && <meta name="robots" content="noindex, follow" />}

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={`${title} | Autoflow Solutions`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={`${title} | Autoflow Solutions`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- Structured Data -->
		<Schema item={organizationSchema} />
		<Schema item={websiteSchema} />
		{combinedSchema && (Array.isArray(combinedSchema) ? combinedSchema.map(item => <Schema item={item} />) : <Schema item={combinedSchema} />)}

		
		<!-- Google Fonts — async to avoid render-blocking -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Outfit:wght@400;700&family=Barlow+Condensed:wght@600;700;900&display=swap" media="print" onload="this.media='all'">
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Outfit:wght@400;700&family=Barlow+Condensed:wght@600;700;900&display=swap"></noscript>

		<!-- Google tag (gtag.js) — deferred after load, cookieless -->
		<script is:inline>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  window.addEventListener('load', function() {
		    var s = document.createElement('script');
		    s.src = 'https://www.googletagmanager.com/gtag/js?id=G-6ETHYCNH3X';
		    s.async = true;
		    document.head.appendChild(s);
		    gtag('js', new Date());
		    gtag('config', 'G-6ETHYCNH3X', {
		      client_storage: 'none',
		      anonymize_ip: true
		    });
		  });
		</script>

		<!-- SEO: Regional Alt Versions -->
		{alternateLinks.map(({ hreflang, href }) => <link rel="alternate" hreflang={hreflang} href={href} />)}
		{defaultAlternate && <link rel="alternate" hreflang="x-default" href={defaultAlternate} />}
	</head>
	<body>
		<Navbar />
		<slot />
		<Analytics />
		<Footer />
		<!-- Cal.com embed — lazy loaded on first interaction to avoid cookie bloat -->
		<script is:inline>
			(function() {
				if (!document.querySelector('[data-cal-link]')) return;
				var calInitialized = false;
				function loadCal() {
					if (calInitialized) return;
					calInitialized = true;
					(function (C, A, L) { var p = function (a, ar) { a.q.push(ar); }; var d = C.document; C.Cal = C.Cal || function () { var cal = C.Cal; var ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { var api = function () { p(api, arguments); }; var namespace = ar[1]; api.q = api.q || []; typeof namespace === "string" ? (cal.ns[namespace] = cal.ns[namespace] || api) : p(cal, ar); return; } p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
					Cal("init", {origin:"https://cal.com"});
					Cal("ui", {"styles":{"branding":{"brandColor":"#000000"}},"hideEventTypeDetails":false,"layout":"month_view"});
				}
				var events = ['scroll', 'mousemove', 'touchstart', 'keydown'];
				function onFirstInteraction() {
					loadCal();
					events.forEach(function(e) { window.removeEventListener(e, onFirstInteraction); });
				}
				events.forEach(function(e) { window.addEventListener(e, onFirstInteraction, { once: true, passive: true }); });
			})();
		</script>
	</body>
</html>
