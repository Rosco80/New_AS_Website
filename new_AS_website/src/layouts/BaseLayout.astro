---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/variant.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: URL;
	schemaData?: object | object[]; // Page-specific JSON-LD schemas (Service, FAQ, etc.)
}

const { 
	title, 
	description = "AI Automation for SMEs and Professional Services",
	image = "/og-image.png",
	canonicalURL = new URL(Astro.url.pathname, Astro.site),
	schemaData
} = Astro.props;

const pathname = Astro.url.pathname;
const isUK = pathname.startsWith('/uk/');
const isMY = pathname.startsWith('/my/');
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://autoflow-solutions.com';

// Generate reciprocal hreflang URLs
let cleanPath = pathname;
if (isUK) cleanPath = pathname.replace(/^\/uk/, '') || '/';
if (isMY) cleanPath = pathname.replace(/^\/my/, '') || '/';
if (cleanPath === '') cleanPath = '/';

const urlInt = `${siteUrl}${cleanPath.replace(/\/$/, '') || '/'}`;
const urlMy = `${siteUrl}/my${cleanPath.replace(/\/$/, '') || '/'}`;
const urlUk = `${siteUrl}/uk${cleanPath.replace(/\/$/, '') || '/'}`;

// Build Breadcrumb schema from pathname
const pathParts = pathname.replace(/\/$/, '').split('/').filter(Boolean);
const breadcrumbItems = [
	{ "@type": "ListItem", position: 1, name: "Home", item: siteUrl + '/' }
];
pathParts.forEach((part, i) => {
	const label = part.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
	const url = siteUrl + '/' + pathParts.slice(0, i + 1).join('/') + '/';
	breadcrumbItems.push({ "@type": "ListItem", position: i + 2, name: label, item: url });
});
const showBreadcrumb = pathParts.length > 0;
const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: breadcrumbItems
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Autoflow Solutions</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		
		<!-- Regional Targeting (hreflang) -->
		<link rel="alternate" hreflang="en-my" href={urlMy} />
		<link rel="alternate" hreflang="en-gb" href={urlUk} />
		<link rel="alternate" hreflang="x-default" href={urlInt} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Outfit:wght@400;700&family=Barlow+Condensed:wght@600;700;900&display=swap" rel="stylesheet">
	</head>
	<body>
		<Navbar />
		<slot />
		<Footer />
		<!-- JSON-LD: Organization -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "Organization",
				"name": "Autoflow Solutions",
				"url": "https://autoflow-solutions.com",
				"logo": "https://autoflow-solutions.com/favicon.svg",
				"description": "AI Automation Agency specializing in done-for-you AI agents, back-office automation, and AI voice agents for SMEs and professional services.",
				"sameAs": [
					"https://www.linkedin.com/company/autoflow-solutions"
				]
			}
		</script>
		
		<!-- JSON-LD: Breadcrumb (auto-generated for all sub-pages) -->
		{showBreadcrumb && <script type="application/ld+json" set:text={JSON.stringify(breadcrumbSchema)} />}
		
		<!-- JSON-LD: Page-specific schemas (Service, FAQ, etc.) -->
		{schemaData && <script type="application/ld+json" set:text={JSON.stringify(Array.isArray(schemaData) ? schemaData : [schemaData])} />}
		
		<!-- Cal.com embed -->
		<script is:inline>
			(function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; typeof namespace === "string" ? (cal.ns[namespace] = cal.ns[namespace] || api) : p(cal, ar); return; } p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
			Cal("init", {origin:"https://cal.com"});
			Cal("ui", {"styles":{"branding":{"brandColor":"#000000"}},"hideEventTypeDetails":false,"layout":"month_view"});
		</script>
	</body>
</html>
