---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Schema from '../components/Schema.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/variant.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	schema?: Record<string, any> | Record<string, any>[];
	schemaData?: Record<string, any> | Record<string, any>[];
	noindex?: boolean;
}

const {
	title,
	description = "AI Automation for SMEs and Professional Services. Scale your business, not your payroll with custom AI agents.",
	image = "/AS%20logos/logo-square-dark-initials.png",
	schema,
	schemaData,
	noindex = false
} = Astro.props;

const combinedSchema = schema || schemaData;

const sanitizedPath = Astro.url.pathname.endsWith('/') && Astro.url.pathname.length > 1 
	? Astro.url.pathname.slice(0, -1) 
	: Astro.url.pathname;
const canonicalURL = new URL(sanitizedPath, "https://autoflow-solutions.com");

const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"name": "Autoflow Solutions",
	"url": "https://autoflow-solutions.com",
	"logo": "https://autoflow-solutions.com/AS%20logos/logo-square-dark-initials.png",
	"description": "AI Automation Agency providing custom AI agents and automation pipelines for SMEs and Professional Services.",
	"sameAs": [
		"https://www.linkedin.com/company/autoflow-solutions"
	],
	"contactPoint": {
		"@type": "ContactPoint",
		"contactType": "customer service",
		"url": "https://autoflow-solutions.com/services#request"
	}
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Autoflow Solutions",
	"url": "https://autoflow-solutions.com",
	"potentialAction": {
		"@type": "SearchAction",
		"target": "https://autoflow-solutions.com/search?q={search_term_string}",
		"query-input": "required name=search_term_string"
	}
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/AS%20logos/logo-square-dark-initials.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title} | Autoflow Solutions</title>
		<meta name="title" content={`${title} | Autoflow Solutions`} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		{noindex && <meta name="robots" content="noindex, follow" />}

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={`${title} | Autoflow Solutions`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={`${title} | Autoflow Solutions`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- Structured Data -->
		<Schema item={organizationSchema} />
		<Schema item={websiteSchema} />
		{combinedSchema && (Array.isArray(combinedSchema) ? combinedSchema.map(item => <Schema item={item} />) : <Schema item={combinedSchema} />)}

		
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-6ETHYCNH3X"></script>
		<script is:inline>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  gtag('js', new Date());

		  gtag('config', 'G-6ETHYCNH3X');
		</script>

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Outfit:wght@400;700&family=Barlow+Condensed:wght@600;700;900&display=swap" rel="stylesheet">

		<!-- SEO: Regional Alt Versions -->
		<link rel="alternate" hreflang="en-MY" href={`https://autoflow-solutions.com/my${sanitizedPath.replace(/^\/(my|ms|uk)/, '')}`} />
		<link rel="alternate" hreflang="ms-MY" href={`https://autoflow-solutions.com/ms${sanitizedPath.replace(/^\/(my|ms|uk)/, '')}`} />
		<link rel="alternate" hreflang="en-GB" href={`https://autoflow-solutions.com/uk${sanitizedPath.replace(/^\/(my|ms|uk)/, '')}`} />
		<link rel="alternate" hreflang="en" href={`https://autoflow-solutions.com${sanitizedPath.replace(/^\/(my|ms|uk)/, '')}`} />
		<link rel="alternate" hreflang="x-default" href={`https://autoflow-solutions.com${sanitizedPath.replace(/^\/(my|ms|uk)/, '')}`} />
	</head>
	<body>
		<Navbar />
		<slot />
		<Analytics />
		<SpeedInsights />
		<Footer />
		<!-- Cal.com embed -->
		<script is:inline>
			(function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; typeof namespace === "string" ? (cal.ns[namespace] = cal.ns[namespace] || api) : p(cal, ar); return; } p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
			Cal("init", {origin:"https://cal.com"});
			Cal("ui", {"styles":{"branding":{"brandColor":"#000000"}},"hideEventTypeDetails":false,"layout":"month_view"});
		</script>
	</body>
</html>
