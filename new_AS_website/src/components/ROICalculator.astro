---
interface Props {
  defaultCurrency?: 'MYR' | 'USD' | 'GBP' | 'EUR';
}

const { defaultCurrency = 'MYR' } = Astro.props;
---

<div class="roi-tool-content" data-default-currency={defaultCurrency}>
  <!-- HERO -->
  <section class="hero-section" aria-label="Tool introduction">
    <div class="hero-inner">
        <div class="hero-badge">FREE TOOL &mdash; NO EMAIL REQUIRED</div>
        <h1 class="hero-h1">SEE YOUR <span>AUTOMATION ROI</span><br>IN 60 SECONDS</h1>
        <p class="hero-sub">ENTER YOUR NUMBERS. GET YOUR REAL PAYBACK PROJECTION.</p>
        <div class="hero-body">
          <p>Most operators guess at ROI. This calculator doesn't guess.</p>
          <p>Enter your labor costs and manual hours. Get a projection of annual savings, payback period, and hours recovered -- built on real automation benchmarks.</p>
          <p>No sales pitch. Just the numbers.</p>
        </div>
      </div>
  </section>

  <!-- MAIN TOOL -->
  <main id="main-content" role="main">
    <div class="tool-wrapper">
      <!-- INPUTS -->
      <div class="inputs-column" id="inputs-column">
        <div>
          <div class="page-intro">
            <span class="page-intro__eyebrow">ROI FORECASTER</span>
            <h2 class="page-intro__title">YOUR NUMBERS</h2>
            <p class="page-intro__subtitle">Adjust the sliders. Your savings projection updates in real time.</p>
          </div>

          <div class="currency-switcher" role="group" aria-label="Select currency">
            <button class="currency-btn active" data-currency="MYR" type="button"><span class="currency-btn__flag">🇲🇾</span> MYR</button>
            <button class="currency-btn" data-currency="USD" type="button"><span class="currency-btn__flag">🇺🇸</span> USD</button>
            <button class="currency-btn" data-currency="GBP" type="button"><span class="currency-btn__flag">🇬🇧</span> GBP</button>
            <button class="currency-btn" data-currency="EUR" type="button"><span class="currency-btn__flag">🇪🇺</span> EUR</button>
          </div>

          <div class="progress-block">
            <div class="progress-bar-track" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" id="progress-bar">
              <div class="progress-bar-fill" id="progress-fill" style="--progress-pct:0%"></div>
            </div>
            <p class="progress-label" id="progress-label" aria-live="polite">0 of 5 fields adjusted</p>
          </div>

          <!-- Card: Your Team -->
          <section class="input-card" aria-labelledby="card-team-title">
            <div class="input-card__header">
              <div class="input-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              </div>
              <h3 class="input-card__title" id="card-team-title">YOUR TEAM</h3>
            </div>

            <div class="slider-field">
              <div class="slider-field__top-row">
                <label class="slider-field__label" for="staff-count">EMPLOYEES ON MANUAL TASKS</label>
                <div class="slider-field__value-group">
                  <span class="slider-field__value" id="staff-count-display" aria-live="polite">5</span>
                  <span class="slider-field__unit">people</span>
                </div>
              </div>
              <input type="range" class="slider-field__input" id="staff-count" min="1" max="50" value="5" step="1" aria-describedby="staff-count-help">
              <p class="slider-field__helper" id="staff-count-help">Count only the people whose time would be freed -- not your whole headcount.</p>
            </div>

            <div class="slider-field">
              <div class="slider-field__top-row">
                <label class="slider-field__label" for="avg-salary">AVG MONTHLY SALARY</label>
                <div class="slider-field__value-group">
                  <span class="slider-field__value" id="avg-salary-display" aria-live="polite">RM 4,000</span>
                </div>
              </div>
              <input type="range" class="slider-field__input" id="avg-salary" min="1500" max="15000" value="4000" step="500" aria-describedby="avg-salary-help">
              <p class="slider-field__helper" id="avg-salary-help">Use gross salary. For freelancers, estimate equivalent monthly cost.</p>
            </div>

            <div class="slider-field">
              <div class="slider-field__top-row">
                <label class="slider-field__label" for="repetitive-hours">MANUAL HOURS / WEEK / PERSON</label>
                <div class="slider-field__value-group">
                  <span class="slider-field__value" id="repetitive-hours-display" aria-live="polite">10</span>
                  <span class="slider-field__unit">hrs/wk</span>
                </div>
              </div>
              <input type="range" class="slider-field__input" id="repetitive-hours" min="2" max="40" value="10" step="1" aria-describedby="repetitive-hours-help">
              <p class="slider-field__helper" id="repetitive-hours-help">Data entry, follow-ups, report building, scheduling -- anything that runs the same every time.</p>
            </div>
          </section>

          <!-- Card: Your Investment -->
          <section class="input-card" aria-labelledby="card-investment-title">
            <div class="input-card__header">
              <div class="input-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>
                </svg>
              </div>
              <h3 class="input-card__title" id="card-investment-title">YOUR INVESTMENT</h3>
            </div>

            <p class="slider-field__label" style="margin-bottom: 0.5rem;">CHOOSE AN AUTOMATION ENGINE</p>
            <select id="engine-tier" class="tier-selector">
              <option value="engagement">ENGAGEMENT ENGINE</option>
              <option value="operations" selected>OPERATIONS ENGINE</option>
              <option value="voice">VOICE ENGINE</option>
              <option value="execution">EXECUTION ENGINE (BALLPARK)</option>
              <option value="enterprise">MANAGED ENTERPRISE</option>
              <option value="custom">CUSTOM / BESPOKE</option>
            </select>

            <div id="tier-summary-box" class="tier-summary">
              <div class="tier-summary__item">
                <span class="tier-summary__label">SETUP</span>
                <span class="tier-summary__value" id="summary-setup">--</span>
              </div>
              <div class="tier-summary__item">
                <span class="tier-summary__label">MONTHLY RETAINER</span>
                <span class="tier-summary__value" id="summary-monthly">--</span>
                <span class="tier-summary__note">For small fixes & adjustments</span>
              </div>
            </div>

            <!-- Hidden Manual Sliders -->
            <div id="manual-investment" class="hidden">
              <div class="slider-field">
                <div class="slider-field__top-row">
                  <label class="slider-field__label" for="setup-fee">SETUP INVESTMENT</label>
                  <div class="slider-field__value-group">
                    <span class="slider-field__value" id="setup-fee-display" aria-live="polite">--</span>
                  </div>
                </div>
                <input type="range" class="slider-field__input" id="setup-fee" min="2000" max="50000" value="4500" step="500">
              </div>

              <div class="slider-field">
                <div class="slider-field__top-row">
                  <label class="slider-field__label" for="monthly-retainer">MONTHLY MAINTENANCE</label>
                  <div class="slider-field__value-group">
                    <span class="slider-field__value" id="monthly-retainer-display" aria-live="polite">--</span>
                    <span class="slider-field__unit">/mo</span>
                  </div>
                </div>
                <input type="range" class="slider-field__input" id="monthly-retainer" min="0" max="10000" value="1750" step="10">
              </div>
            </div>
          </section>

          <!-- Advanced Assumptions -->
          <div class="assumptions-section">
            <button class="assumptions-toggle" id="assumptions-toggle" aria-expanded="false" aria-controls="assumptions-body" type="button">
              <div class="assumptions-toggle__label-group">
                <span class="assumptions-toggle__title">FINE-TUNE YOUR ESTIMATE</span>
                <span class="assumptions-toggle__subtitle">Advanced -- adjust automation assumptions</span>
              </div>
              <svg class="assumptions-toggle__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <div class="assumptions-body" id="assumptions-body" role="region" aria-labelledby="assumptions-toggle">
              <div class="assumptions-body__inner">

                <div class="slider-field">
                  <div class="slider-field__top-row">
                    <label class="slider-field__label" for="automation-rate">EFFICIENCY GAIN (%)</label>
                    <div class="slider-field__value-group">
                      <span class="slider-field__value" id="automation-rate-display" aria-live="polite">70</span>
                      <span class="slider-field__unit">%</span>
                    </div>
                  </div>
                  <input type="range" class="slider-field__input" id="automation-rate" min="30" max="90" value="70" step="5">
                  <p class="slider-field__helper">Percentage of manual time the automation replaces. 70--85% is realistic for most workflows.</p>
                </div>

                <div class="slider-field">
                  <div class="slider-field__top-row">
                    <label class="slider-field__label" for="error-reduction">ERROR REDUCTION (%)</label>
                    <div class="slider-field__value-group">
                      <span class="slider-field__value" id="error-reduction-display" aria-live="polite">40</span>
                      <span class="slider-field__unit">%</span>
                    </div>
                  </div>
                  <input type="range" class="slider-field__input" id="error-reduction" min="10" max="80" value="40" step="5">
                  <p class="slider-field__helper">Estimated drop in errors and rework. Manual errors cost time to fix -- 30% reduction compounds fast.</p>
                </div>

                <div class="slider-field">
                  <div class="slider-field__top-row">
                    <label class="slider-field__label" for="revenue-impact">PRODUCTIVITY REINVESTMENT (%)</label>
                    <div class="slider-field__value-group">
                      <span class="slider-field__value" id="revenue-impact-display" aria-live="polite">5</span>
                      <span class="slider-field__unit">%</span>
                    </div>
                  </div>
                  <input type="range" class="slider-field__input" id="revenue-impact" min="0" max="20" value="5" step="1">
                  <p class="slider-field__helper">% of recovered hours redirected into revenue-generating work. Faster follow-up, fewer missed leads. Conservative: 3--8%.</p>
                </div>

              </div>
            </div>
          </div>

          <a href="#results-panel" class="mobile-see-results">
            SEE YOUR RESULTS
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </a>

        </div>
      </div>
      <!-- /inputs-column -->

      <!-- RESULTS -->
      <aside class="results-column" id="results-panel" aria-label="ROI calculation results">
        <div id="enterprise-overlay" class="enterprise-overlay hidden">
          <h2 class="enterprise-overlay__title">CUSTOM QUOTE REQUIRED</h2>
          <p class="enterprise-overlay__body">Enterprise deployments process 10k+ interactions monthly. These require dedicated RAG architectures and custom SLAs.</p>
          <button data-cal-link="autoflow-solutions/book-a-discovery-call" data-cal-config='{"layout":"month_view"}' class="btn-primary" style="max-width: 240px; border: none; margin: 0 auto;">SCHEDULE ARCHITECT CALL</button>
        </div>

        <div id="results-live-region" aria-live="polite" aria-atomic="false" class="visually-hidden"></div>

        <div id="badge-strong-roi" class="badge-strong-roi hidden">STRONG ROI</div>

        <div class="results-hero">
          <span class="results-hero__eyebrow">ANNUAL SAVINGS</span>
          <p class="results-hero__value" id="result-annual-savings">RM 0</p>
          <p class="results-hero__subtext">Labor + error cost reduction</p>
        </div>

        <div class="results-secondary">
          <div class="metric-tile">
            <span class="metric-tile__label">PAYBACK PERIOD</span>
            <span class="metric-tile__value" id="result-payback">--</span>
            <span class="metric-tile__context">Time to recover setup cost</span>
          </div>
          <div class="metric-tile roi-tile" id="roi-tile" data-roi-tier="ok">
            <span class="metric-tile__label">FIRST-YEAR ROI</span>
            <span class="metric-tile__value" id="result-roi-pct">--%</span>
            <span class="metric-tile__context">Return on setup investment</span>
          </div>
        </div>

        <p class="results-opex-note">All system & API costs (OpenAI, WhatsApp, etc.) are borne by the client using their own accounts.</p>

        <div class="results-projection">
          <p class="results-projection__label">3-YEAR NET BENEFIT</p>
          <div class="projection-bars" aria-hidden="true">
            <div class="projection-bar-col">
              <div class="projection-bar-col__track"><div class="projection-bar-col__bar" id="bar-year1" style="--bar-height:25%"></div></div>
              <span class="projection-bar-col__year">YR 1</span>
              <span class="projection-bar-col__value" id="result-year1">--</span>
            </div>
            <div class="projection-bar-col">
              <div class="projection-bar-col__track"><div class="projection-bar-col__bar" id="bar-year2" style="--bar-height:55%"></div></div>
              <span class="projection-bar-col__year">YR 2</span>
              <span class="projection-bar-col__value" id="result-year2">--</span>
            </div>
            <div class="projection-bar-col">
              <div class="projection-bar-col__track"><div class="projection-bar-col__bar" id="bar-year3" style="--bar-height:85%"></div></div>
              <span class="projection-bar-col__year">YR 3</span>
              <span class="projection-bar-col__value" id="result-year3">--</span>
            </div>
          </div>
          <dl class="visually-hidden">
            <dt>Year 1 cumulative</dt><dd id="result-year1-sr">--</dd>
            <dt>Year 2 cumulative</dt><dd id="result-year2-sr">--</dd>
            <dt>Year 3 cumulative</dt><dd id="result-year3-sr">--</dd>
          </dl>
        </div>

        <div class="results-hours">
          <div class="results-hours__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <p class="results-hours__primary" id="result-hours-freed">0 HRS/WK FREED</p>
            <p class="results-hours__secondary" id="result-fte">Equivalent to 0.0 full-time staff</p>
          </div>
        </div>

        <p class="results-warning hidden" id="msg-payback-warning"></p>

        <div class="results-cta">
          <h2 class="results-cta__heading">BUILD THIS PIPELINE</h2>
          <p class="results-cta__body">Your free strategy call is 30 minutes. We map out exactly where to start and what the build looks like for your business.</p>
          <button data-cal-link="autoflow-solutions/book-a-discovery-call" data-cal-config='{"layout":"month_view"}' class="btn-primary" style="border: none;">BOOK STRATEGY CALL</button>
          <p class="results-cta__trust">No pitch deck. No obligation. Just the numbers.</p>
        </div>

        <div class="results-actions">
          <button class="btn-share" id="share-btn" type="button" aria-label="Copy link to results">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
            </svg>
            <span id="share-btn-label">SHARE</span>
          </button>
          <button class="btn-reset" id="reset-btn" type="button">RESET</button>
        </div>

        <p class="results-disclaimer">Projections are estimates based on your inputs and standard automation benchmarks. Actual results depend on process complexity, implementation quality, and team adoption. Use this as a directional guide, not a guarantee.</p>

      </aside>
      <!-- /results-column -->
    </div>
  </main>

  <!-- TRUST STRIP -->
  <div class="trust-strip">
    <div class="site-container">
      <div class="trust-strip__inner">
        <h2 class="trust-strip__headline">YOUR OPS ARE EITHER WORKING FOR YOU OR COSTING YOU.</h2>
        <a href="https://ai-self-audit.autoflow-solutions.com/" class="trust-strip__cta">START YOUR FREE AI AUDIT</a>
      </div>
    </div>
  </div>
</div>

<style>
  .roi-tool-content {
    --black:       #000000;
    --chartreuse:  #C4EF17;
    --white:       #FFFFFF;
    --grey-100:    #F4F4F4;
    --grey-200:    #E5E5E5;
    --grey-400:    #A3A3A3;
    --grey-600:    #525252;
    --font-display: 'Oswald', sans-serif;
    --font-body:    'Inter', sans-serif;
    --t:           200ms ease;
    --t-slow:      350ms ease;
  }

  /* Reset local tool scope specifically to avoid affecting global Astro layout */
  .roi-tool-content :global(*) { box-sizing: border-box; }
  
  .hero-section {
    background: var(--black);
    padding: 8rem 0 5rem;
    position: relative; overflow: hidden;
  }
  .hero-section::before {
    content: ''; position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 28px 28px; pointer-events: none;
  }
  .hero-inner { position: relative; z-index: 1; max-width: 1200px; padding: 0 2rem; margin: 0; text-align: left; }
  .hero-badge {
    display: inline-flex; align-items: center;
    background: var(--chartreuse); color: var(--black);
    font-weight: 700; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 5px 12px; border-radius: 2px; margin-bottom: 1.5rem;
  }
  .hero-h1 {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(2.75rem, 7vw, 5.5rem);
    line-height: 0.95; text-transform: uppercase;
    color: var(--white); letter-spacing: -0.01em; margin-bottom: 1.25rem;
  }
  .hero-h1 span { color: var(--chartreuse); }
  .hero-sub {
    font-weight: 600; font-size: 0.8125rem; letter-spacing: 0.12em;
    text-transform: uppercase; color: rgba(255,255,255,0.55); margin-bottom: 1.5rem;
  }
  .hero-body { color: rgba(255,255,255,0.7); font-size: 1rem; line-height: 1.7; max-width: 560px; }

  /* Fix for huge icons */
  .roi-tool-content svg {
    width: 1em;
    height: 1em;
    display: inline-block;
    vertical-align: middle;
  }
  .input-card__icon svg { width: 16px; height: 16px; }
  .assumptions-toggle__chevron { width: 20px; height: 20px; transition: transform var(--t); }
  .results-hours__icon svg { width: 24px; height: 24px; }
  .btn-share svg { width: 16px; height: 16px; }
  .mobile-see-results svg { width: 20px; height: 20px; margin-left: 8px; }

  .tool-wrapper { display: flex; min-height: 100vh; align-items: flex-start; background: #fff; border-top: 1px solid var(--grey-200); }
  .inputs-column {
    flex: 0 0 44%; min-width: 0; background: #F8F8F8;
    padding: 1.75rem 1.75rem 4rem; border-right: 1px solid var(--grey-200);
  }
  .results-column {
    flex: 1; min-width: 340px;
    background: var(--black);
    position: sticky; top: 0;
    height: 100vh; overflow-y: auto;
    padding: 2rem 3rem 3rem; flex-shrink: 0;
  }

  .page-intro { margin-bottom: 1.25rem; }
  .page-intro__eyebrow { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; color: var(--grey-400); }
  .page-intro__title { font-family: var(--font-display); font-weight: 900; font-size: 1.75rem; text-transform: uppercase; margin-top: 0.25rem; }

  .currency-switcher { display: flex; gap: 4px; margin-bottom: 1.5rem; }
  .currency-btn { padding: 6px 12px; border: 1px solid var(--grey-200); border-radius: 4px; font-size: 0.75rem; font-weight: 600; background: #fff; color: var(--grey-600); transition: all 0.2s; cursor: pointer; }
  .currency-btn.active { background: var(--black); color: var(--white); border-color: var(--black); }

  .input-card { background: var(--white); border: 1px solid var(--grey-200); border-radius: 6px; padding: 1.25rem; margin-bottom: 0; }
  .input-card + .input-card { border-top: none; border-radius: 0; }
  .input-card:last-of-type { border-radius: 0 0 6px 6px; }
  .input-card__header { display: flex; align-items: center; gap: 8px; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--grey-200); }
  .input-card__icon { width: 26px; height: 26px; background: var(--black); color: var(--chartreuse); border-radius: 4px; display: flex; align-items: center; justify-content: center; padding: 5px; }

  .slider-field { margin-bottom: 1rem; }
  .slider-field__top-row { display: flex; justify-content: space-between; margin-bottom: 0.5rem; }
  .slider-field__label { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; color: var(--grey-600); }
  .slider-field__value { font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; }

  .slider-field__input {
    -webkit-appearance: none; width: 100%; height: 4px; background: var(--grey-200); border-radius: 2px; outline: none;
    background: linear-gradient(to right, var(--chartreuse) 0%, var(--chartreuse) var(--slider-pct, 0%), var(--grey-200) var(--slider-pct, 0%), var(--grey-200) 100%);
  }
  .slider-field__input::-webkit-slider-thumb { -webkit-appearance: none; width: 18px; height: 18px; border-radius: 50%; background: var(--black); border: 2px solid var(--chartreuse); cursor: pointer; }

  .tier-selector { width: 100%; padding: 12px; border: 2px solid var(--black); font-family: var(--font-display); font-weight: 700; font-size: 1rem; text-transform: uppercase; background: var(--white); border-radius: 4px; margin-bottom: 1rem; }
  .tier-summary { background: var(--grey-100); border: 1px solid var(--grey-200); border-radius: 4px; padding: 1rem; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .tier-summary__label { font-size: 0.6rem; font-weight: 700; color: var(--grey-600); text-transform: uppercase; display: block; }
  .tier-summary__value { font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: var(--black); display: block; }
  .tier-summary__note { font-size: 0.55rem; color: var(--grey-400); font-weight: 500; display: block; margin-top: 2px; }

  .results-opex-note { font-size: 0.625rem; color: var(--grey-400); text-align: center; margin-bottom: 2rem; padding: 0 1rem; opacity: 0.8; }

  /* Assumptions section refined */
  .assumptions-section { margin-top: 1.5rem; border: 1px solid var(--grey-200); border-radius: 6px; overflow: hidden; background: #fff; }
  .assumptions-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; padding: 1.25rem; background: #fff; border: none; cursor: pointer; text-align: left; }
  .assumptions-toggle:hover { background: var(--grey-100); }
  .assumptions-toggle__title { display: block; font-size: 0.75rem; font-weight: 800; color: var(--black); }
  .assumptions-toggle__subtitle { display: block; font-size: 0.625rem; color: var(--grey-400); margin-top: 2px; }
  .assumptions-toggle[aria-expanded="true"] .assumptions-toggle__chevron { transform: rotate(180deg); }
  
  .assumptions-body { display: none; padding: 0 1.25rem 1.25rem; background: #fff; }
  .assumptions-body.is-open { display: block; }

  .results-hero { margin-bottom: 1.75rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgba(196,239,23,0.12); }
  .results-hero__value { font-family: var(--font-display); font-weight: 900; font-size: 3.5rem; color: var(--chartreuse); line-height: 1; }
  
  .results-secondary { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem; }
  .metric-tile { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; padding: 1.25rem; }
  .metric-tile__label { font-size: 0.625rem; font-weight: 800; text-transform: uppercase; color: var(--grey-400); letter-spacing: 0.05em; margin-bottom: 0.5rem; display: block; }
  .metric-tile__value { font-family: var(--font-display); font-weight: 700; font-size: 1.75rem; color: var(--white); line-height: 1; }
  .metric-tile__context { font-size: 0.625rem; color: var(--grey-400); margin-top: 0.5rem; display: block; }

  .results-hero__eyebrow { font-size: 0.75rem; font-weight: 800; color: var(--grey-400); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 0.5rem; display: block; }
  .results-hero__subtext { font-size: 0.75rem; color: var(--grey-400); margin-top: 0.5rem; }

  .results-projection { margin-bottom: 2rem; }
  .results-projection__label { font-size: 0.6875rem; font-weight: 800; color: var(--grey-400); text-transform: uppercase; margin-bottom: 1rem; }
  .projection-bars { display: flex; align-items: flex-end; gap: 12px; height: 100px; margin-top: 1rem; }
  .projection-bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; height: 100%; }
  .projection-bar-col__track { width: 100%; height: 70px; background: rgba(255,255,255,0.05); border-radius: 2px; position: relative; overflow: hidden; }
  .projection-bar-col__bar { width: 100%; background: var(--chartreuse); height: var(--bar-height, 10%); position: absolute; bottom: 0; transition: height var(--t-slow); opacity: 0.9; }
  .projection-bar-col__year { font-size: 0.6rem; font-weight: 700; color: var(--grey-400); margin-top: 8px; }
  .projection-bar-col__value { font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; color: var(--white); margin-top: 2px; }

  .results-hours { display: flex; align-items: center; gap: 1rem; padding: 1.25rem; background: rgba(196,239,23,0.05); border: 1px solid rgba(196,239,23,0.2); border-radius: 6px; margin-bottom: 2rem; }
  .results-hours__icon { width: 40px; height: 40px; border-radius: 50%; background: var(--chartreuse); color: var(--black); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .results-hours__primary { font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: var(--chartreuse); line-height: 1.2; }
  .results-hours__secondary { font-size: 0.75rem; color: var(--grey-400); margin-top: 2px; }

  .btn-primary { display: block; width: 100%; padding: 16px; background: var(--chartreuse); color: var(--black); font-weight: 800; text-transform: uppercase; border-radius: 4px; text-align: center; text-decoration: none; cursor: pointer; transition: transform 0.2s; }
  .btn-primary:active { transform: scale(0.98); }

  .trust-strip { background: var(--chartreuse); padding: 5rem 0; }
  .trust-strip__inner { display: flex; justify-content: space-between; align-items: center; max-width: 1200px; margin: 0 auto; padding: 0 1.25rem; }
  .trust-strip__headline { font-family: var(--font-display); font-weight: 900; font-size: 2.25rem; text-transform: uppercase; max-width: 600px; color: #000; }
  .trust-strip__cta { padding: 14px 28px; background: var(--black); color: var(--white); font-weight: 700; text-transform: uppercase; border-radius: 4px; text-decoration: none; }

  /* Mobile results floating button fix */
  .mobile-see-results {
    display: none;
    position: fixed; bottom: 20px; right: 20px;
    background: var(--chartreuse); color: var(--black);
    padding: 12px 20px; border-radius: 50px;
    font-weight: 800; font-size: 0.75rem;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    z-index: 100; text-decoration: none;
  }
  @media (max-width: 900px) {
    .mobile-see-results { display: flex; align-items: center; }
  }

  .results-actions { display: flex; gap: 10px; margin-top: 1.5rem; margin-bottom: 2rem; }
  .btn-share, .btn-reset { flex: 1; padding: 12px; border-radius: 4px; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.2s; }
  .btn-share { background: rgba(255,255,255,0.1); color: var(--white); border: 1px solid rgba(255,255,255,0.2); }
  .btn-share:hover { background: rgba(255,255,255,0.2); }
  .btn-reset { background: transparent; color: var(--grey-400); border: 1px solid var(--grey-600); }
  .btn-reset:hover { border-color: var(--grey-400); color: var(--white); }

  .results-cta { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 2rem; margin: 3rem 0; text-align: center; }
  .results-cta__heading { font-family: var(--font-display); font-weight: 900; font-size: 1.5rem; color: var(--white); margin-bottom: 1rem; text-transform: uppercase; }
  .results-cta__body { font-size: 0.875rem; color: var(--grey-400); margin-bottom: 1.5rem; line-height: 1.6; }
  .results-cta__trust { font-size: 0.625rem; color: var(--grey-400); margin-top: 1rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .results-warning { background: rgba(255,100,0,0.1); border: 1px solid rgba(255,100,0,0.3); color: #ffca28; padding: 1rem; border-radius: 4px; font-size: 0.75rem; margin-top: 1rem; }

  .results-disclaimer { font-size: 0.65rem; line-height: 1.5; color: var(--grey-400); margin-top: 2rem; }

  @media (max-width: 900px) {
    .tool-wrapper { flex-direction: column; }
    .inputs-column, .results-column { width: 100%; flex: none; height: auto; position: static; }
    .trust-strip__inner { flex-direction: column; text-align: center; gap: 2rem; }
    .results-column { padding: 2rem 1.25rem; }
  }

  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  .hidden { display: none !important; }
</style>

<script is:inline>
(function () {
  'use strict';
  
  const CURRENCIES = {
    MYR: { symbol: 'RM ', locale: 'en-MY', salary: { min: 1500, max: 15000, default: 4000, step: 500 }, setup: { min: 3000, max: 50000, default: 5400, step: 500 }, retainer: { min: 250, max: 10000, default: 540, step: 10 } },
    USD: { symbol: '$', locale: 'en-US', salary: { min: 2000, max: 12000, default: 4500, step: 500 }, setup: { min: 899, max: 20000, default: 1699, step: 50 }, retainer: { min: 150, max: 5000, default: 170, step: 10 } },
    GBP: { symbol: '\u00a3', locale: 'en-GB', salary: { min: 1500, max: 8000, default: 2800, step: 250 }, setup: { min: 719, max: 15000, default: 1319, step: 50 }, retainer: { min: 149, max: 4000, default: 200, step: 10 } },
    EUR: { symbol: '\u20ac', locale: 'de-DE', salary: { min: 1500, max: 8000, default: 2500, step: 250 }, setup: { min: 839, max: 15000, default: 1499, step: 50 }, retainer: { min: 150, max: 4000, default: 150, step: 20 } }
  };
  
  const TIER_PRICES = {
    MYR: { engagement: { setup: 3000, monthly: 300 }, operations: { setup: 5400, monthly: 540 }, voice: { setup: 6000, monthly: 600 }, execution: { setup: 6000, monthly: 600 } },
    USD: { engagement: { setup: 899, monthly: 150 }, operations: { setup: 1699, monthly: 170 }, voice: { setup: 1999, monthly: 200 }, execution: { setup: 1999, monthly: 200 } },
    GBP: { engagement: { setup: 719, monthly: 149 }, operations: { setup: 1319, monthly: 200 }, voice: { setup: 1499, monthly: 249 }, execution: { setup: 1499, monthly: 249 } },
    EUR: { engagement: { setup: 839, monthly: 150 }, operations: { setup: 1499, monthly: 150 }, voice: { setup: 1699, monthly: 170 }, execution: { setup: 1699, monthly: 170 } }
  };

  let activeCurrency = document.querySelector('.roi-tool-content').dataset.defaultCurrency || 'MYR';
  const STATIC_DEFAULTS = { 'staff-count': 5, 'repetitive-hours': 10, 'automation-rate': 70, 'error-reduction': 40, 'revenue-impact': 5 };
  const MONEY_SLIDERS = ['avg-salary', 'setup-fee', 'monthly-retainer'];

  function get(id) { return document.getElementById(id); }
  function gv(id)  { return parseFloat(get(id)?.value) || 0; }
  
  function fmt(v, short) {
    if (!isFinite(v) || isNaN(v)) return '--';
    const cfg = CURRENCIES[activeCurrency];
    const abs = Math.abs(v);
    if (short && abs >= 1000) return (v < 0 ? '-' : '') + cfg.symbol + (abs / 1000).toFixed(1) + 'k';
    return (v < 0 ? '-' : '') + cfg.symbol + Math.round(abs).toLocaleString(cfg.locale);
  }

  function calc() {
    const staff = gv('staff-count'), salary = gv('avg-salary'), hrs = gv('repetitive-hours'), setup = Math.max(1, gv('setup-fee')), monthly = gv('monthly-retainer');
    const autoRate = gv('automation-rate')/100, errRate = gv('error-reduction')/100, revRate = gv('revenue-impact')/100;
    const annualLabor = staff * (salary/160) * hrs * 52, autoSav = annualLabor * autoRate, errSav = annualLabor * errRate * 0.25, revSav = annualLabor * revRate;
    const netAnnual = autoSav + errSav + revSav - (monthly * 12);
    return { netAnnual: netAnnual, roi: (netAnnual/setup)*100, payback: netAnnual > 0 ? setup/(netAnnual/12) : Infinity, yr1: netAnnual-setup, yr2: (netAnnual*2)-setup, yr3: (netAnnual*3)-setup, hoursFreed: staff*hrs*autoRate, fte: (staff*hrs*autoRate)/40 };
  }

  function updateUI(r) {
    get('result-annual-savings').textContent = fmt(r.netAnnual);
    get('result-payback').textContent = r.payback === Infinity ? '--' : Math.ceil(r.payback) + ' mo';
    get('result-roi-pct').textContent = (r.roi >= 0 ? '+' : '') + Math.round(r.roi) + '%';
    get('result-hours-freed').textContent = r.hoursFreed.toFixed(1) + ' HRS/WK FREED';
    get('result-fte').textContent = 'Equivalent to ' + r.fte.toFixed(1) + ' staff';
    
    const maxV = Math.max(Math.abs(r.yr1), Math.abs(r.yr2), Math.abs(r.yr3), 1);
    ['yr1','yr2','yr3'].forEach((y, i) => {
      get(`bar-year${i+1}`).style.setProperty('--bar-height', (Math.max(5, (r[y]/maxV)*100)) + '%');
      get(`result-year${i+1}`).textContent = fmt(r[y], true);
    });
  }

  function updateSlider(id) {
    const el = get(id); if (!el) return;
    const pct = ((el.value - el.min) / (el.max - el.min)) * 100;
    el.style.setProperty('--slider-pct', pct + '%');
    const dis = get(id + '-display'); if (dis) dis.textContent = (MONEY_SLIDERS.indexOf(id) !== -1) ? fmt(parseFloat(el.value)) : el.value;
  }

  function applyTierSelection() {
    const tier = get('engine-tier').value;
    const manualBox = get('manual-investment'), summaryBox = get('tier-summary-box'), overlay = get('enterprise-overlay');
    manualBox.classList.add('hidden'); summaryBox.classList.remove('hidden'); overlay.classList.add('hidden');

    if (tier === 'custom') { manualBox.classList.remove('hidden'); summaryBox.classList.add('hidden'); }
    else if (tier === 'enterprise') { overlay.classList.remove('hidden'); summaryBox.classList.add('hidden'); }
    else {
      const p = TIER_PRICES[activeCurrency][tier];
      get('setup-fee').value = p.setup; get('monthly-retainer').value = p.monthly;
      get('summary-setup').textContent = fmt(p.setup); get('summary-monthly').textContent = fmt(p.monthly) + '/mo';
      updateSlider('setup-fee'); updateSlider('monthly-retainer');
    }
    recalc();
  }

  function setCurrency(code) {
    activeCurrency = code;
    const cfg = CURRENCIES[code];
    const sal = get('avg-salary'); sal.min = cfg.salary.min; sal.max = cfg.salary.max; sal.value = cfg.salary.default;
    document.querySelectorAll('.currency-btn').forEach(b => b.classList.toggle('active', b.dataset.currency === code));
    applyTierSelection();
    updateSlider('avg-salary');
  }

  function recalc() { updateUI(calc()); }

  function init() {
    ['staff-count', 'avg-salary', 'repetitive-hours', 'automation-rate', 'error-reduction', 'revenue-impact', 'setup-fee', 'monthly-retainer'].forEach(id => {
      const el = get(id); if (el) { el.addEventListener('input', () => { updateSlider(id); recalc(); }); updateSlider(id); }
    });
    get('engine-tier').addEventListener('change', applyTierSelection);
    document.querySelectorAll('.currency-btn').forEach(b => b.addEventListener('click', () => setCurrency(b.dataset.currency)));
    get('assumptions-toggle').addEventListener('click', function() {
      const open = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', !open); get('assumptions-body').classList.toggle('is-open', !open);
    });
    setCurrency(activeCurrency);
  }

  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
})();
</script>
