---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname;

const getLangPrefix = (path) => {
    if (path.startsWith('/my')) return '/my';
    if (path.startsWith('/ms')) return '/ms';
    if (path.startsWith('/uk')) return '/uk';
    return '';
};

const langPrefix = getLangPrefix(currentPath);
const isMalay = langPrefix === '/ms';

const localizePath = (path) => {
    if (path === '/') return langPrefix || '/';
    if (path.startsWith(langPrefix) && langPrefix !== '') return path;
    const result = `${langPrefix}${path.startsWith('/') ? path : '/' + path}`;
    return result.endsWith('/') && result.length > 1 ? result.slice(0, -1) : result;
};

const labels = {
    company: isMalay ? "Syarikat" : "Company",
    about: isMalay ? "Tentang Kami" : "About Us",
    process: isMalay ? "Proses Kami" : "Our Process",
    careers: isMalay ? "Kerjaya" : "Careers",
    services: isMalay ? "Perkhidmatan" : "Services",
    resourcesLabel: isMalay ? "Sumber" : "Resources",
    resources: isMalay ? "Sumber" : "Resources",
    seoReport: isMalay ? "Laporan SEO Percuma" : "Free SEO Report",
    aiAudit: isMalay ? "Audit Kendiri AI Percuma" : "Free AI Self Audit",
    roiCalculator: isMalay ? "Kalkulator ROI Percuma" : "Free ROI Calculator",
    legal: isMalay ? "Undang-undang" : "Legal",
    privacy: isMalay ? "Dasar Privasi" : "Privacy Policy",
    terms: isMalay ? "Syarat Perkhidmatan" : "Terms of Service",
    disclaimer: isMalay ? "Penafian" : "Disclaimer",
    cookies: isMalay ? "Dasar Kuki" : "Cookie Policy",
    startProject: isMalay ? "Mulakan Projek" : "Start a Project",
    allRights: isMalay ? "Hak cipta terpelihara." : "All rights reserved."
};
---
<footer>
    <div class="container">
        <div class="footer-top">
            <div style="max-width: 400px;">
                <a href={localizePath('/')} class="logo" style="color: var(--white); margin-bottom: var(--space-md); display: inline-flex; align-items: center; gap: 10px;">
                    <img src="/AS%20logos/logo-square-dark-initials-removebg-preview.png" alt="Autoflow Solutions Logo" style="height: 48px; width: auto;" />
                    Autoflow Solutions
                </a>
                <p class="text-body" style="color: var(--gray-light); font-weight: 500;">Simplify. Automate. Thrive.</p>
                <p class="text-body" style="color: var(--gray-light); margin-top: 10px; font-size: 0.9rem;">
                    {isMalay ? "Membina daya leveraj untuk perkhidmatan profesional melalui automasi gunaan." : "Building leverage for professional services through applied automation."}
                </p>
                <a href={localizePath('/services#request')} class="btn btn-neon" style="margin-top: var(--space-md);">{labels.startProject}</a>
            </div>

            <div class="footer-links">
                <div class="footer-col">
                    <span class="label-micro">{labels.company}</span>
                    <a href={localizePath('/about')}>{labels.about}</a>
                    <a href={localizePath('/process')}>{labels.process}</a>
                    <a href={localizePath('/careers')}>{labels.careers}</a>
                    <a href={localizePath('/services')}>{labels.services}</a>
                </div>
                <div class="footer-col">
                    <span class="label-micro">{labels.resourcesLabel}</span>
                    <a href={localizePath('/resources')}>{labels.resources}</a>
                    <a href={localizePath('/seo-report')}>{labels.seoReport}</a>
                    <a href="https://ai-self-audit.autoflow-solutions.com/">{labels.aiAudit}</a>
                    <a href={localizePath('/tools/automation-roi-calculator')}>{labels.roiCalculator}</a>
                </div>
                <div class="footer-col">
                    <span class="label-micro">{labels.legal}</span>
                    <a href={localizePath('/privacy')}>{labels.privacy}</a>
                    <a href={localizePath('/terms')}>{labels.terms}</a>
                    <a href={localizePath('/disclaimer')}>{labels.disclaimer}</a>
                    <a href={localizePath('/cookies')}>{labels.cookies}</a>
                </div>
            </div>
        </div>
        
        <div class="footer-bottom">
            <span>© {new Date().getFullYear()} Autoflow Solutions. {labels.allRights}</span>
            <span style="font-family: monospace; font-size: 0.75rem;">SYS_STATUS: OPTIMAL</span>
        </div>
    </div>
</footer>
