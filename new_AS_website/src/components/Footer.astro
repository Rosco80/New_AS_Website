---
const pathname = Astro.url.pathname.replace(/\/$/, ""); // Normalize: remove trailing slash for comparison
const isUK = pathname === "/uk" || pathname.startsWith("/uk/");
const isMY = pathname === "/my" || pathname.startsWith("/my/");

let regionPrefix = "";
if (isUK) regionPrefix = "/uk";
else if (isMY) regionPrefix = "/my";
---
<footer>
    <div class="container">
        <div class="footer-top">
            <div style="max-width: 400px;">
                <a href={regionPrefix || "/"} class="logo" style="color: var(--white); margin-bottom: var(--space-md); display: inline-flex; align-items: center; gap: 10px;">
                    <img src="/AS%20logos/logo-square-dark-initials-removebg-preview.png" alt="Autoflow Solutions Logo" style="height: 48px; width: auto;" />
                    Autoflow Solutions
                </a>
                <p class="text-body" style="color: var(--gray-light); font-weight: 500;">Simplify. Automate. Thrive.</p>
                <p class="text-body" style="color: var(--gray-light); margin-top: 10px; font-size: 0.9rem;">Building leverage for professional services through applied automation.</p>
                <a href={`${regionPrefix}/services#request`} class="btn btn-neon" style="margin-top: var(--space-md);">Start a Project</a>
            </div>

            <div class="footer-links">
                <div class="footer-col">
                    <span class="label-micro">Company</span>
                    <a href={`${regionPrefix}/about`}>About us</a>
                    <a href={`${regionPrefix}/services`}>Services</a>
                    <a href={`${regionPrefix}/careers`}>Career</a>
                    <a href={`${regionPrefix}/process`}>Our Process</a>
                </div>

                {isUK && (
                    <>
                        <div class="footer-col">
                            <span class="label-micro">Verticals</span>
                            <a href="/uk/logistics-automation">Logistics</a>
                            <a href="/uk/healthcare-automation">Healthcare</a>
                            <a href="/uk/ecommerce-automation">E-Commerce</a>
                            <a href="/uk/professional-services-automation">Prof. Services</a>
                            <a href="/uk/legal-automation">Legal</a>
                        </div>
                        <div class="footer-col hide-mobile-sm">
                            <span class="label-micro">Platforms</span>
                            <a href="/uk/tools/n8n">n8n.io</a>
                            <a href="/uk/tools/make">Make.com</a>
                            <a href="/uk/tools/highlevel">HighLevel</a>
                            <a href="/uk/tools/voiceflow">Voiceflow</a>
                            <a href="/uk/tools/zoho">Zoho One</a>
                        </div>
                    </>
                )}

                <div class="footer-col">
                    <span class="label-micro">Resources</span>
                    <a href={`${regionPrefix}/resources`}>Resources</a>
                    <a href={`${regionPrefix}/blog`}>Blogs</a>
                    <a href="https://ai-self-audit.autoflow-solutions.com/" target="_blank" rel="noopener noreferrer">Free AI Audit</a>
                    <a href="https://seo-audit.autoflow-solutions.com/" target="_blank" rel="noopener noreferrer">Free SEO Report</a>
                </div>

                <div class="footer-col">
                    <span class="label-micro">Legal</span>
                    <a href={`${regionPrefix}/privacy`}>Privacy Policy</a>
                    <a href={`${regionPrefix}/terms`}>Terms of Service</a>
                    <a href={`${regionPrefix}/disclaimer`}>Disclaimer</a>
                    <a href={`${regionPrefix}/cookies`}>Cookie Policy</a>
                </div>
            </div>
        </div>
        
        <div class="footer-bottom">
            <div class="footer-bottom-content">
                <span>© {new Date().getFullYear()} Autoflow Solutions. All rights reserved.</span>
                <div class="social-links">
                    <a href="https://www.facebook.com/557476994107597" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                    </a>
                    <a href="https://www.instagram.com/autoflowsolutionsagency/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                    </a>
                    <a href="https://www.linkedin.com/company/autoflowsolutions" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                    </a>
                    <a href="https://x.com/AutofloSolution" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                    </a>
                </div>
                <span class="status-indicator">SYS_STATUS: OPTIMAL</span>
            </div>
        </div>
    </div>
<style>
    .footer-links {
        display: flex;
        gap: var(--space-lg);
    }

    .footer-col {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .footer-col a {
        color: var(--gray-light);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.3s ease;
    }

    .footer-col a:hover {
        color: var(--white);
    }

    .footer-col .label-micro {
        color: var(--gray-dark);
        margin-bottom: var(--space-xs);
    }

    /* Fixed hover contrast for buttons in the footer */
    .btn-neon:hover {
        background-color: transparent !important;
        border-color: var(--white) !important;
        color: var(--white) !important;
    }

    .footer-bottom-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: var(--space-md);
    }

    .social-links {
        display: flex;
        gap: var(--space-md);
        align-items: center;
    }

    .social-links a {
        color: var(--gray-light);
        transition: color 0.3s ease, transform 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .social-links a:hover {
        color: var(--neon);
        transform: translateY(-2px);
    }

    .status-indicator {
        font-family: monospace;
        font-size: 0.75rem;
        color: var(--gray-dark);
        background: #111;
        padding: 4px 8px;
        border-radius: 4px;
        border: 1px solid #333;
    }

    @media (max-width: 768px) {
        .footer-bottom-content {
            flex-direction: column;
            text-align: center;
        }
    }
</style>
</footer>
