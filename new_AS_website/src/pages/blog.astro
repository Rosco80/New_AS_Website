---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
    { name: "All Posts", active: true },
    { name: "AI Strategy", active: false },
    { name: "Automation Pipelines", active: false },
    { name: "Case Studies", active: false },
    { name: "SME Growth", active: false },
    { name: "Engineering", active: false }
];



import { sanityClient } from "sanity:client";

export const prerender = false;

// If you forget to set a "Publish Date" in the CMS, this fallback guarantees the newest created post is ALWAYS at the top.
const query = `*[_type == "post"] | order(coalesce(publishedAt, _createdAt) desc)`;
const sanityPosts = await sanityClient.fetch(query).catch(() => []);

const fallbackPosts = [
    {
        title: "Building Resilient Data Ingestion Pipelines.",
        description: "A technical deep dive into handling messy PDF data with high accuracy rates.",
        category: "Engineering",
        date: "March 14, 2024",
        type: "ai-visual",
        visualText: "01011001"
    },
    {
        title: "Why your CRM is actually a data graveyard.",
        description: "Why manual entry kills data integrity and how to fix it with automated sync layers.",
        category: "Strategy",
        date: "March 10, 2024",
        type: "accent",
        visualText: "CRM"
    },
    {
        title: "Saving 40 Hours a Week for a Logistics Firm.",
        description: "How we automated invoice reconciliation for a regional shipping company.",
        category: "Case Study",
        date: "Feb 28, 2024",
        type: "lines"
    },
    {
        title: "LLMs are not a strategy. Pipelines are.",
        description: "Stop thinking about 'buying AI' and start thinking about building workflows.",
        category: "AI Strategy",
        date: "Feb 15, 2024",
        type: "svg-circles"
    },
    {
        title: "When is your business too small for automation?",
        description: "The 'threshold of leverage' and why early automation saves millions in technical debt.",
        category: "SME Growth",
        date: "Jan 22, 2024",
        type: "box"
    }
];

const posts = sanityPosts.length > 0 ? sanityPosts.map((post: any) => ({
    title: post.title,
    description: post.excerpt || "",
    category: post.category || "Blog Post",
    date: post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : "",
    type: post.visualType || "box",
    visualText: post.visualText || "",
    slug: post.slug?.current || ""
})) : fallbackPosts.map(p => ({ ...p, slug: p.title.toLowerCase().replace(/[^a-z0-9]+/g, '-') }));

const featuredPost = posts[0] || {};
const gridPosts = posts.slice(1);
---

<BaseLayout title="Insights | Autoflow Solutions Blog">
    <header class="blog-header">
        <div class="container">
            <h1 class="text-display">Operational<br>Insights.</h1>
            <div class="category-nav">
                {categories.map((cat) => (
                    <a href="#" class={`cat-chip ${cat.active ? 'active' : ''}`} data-category={cat.name}>{cat.name}</a>
                ))}
            </div>
        </div>
    </header>

    <section class="featured-article">
        <div class="featured-image">
            <div class="decoration-box" style="width: 80%; height: 70%;">
                <div style="font-family: monospace; font-weight: 800; font-size: 1.2rem;">
                    [SYSTEM_VISUAL_01]
                    <div style="width: 200px; height: 4px; background: var(--black); margin-top: 10px;"></div>
                    <div style="width: 140px; height: 4px; background: var(--neon); margin-top: 6px; border: 1px solid black"></div>
                </div>
            </div>
        </div>
        <div class="featured-content">
            <span class="label-micro" style="margin-bottom: var(--space-sm); align-self: flex-start;">Featured Article</span>
            <h2 class="text-h2" style="margin-bottom: var(--space-sm);">{featuredPost.title}</h2>
            <p style="font-size: 1.2rem; color: var(--gray-dark); margin-bottom: var(--space-md);">{featuredPost.description}</p>
            <div style="display: flex; align-items: center; gap: 1rem;">
                <a href={`/blog/${featuredPost.slug}`} class="btn btn-solid-accent">Read Article</a>
                <span style="font-weight: 700; font-size: 0.9rem;">12 min read</span>
            </div>
        </div>
    </section>

    <section class="article-grid" id="blog-grid">
        {gridPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="article-card" data-post-category={post.category}>
                <div class={`card-thumb ${post.type === 'ai-visual' ? 'ai-visual' : ''}`} style={post.type === 'accent' ? "background: var(--neon);" : post.type === 'box' ? "background: var(--black);" : ""}>
                    {post.type === 'ai-visual' && (
                        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: var(--neon); font-family: monospace;">{post.visualText}</div>
                    )}
                    {post.type === 'accent' && (
                        <div style="position: absolute; bottom: 10px; right: 10px; font-weight: 900; font-size: 4rem; opacity: 0.2;">{post.visualText}</div>
                    )}
                    {post.type === 'lines' && (
                        <div style="padding: 20px;">
                            <div style="width: 100%; height: 2px; background: black; margin-bottom: 10px;"></div>
                            <div style="width: 80%; height: 2px; background: black; margin-bottom: 10px;"></div>
                            <div style="width: 90%; height: 2px; background: black;"></div>
                        </div>
                    )}
                    {post.type === 'svg-circles' && (
                        <svg width="100%" height="100%" viewBox="0 0 100 100">
                            <circle cx="50" cy="50" r="20" stroke="var(--neon)" fill="none" stroke-width="0.5"></circle>
                            <circle cx="50" cy="50" r="30" stroke="var(--neon)" fill="none" stroke-width="0.5"></circle>
                        </svg>
                    )}
                    {post.type === 'box' && (
                        <div style="width: 40px; height: 40px; border: 2px solid var(--neon); margin: 20px;"></div>
                    )}
                </div>
                <span class="label-micro" style="margin-bottom: 12px; align-self: flex-start;">{post.category}</span>
                <h3 class="text-h3" style="margin-bottom: 12px;">{post.title}</h3>
                <p style="font-size: 0.95rem; color: var(--gray-dark); flex-grow: 1;">{post.description}</p>
                <div style="margin-top: 20px; font-weight: 800; font-size: 0.8rem; text-transform: uppercase;">{post.date}</div>
            </a>
        ))}
        
        <div class="article-card next-page-card">
            <div style="text-align: center;">
                <div style="font-size: 3rem; font-weight: 900; margin-bottom: 1rem;">07</div>
                <p class="text-h3">Next Page</p>
                <div style="width: 40px; height: 2px; background: black; margin: 10px auto;"></div>
            </div>
        </div>
    </section>

    <section class="newsletter-section">
        <div class="container">
            <h2 class="text-h2">Don't miss a sprint.</h2>
            <p style="font-weight: 600; font-size: 1.25rem; margin-top: 10px;">Get our bi-weekly breakdown of automation wins and AI implementation tactics.</p>
            <form class="newsletter-form" id="newsletter-form">
                <input type="email" name="email" placeholder="Enter your business email" required>
                <button type="submit" class="btn btn-solid-accent">Subscribe Now</button>
            </form>
            <div id="newsletter-success" style="display: none; margin-top: 1.5rem; background: var(--black); color: var(--neon); padding: 1rem; border-radius: 99px; font-weight: 800;">
                ✓ You're on the list! Talk soon.
            </div>
            <p style="font-size: 0.8rem; margin-top: 1.5rem; font-weight: 600;">Join 2,400+ SME owners and operators.</p>
        </div>
    </section>

    <style>
        .blog-header {
            padding: var(--space-lg) 0;
            background-image: linear-gradient(var(--gray-light, #E5E5E5) 1px, transparent 1px), linear-gradient(90deg, var(--gray-light, #E5E5E5) 1px, transparent 1px);
            background-size: 40px 40px;
            border-bottom: 2px solid var(--black, #050505);
        }

        .category-nav {
            display: flex;
            gap: var(--space-sm);
            margin-top: var(--space-md);
            overflow-x: auto;
            padding-bottom: 10px;
        }

        .cat-chip {
            padding: 8px 20px;
            border: 2px solid var(--black, #050505);
            border-radius: var(--radius-pill);
            font-weight: 700;
            font-size: 0.9rem;
            text-decoration: none;
            color: var(--black, #050505);
            white-space: nowrap;
            transition: 0.2s;
            cursor: pointer;
        }

        .cat-chip.active { background: var(--neon, #D4FF00); }
        .cat-chip:hover:not(.active) { background: var(--black, #050505); color: var(--white, #fff); }

        .featured-article {
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            border-bottom: 2px solid var(--black, #050505);
        }

        @media (max-width: 1024px) {
            .featured-article { grid-template-columns: 1fr; }
        }

        .featured-image {
            background: var(--neon, #D4FF00);
            border-right: 2px solid var(--black, #050505);
            height: 500px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .featured-image::after {
            content: "FEATURED";
            position: absolute;
            font-weight: 900;
            font-size: 12rem;
            color: rgba(0,0,0,0.05);
            bottom: -20px;
            right: -20px;
        }

        .featured-content {
            padding: var(--space-lg);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .decoration-box {
            width: 100%;
            height: 100%;
            border: 2px solid var(--black, #050505);
            background: var(--white, #fff);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 12px 12px 0 var(--black, #050505);
            position: relative;
            z-index: 1;
        }

        .article-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            border-bottom: 2px solid var(--black, #050505);
        }

        @media (max-width: 1024px) {
            .article-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 640px) {
            .article-grid { grid-template-columns: 1fr; }
        }

        .article-card {
            border-right: 1px solid var(--black, #050505);
            border-bottom: 1px solid var(--black, #050505);
            padding: var(--space-md);
            transition: background 0.2s;
            text-decoration: none;
            color: var(--black, #050505);
            display: flex;
            flex-direction: column;
        }

        .article-card:nth-child(3n) { border-right: none; }
        .article-card:hover { background: #fafafa; }
        .article-card:hover .text-h3 { text-decoration: underline; text-decoration-thickness: 3px; text-decoration-color: var(--neon, #D4FF00); }
        
        .card-thumb {
            aspect-ratio: 16/9;
            background: var(--gray-light, #E5E5E5);
            margin-bottom: var(--space-md);
            border: 2px solid var(--black, #050505);
            position: relative;
            overflow: hidden;
        }

        .card-thumb.ai-visual { background: var(--black, #050505); }

        .next-page-card {
            background: var(--gray-light, #E5E5E5); 
            justify-content: center; 
            align-items: center; 
            border-right: none;
        }

        .newsletter-section {
            background: var(--neon, #D4FF00);
            padding: var(--space-xl) 0;
            text-align: center;
            border-bottom: 2px solid var(--black, #050505);
        }

        .newsletter-form {
            max-width: 600px;
            margin: var(--space-md) auto 0;
            display: flex;
            gap: 10px;
        }

        @media (max-width: 640px) {
            .newsletter-form {
                flex-direction: column;
            }
        }

        .newsletter-form input {
            flex: 1;
            padding: 1rem 1.5rem;
            border: 2px solid var(--black, #050505);
            border-radius: var(--radius-pill);
            font-family: var(--font-sans);
            font-weight: 600;
            outline: none;
        }

        .btn-solid-accent {
            background: var(--black, #050505);
            color: var(--white, #fff);
            white-space: nowrap;
        }

        .btn-solid-accent:hover {
            background: var(--white, #fff);
            color: var(--black, #050505);
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const filters = document.querySelectorAll('.cat-chip');
            const cards = document.querySelectorAll('.article-card[data-post-category]');
            const featuredSection = document.querySelector('.featured-article');

            filters.forEach(filter => {
                filter.addEventListener('click', (e) => {
                    e.preventDefault();
                    
                    filters.forEach(f => f.classList.remove('active'));
                    e.currentTarget.classList.add('active');
                    
                    const selectedCategory = e.currentTarget.getAttribute('data-category');
                    
                    if (selectedCategory === "All Posts") {
                        if(featuredSection) featuredSection.style.display = 'grid';
                        cards.forEach(card => card.style.display = 'flex');
                    } else {
                        if(featuredSection) featuredSection.style.display = 'none';
                        cards.forEach(card => {
                            if (card.getAttribute('data-post-category') === selectedCategory) {
                                card.style.display = 'flex';
                            } else {
                                card.style.display = 'none';
                            }
                        });
                    }
                });
            });
            // Newsletter Submission
            const newsletterForm = document.getElementById('newsletter-form');
            const newsletterSuccess = document.getElementById('newsletter-success');
            
            if (newsletterForm) {
                newsletterForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const formData = new FormData(newsletterForm);
                    const submitBtn = newsletterForm.querySelector('button');
                    if (submitBtn) {
                        submitBtn.textContent = 'Joining...';
                        submitBtn.disabled = true;
                    }
                    
                    try {
                        const response = await fetch('https://script.google.com/macros/s/AKfycbywia_SFpTLhBUb8fs3T-lXHaGN-9Ht-iSvReQiaVWpTfVAqMJHWMHDvGKk3gtQALf9sQ/exec', {
                            method: 'POST',
                            body: formData,
                            mode: 'no-cors' // Use no-cors for Google Apps Script Web Apps
                        });
                        
                        // We assume success since no-cors doesn't return response details
                        newsletterForm.style.display = 'none';
                        if (newsletterSuccess) newsletterSuccess.style.display = 'block';
                    } catch (error) {
                        console.error('Newsletter Error:', error);
                        if (submitBtn) {
                            submitBtn.textContent = 'Subscribe Now';
                            submitBtn.disabled = false;
                        }
                    }
                });
            }
        });
    </script>
</BaseLayout>
