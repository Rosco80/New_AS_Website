        }
    }

    /* Missing styles from the original HTML */
    .assumptions-section { margin-top: 2rem; margin-bottom: 2rem; }
    .assumptions-toggle {
        width: 100%; display: flex; justify-content: space-between; align-items: center;
        padding: 1rem; background: var(--grey-100); border: 1px solid var(--grey-200);
        border-radius: 8px; cursor: pointer;
    }
    .assumptions-toggle__title { font-weight: 800; font-size: 0.8rem; text-transform: uppercase; }
    .assumptions-toggle__subtitle { font-size: 0.75rem; color: var(--grey-400); }
    .assumptions-body { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
