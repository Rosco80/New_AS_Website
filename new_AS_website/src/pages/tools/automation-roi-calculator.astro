    .assumptions-body__inner { padding: 2rem; border: 1px solid var(--grey-200); border-top: none; border-radius: 0 0 8px 8px; background: #fff; }

    .projection-bars { display: flex; align-items: flex-end; gap: 1rem; height: 120px; margin-top: 1rem; }
    .projection-bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .projection-bar-col__track { width: 100%; height: 100px; background: rgba(255,255,255,0.05); border-radius: 4px 4px 0 0; display: flex; align-items: flex-end; }
    .projection-bar-col__bar { width: 100%; background: var(--chartreuse); height: var(--bar-height, 0%); border-radius: 4px 4px 0 0; transition: height 0.6s ease; opacity: 0.8; }
    .projection-bar-col__year { font-size: 0.7rem; color: rgba(255,255,255,0.4); font-weight: 700; }
    .projection-bar-col__value { font-family: var(--font-display); font-size: 0.8rem; color: #fff; }

    .results-hours { display: flex; gap: 1rem; padding: 2rem 0; border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 2rem; }
    .results-hours__icon { width: 32px; height: 32px; color: var(--chartreuse); }
    .results-hours__primary { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; color: #fff; }
    .results-hours__secondary { color: rgba(255,255,255,0.4); font-size: 0.8rem; }

    .results-actions { display: flex; gap: 1rem; margin: 2rem 0; }
    .btn-share, .btn-reset { flex: 1; padding: 0.75rem; background: transparent; border: 1px solid rgba(255,255,255,0.2); color: #fff; border-radius: 4px; font-weight: 700; font-size: 0.75rem; cursor: pointer; }
    .btn-reset { color: rgba(255,255,255,0.5); }
    .results-disclaimer { font-size: 0.7rem; color: rgba(255,255,255,0.3); line-height: 1.5; }

    .hidden { display: none !important; }
    .badge-strong-roi { display: inline-block; background: var(--chartreuse); color: #000; padding: 4px 8px; font-size: 0.65rem; font-weight: 800; border-radius: 2px; margin-bottom: 1rem; }
</style>

<script>
    // PORT THE INTERACTIVE LOGIC
    (function () {
        'use strict';

        var CURRENCIES = {
            MYR: {
                symbol: 'RM ', locale: 'en-MY',
                salary: { min: 1500, max: 15000, default: 4000, step: 500 },
                setup: { min: 2000, max: 50000, default: 8000, step: 1000 },
                retainer: { min: 0, max: 3000, default: 500, step: 100 }
            },
            USD: {
                symbol: '$', locale: 'en-US',
                salary: { min: 2000, max: 12000, default: 4500, step: 500 },
                setup: { min: 2000, max: 60000, default: 10000, step: 1000 },
                retainer: { min: 0, max: 3000, default: 500, step: 100 }
            },
            GBP: {
                symbol: '£', locale: 'en-GB',
                salary: { min: 1500, max: 8000, default: 2800, step: 250 },
                setup: { min: 1500, max: 50000, default: 6000, step: 500 },
                retainer: { min: 0, max: 2000, default: 350, step: 50 }
            },
            EUR: {
                symbol: '€', locale: 'de-DE',
                salary: { min: 1500, max: 8000, default: 2500, step: 250 },
                setup: { min: 1500, max: 50000, default: 6000, step: 500 },
                retainer: { min: 0, max: 2000, default: 350, step: 50 }
            }
        };

        var activeCurrency = 'MYR';
        var MONEY_SLIDERS = ['avg-salary', 'setup-fee', 'monthly-retainer'];
        var ANIM_MS = 400;

        function get(id) { return document.getElementById(id); }
        function gv(id) { return parseFloat(get(id).value) || 0; }

        function fmt(v, short) {
            var cfg = CURRENCIES[activeCurrency];
            if (short && Math.abs(v) >= 1000) return cfg.symbol + (v / 1000).toFixed(1) + 'k';
            return cfg.symbol + Math.round(v).toLocaleString(cfg.locale);
        }

        function calc() {
            var staff = gv('staff-count');
            var salary = gv('avg-salary');
            var hrs = gv('repetitive-hours');
            var setup = Math.max(1, gv('setup-fee'));
            var monthly = gv('monthly-retainer');
            var autoRate = gv('automation-rate') / 100;
            var errRate = gv('error-reduction') / 100;
            var revRate = gv('revenue-impact') / 100;

            var hourly = salary / 160;
            var annualLabor = staff * hourly * hrs * 52;
            var netAnnual = (annualLabor * autoRate) + (annualLabor * errRate * 0.25) + (annualLabor * revRate) - (monthly * 12);
            
            var roi = (netAnnual / setup) * 100;
            var payback = netAnnual > 0 ? setup / (netAnnual / 12) : Infinity;
            
            return {
                netAnnual: netAnnual, 
                roi: roi, 
                payback: payback,
                yr1: netAnnual - setup,
                yr2: (netAnnual * 2) - setup,
                yr3: (netAnnual * 3) - setup,
                hoursFreed: staff * hrs * autoRate,
                fte: (staff * hrs * autoRate) / 40
            };
        }

        function updateUI() {
            var r = calc();
            get('result-annual-savings').textContent = fmt(r.netAnnual);
            get('result-payback').textContent = r.payback === Infinity ? '--' : Math.ceil(r.payback) + ' mo';
            get('result-roi-pct').textContent = Math.round(r.roi) + '%';
            get('result-hours-freed').textContent = r.hoursFreed.toFixed(1) + ' HRS/WK FREED';
            get('result-fte').textContent = 'Equivalent to ' + r.fte.toFixed(1) + ' full-time staff';

            var maxV = Math.max(r.yr3, 1);
            get('bar-year1').style.setProperty('--bar-height', Math.max(5, (r.yr1 / maxV) * 100) + '%');
            get('bar-year2').style.setProperty('--bar-height', Math.max(5, (r.yr2 / maxV) * 100) + '%');
            get('bar-year3').style.setProperty('--bar-height', Math.max(5, (r.yr3 / maxV) * 100) + '%');
            
            get('result-year1').textContent = fmt(r.yr1, true);
            get('result-year2').textContent = fmt(r.yr2, true);
            get('result-year3').textContent = fmt(r.yr3, true);

            get('badge-strong-roi').classList.toggle('hidden', r.roi < 200);
        }

        function updateSlider(id) {
            var el = get(id);
            var pct = ((el.value - el.min) / (el.max - el.min)) * 100;
            el.style.setProperty('--slider-pct', pct + '%');
            
            var dis = get(id + '-display');
            if (MONEY_SLIDERS.indexOf(id) !== -1) {
                dis.textContent = CURRENCIES[activeCurrency].symbol + parseFloat(el.value).toLocaleString(CURRENCIES[activeCurrency].locale);
            } else {
                dis.textContent = el.value;
            }
        }

        // Event Listeners
        document.querySelectorAll('input[type="range"]').forEach(function (input) {
            input.addEventListener('input', function () {
                updateSlider(this.id);
                updateUI();
                
                // Progress Label
                var adjusted = document.querySelectorAll('input[type="range"]').length; // Simple for now
                get('progress-fill').style.setProperty('--progress-pct', '100%');
                get('progress-label').textContent = 'Ready to SCALE';
            });
            updateSlider(input.id);
        });

        document.querySelectorAll('.currency-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.currency-btn').forEach(function (b) { b.classList.remove('active'); });
                this.classList.add('active');
                activeCurrency = this.dataset.currency;
                
                var cfg = CURRENCIES[activeCurrency];
                MONEY_SLIDERS.forEach(function (id) {
                    var el = get(id);
                    // Adjust ranges
                    if (id === 'avg-salary') { el.min = cfg.salary.min; el.max = cfg.salary.max; el.value = cfg.salary.default; el.step = cfg.salary.step; }
                    if (id === 'setup-fee') { el.min = cfg.setup.min; el.max = cfg.setup.max; el.value = cfg.setup.default; el.step = cfg.setup.step; }
                    if (id === 'monthly-retainer') { el.min = cfg.retainer.min; el.max = cfg.retainer.max; el.value = cfg.retainer.default; el.step = cfg.retainer.step; }
                    updateSlider(id);
                });
                updateUI();
            });
        });

        get('assumptions-toggle').addEventListener('click', function () {
            var expanded = this.getAttribute('aria-expanded') === 'true';
            this.setAttribute('aria-expanded', !expanded);
            get('assumptions-body').classList.toggle('is-open');
        });

        get('reset-btn').addEventListener('click', function() {
            window.location.reload();
        });

        updateUI();

    })();
</script>
