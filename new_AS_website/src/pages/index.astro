---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
    <header class="hero">
        <div class="hero-left">
            <span class="label-micro" style="border: 1px solid var(--black); padding: 4px 8px; border-radius: var(--radius-pill);">For SME Owners</span>
            <h1 class="text-display">Turn More Inquiries Into Booked Clients<br>With AI-Powered Follow-Up.</h1>
            <p class="text-body-lg">Automate lead capture, qualification, CRM updates, and missed inquiry recovery for professional service SMEs.</p>
            <div style="display: flex; gap: 1rem;">
                <a href="/ai-self-audit" class="btn btn-solid">Start Free AI Self Audit</a>
                <a href="/tools/automation-roi-calculator" class="btn btn-outline">Calculate Your Automation ROI</a>
            </div>
            <p class="label-micro" style="margin-top: 1rem;">Built for SMEs that want faster response times, less admin, and cleaner operations.</p>
        </div>
        <div class="hero-right">
            <div class="cluster-wrapper">
                
                <div class="ui-card card-1">
                    <div class="card-header">
                        <span class="label-micro">Process 01: Ingestion</span>
                        <span class="status"></span>
                    </div>
                    <h3 class="text-h3" style="margin-bottom: 8px;">Invoice Extraction</h3>
                    <p class="text-body" style="font-size: 0.85rem; margin-bottom: 16px;">AI reads incoming PDFs, extracts line items, and flags discrepancies instantly.</p>
                    <div style="background: var(--gray-light); height: 4px; border-radius: 2px; width: 100%; margin-bottom: 4px;">
                        <div style="background: var(--black); height: 100%; width: 100%; border-radius: 2px;"></div>
                    </div>
                    <span class="label-micro" style="color: var(--black);">100% Automated</span>
                </div>

                <div class="ui-card card-2">
                    <div class="card-header">
                        <span class="label-micro">Process 02: Routing</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                    </div>
                    <h3 class="text-h3" style="margin-bottom: 8px;">CRM Sync</h3>
                    <p class="text-body" style="font-size: 0.85rem; margin-bottom: 12px;">Data maps directly to Salesforce/HubSpot without human entry.</p>
                    <div style="display: flex; gap: 4px;">
                        <span style="padding: 2px 6px; border: 1px solid var(--gray-dark); border-radius: 4px; font-size: 0.7rem; font-family: monospace;">API_REQ</span>
                        <span style="padding: 2px 6px; border: 1px solid var(--gray-dark); border-radius: 4px; font-size: 0.7rem; font-family: monospace;">SUCCESS</span>
                    </div>
                </div>

                <div class="ui-card card-3">
                    <svg class="doodle-arrow" viewBox="0 0 200 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10 50 C 50 10, 150 10, 190 50" stroke="black" stroke-width="4" stroke-linecap="round"></path>
                        <path d="M170 30 L 195 55 L 160 70" stroke="black" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"></path>
                        <text x="70" y="20" font-family="'Gloria Hallelujah', cursive, sans-serif" font-size="18" fill="black" transform="rotate(-10 70 20)">You save 40hrs/wk!</text>
                    </svg>

                    <div class="card-header">
                        <span class="label-micro">Output: Dashboard</span>
                    </div>
                    <h3 class="text-h3" style="margin-bottom: 8px;">Reconciliation</h3>
                    <div style="display: flex; align-items: baseline; gap: 8px;">
                        <span style="font-size: 2.5rem; font-weight: 900; letter-spacing: -0.05em;">$0.00</span>
                        <span class="label-micro">Discrepancy</span>
                    </div>
                    <a href="#" class="btn btn-solid" style="width: 100%; margin-top: 16px; padding: 0.5rem; font-size: 0.85rem;">View Report</a>
                </div>

            </div>
        </div>
    </header>

    <div class="marquee-container">
        <div class="marquee-content">
            NO JARGON • JUST ROI • BUILT FOR SMES • NO JARGON • JUST ROI • BUILT FOR SMES • NO JARGON • JUST ROI • BUILT FOR SMES • NO JARGON • JUST ROI • BUILT FOR SMES • 
            NO JARGON • JUST ROI • BUILT FOR SMES • NO JARGON • JUST ROI • BUILT FOR SMES • NO JARGON • JUST ROI • BUILT FOR SMES • NO JARGON • JUST ROI • BUILT FOR SMES • 
        </div>
    </div>

    <section class="density-section" style="background-color: var(--gray-light); padding-top: 4rem; padding-bottom: 4rem; margin-top: 2rem;">
        <div class="container">
            <div class="section-header" style="text-align: center; margin-bottom: 2rem;">
                <h2 class="text-h2">Where SME teams lose time and revenue.</h2>
            </div>
            <ul style="max-width: 600px; margin: 0 auto; list-style: disc; padding-left: 2rem; font-size: 1.1rem; line-height: 1.6;">
                <li>Leads sit too long without follow-up</li>
                <li>Staff answer the same questions repeatedly</li>
                <li>Customer details never make it into the CRM properly</li>
                <li>Admin work delays sales and service</li>
            </ul>
        </div>
    </section>

    <section class="density-section">
        <div class="container">
            <div class="section-header">
                <h2 class="text-h2" style="margin-bottom: 1rem;">What we build.</h2>
                <p class="text-body-lg">We engineer specific, robust workflows that integrate deeply with the tools you already use.</p>
            </div>
        </div>

        <div class="blueprint-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
            <div class="blueprint-cell">
                <span class="cell-id">CAP.01</span>
                <div class="icon-box">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--neon)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                </div>
                <h4 class="text-h3" style="margin-bottom: 0.5rem;">Lead Handling</h4>
                <p class="text-body" style="font-size: 0.9rem;">Capture, qualify, and route inquiries from WhatsApp, web chat, and forms.</p>
            </div>
            
            <div class="blueprint-cell">
                <span class="cell-id">CAP.02</span>
                <div class="icon-box">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--neon)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                </div>
                <h4 class="text-h3" style="margin-bottom: 0.5rem;">Workflow Automation</h4>
                <p class="text-body" style="font-size: 0.9rem;">Sync CRMs, trigger onboarding, generate documents, and alert the right people.</p>
            </div>

            <div class="blueprint-cell">
                <span class="cell-id">CAP.03</span>
                <div class="icon-box">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--neon)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="15" x2="23" y2="15"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="15" x2="4" y2="15"></line></svg>
                </div>
                <h4 class="text-h3" style="margin-bottom: 0.5rem;">AI Task Execution</h4>
                <p class="text-body" style="font-size: 0.9rem;">Use AI workers to handle repetitive research, updates, summaries, and cross-system actions.</p>
            </div>
        </div>
    </section>

    <section class="density-section" style="background-color: var(--gray-light); padding-top: 4rem; padding-bottom: 4rem;">
        <div class="container">
            <div class="section-header" style="text-align: center; margin-bottom: 2rem;">
                <h2 class="text-h2">What this should improve.</h2>
            </div>
            <ul style="max-width: 600px; margin: 0 auto; list-style: disc; padding-left: 2rem; font-size: 1.1rem; line-height: 1.6;">
                <li>Faster response times</li>
                <li>Fewer missed leads</li>
                <li>Lower admin workload</li>
                <li>Cleaner handoffs</li>
                <li>More consistent follow-up</li>
            </ul>
        </div>
    </section>

    <section class="density-section" style="padding-top: 4rem; padding-bottom: 4rem;">
        <div class="container">
            <div class="section-header" style="text-align: center; margin-bottom: 2rem;">
                <h2 class="text-h2">How we work.</h2>
            </div>
            <ol style="max-width: 600px; margin: 0 auto; padding-left: 2rem; font-size: 1.1rem; line-height: 1.6;">
                <li style="margin-bottom: 0.5rem;"><strong>Audit your current process</strong></li>
                <li style="margin-bottom: 0.5rem;"><strong>Design the right automation flow</strong></li>
                <li style="margin-bottom: 0.5rem;"><strong>Build, test, and launch</strong></li>
                <li style="margin-bottom: 0.5rem;"><strong>Monitor and improve</strong></li>
            </ol>
        </div>
    </section>

    <section class="density-section" style="background-color: var(--black); color: var(--white); padding-top: 4rem; padding-bottom: 4rem; text-align: center;">
        <div class="container">
            <h2 class="text-h2" style="margin-bottom: 2rem; color: var(--white);">See where automation will pay off first</h2>
            <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                <a href="/ai-self-audit" class="btn btn-solid" style="background-color: var(--neon); color: var(--black);">Start Free AI Self Audit</a>
                <a href="/tools/automation-roi-calculator" class="btn btn-outline" style="border-color: var(--white); color: var(--white);">Calculate Your Automation ROI</a>
            </div>
        </div>
    </section>
</BaseLayout>
