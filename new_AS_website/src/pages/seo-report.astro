---
import BaseLayout from '../layouts/BaseLayout.astro';

const countryCodes = [
  { code: "+1", country: "US", flag: "🇺🇸" },
  { code: "+1", country: "CA", flag: "🇨🇦" },
  { code: "+44", country: "UK", flag: "🇬🇧" },
  { code: "+60", country: "MY", flag: "🇲🇾" },
  { code: "+61", country: "AU", flag: "🇦🇺" },
  { code: "+65", country: "SG", flag: "🇸🇬" },
  { code: "+39", country: "IT", flag: "🇮🇹" },
  { code: "+33", country: "FR", flag: "🇫🇷" },
  { code: "+49", country: "DE", flag: "🇩🇪" },
  // ... (Full list can be added later if needed, starting with key markets)
];
---

<BaseLayout title="Free SEO Report">
    <main class="audit-page">
        <header class="audit-hero">
            <div class="container text-center">
                <span class="label-micro" style="margin-bottom: 1.5rem;">The Intelligence Engine</span>
                <h1 class="text-display" style="margin-bottom: 2rem;">GET YOUR FREE<br>SEO REPORT.</h1>
                <p class="text-body-lg" style="max-width: 700px; margin: 0 auto;">Comprehensive technical analysis • Content roadmap • Competitive insights. Stop guessing and start ranking.</p>
            </div>
        </header>

        <section class="audit-content">
            <div class="container audit-grid">
                <!-- Left: Benefits -->
                <div class="benefits-panel">
                    <div class="blueprint-card">
                        <span class="label-micro">ANALYSIS_PARAMETERS.EXE</span>
                        <h3 class="text-h3" style="margin: 1.5rem 0;">What You'll Receive</h3>
                        <ul class="benefit-list">
                            <li>Technical SEO Health Audit</li>
                            <li>Mobile Performance Scoring</li>
                            <li>Backlink Profile Insights</li>
                            <li>Keyword Gap Analysis</li>
                            <li>Actionable Improvement Roadmap</li>
                            <li>Competitor Comparison</li>
                        </ul>
                    </div>
                </div>

                <!-- Right: Form -->
                <div class="form-panel">
                    <div class="audit-form-card" id="formContainer">
                        <div class="neon-bar"></div>
                        <h3 class="text-h3" style="margin-bottom: 2rem;">Start Your Audit</h3>
                        
                        <form id="seoAuditForm" class="bold-form">
                            <div class="form-row">
                                <div class="input-group">
                                    <label>Full Name</label>
                                    <input type="text" name="fullName" placeholder="John Doe" required />
                                </div>
                                <div class="input-group">
                                    <label>Email Address</label>
                                    <input type="email" name="email" placeholder="john@company.com" required />
                                </div>
                            </div>

                            <div class="input-group">
                                <label>Company Name</label>
                                <input type="text" name="companyName" placeholder="Acme Corp" required />
                            </div>

                            <div class="form-row">
                                <div class="input-group" style="flex: 0 0 100px;">
                                    <label>Code</label>
                                    <select name="countryCode" required>
                                        {countryCodes.map(c => (
                                            <option value={`${c.code}-${c.country}`}>{c.flag} {c.code}</option>
                                        ))}
                                    </select>
                                </div>
                                <div class="input-group" style="flex: 1;">
                                    <label>Phone Number</label>
                                    <input type="tel" name="phoneNumber" placeholder="123 456 789" required />
                                </div>
                            </div>

                            <div class="input-group">
                                <label>Company Website</label>
                                <input type="url" name="companyWebsite" placeholder="https://example.com" required />
                            </div>

                            <div class="form-row">
                                <div class="input-group">
                                    <label>Run Google Ads?</label>
                                    <select name="runsGoogleAds" id="googleAdsSelect">
                                        <option value="no">No</option>
                                        <option value="yes">Yes</option>
                                    </select>
                                </div>
                                <div class="input-group" id="googleAdsSpendGroup" style="display: none;">
                                    <label>Monthly Spend</label>
                                    <input type="text" name="googleAdsSpend" placeholder="e.g. $1,000" />
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="input-group">
                                    <label>Run Meta Ads?</label>
                                    <select name="runsMetaAds" id="metaAdsSelect">
                                        <option value="no">No</option>
                                        <option value="yes">Yes</option>
                                    </select>
                                </div>
                                <div class="input-group" id="metaAdsSpendGroup" style="display: none;">
                                    <label>Monthly Spend</label>
                                    <input type="text" name="metaAdsSpend" placeholder="e.g. $1,000" />
                                </div>
                            </div>

                            <button type="submit" class="btn-submit-pill" id="submitBtn">Generate My Report</button>
                        </form>
                    </div>

                    <!-- Success Message -->
                    <div id="successMessage" class="success-card" style="display: none;">
                        <div class="neon-bar"></div>
                        <div class="success-icon">✓</div>
                        <h3 class="text-h3">Transmission Received.</h3>
                        <p class="text-body" style="margin: 1.5rem 0;">Your SEO analysis is being compiled. You will receive the PDF report at your email address within 30 minutes.</p>
                        <button onclick="location.reload()" class="btn btn-outline" style="width: 100%;">Submit Another</button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script is:inline>
        const form = document.getElementById('seoAuditForm');
        const formContainer = document.getElementById('formContainer');
        const successMessage = document.getElementById('successMessage');
        const submitBtn = document.getElementById('submitBtn');

        const googleAdsSelect = document.getElementById('googleAdsSelect');
        const googleAdsSpendGroup = document.getElementById('googleAdsSpendGroup');
        const metaAdsSelect = document.getElementById('metaAdsSelect');
        const metaAdsSpendGroup = document.getElementById('metaAdsSpendGroup');

        // Toggle spend fields
        googleAdsSelect.addEventListener('change', (e) => {
            googleAdsSpendGroup.style.display = e.target.value === 'yes' ? 'block' : 'none';
        });
        metaAdsSelect.addEventListener('change', (e) => {
            metaAdsSpendGroup.style.display = e.target.value === 'yes' ? 'block' : 'none';
        });

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            submitBtn.disabled = true;
            submitBtn.innerText = 'Initializing...';

            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            // Format phone number
            const dialCode = data.countryCode.split('-')[0];
            data.phoneNumber = `${dialCode}${data.phoneNumber}`;

            try {
                const response = await fetch('https://n8n.soryle.space/webhook/27ea5610-f693-4370-a0c9-8ceb5253a49d', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    formContainer.style.display = 'none';
                    successMessage.style.display = 'block';
                } else {
                    alert('Submission failed. Please try again or contact support.');
                    submitBtn.disabled = false;
                    submitBtn.innerText = 'Generate My Report';
                }
            } catch (err) {
                alert('Connection error. Please check your network and try again.');
                submitBtn.disabled = false;
                submitBtn.innerText = 'Generate My Report';
            }
        });
    </script>

    <style>
        .audit-page {
            background-color: var(--black);
            color: var(--white);
            min-height: 100vh;
        }

        .audit-hero {
            padding: 160px 0 80px;
            background-image: radial-gradient(var(--gray-dark) 1px, transparent 1px);
            background-size: 40px 40px;
            border-bottom: 2px solid var(--gray-dark);
        }

        .audit-content {
            padding: 80px 0;
            background-image: linear-gradient(var(--gray-dark) 1px, transparent 1px), linear-gradient(90deg, var(--gray-dark) 1px, transparent 1px);
            background-size: 80px 80px;
        }

        .audit-grid {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 4rem;
            align-items: start;
        }

        .blueprint-card {
            background: rgba(0,0,0,0.8);
            border: 2px solid var(--neon);
            padding: var(--space-lg);
            box-shadow: 12px 12px 0 var(--neon);
        }

        .benefit-list {
            list-style: none;
            padding: 0;
        }

        .benefit-list li {
            padding: 12px 0;
            border-bottom: 1px solid var(--gray-dark);
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 700;
        }

        .benefit-list li::before {
            content: "✓";
            color: var(--neon);
            font-weight: 900;
        }

        .audit-form-card, .success-card {
            background: var(--white);
            color: var(--black);
            padding: 3rem;
            position: relative;
            box-shadow: 20px 20px 0 #c4ef17;
        }

        .neon-bar {
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 8px;
            background: var(--neon);
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .input-group { margin-bottom: 1.5rem; }
        .input-group label { display: block; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; margin-bottom: 8px; }
        .input-group input, .input-group select {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid var(--black);
            font-weight: 700;
            outline: none;
        }

        .input-group input:focus, .input-group select:focus {
            background: var(--gray-bg);
            border-color: var(--neon);
        }

        .btn-submit-pill {
            width: 100%;
            padding: 18px;
            background: var(--black);
            color: var(--white);
            border: none;
            border-radius: 99px;
            font-weight: 900;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s ease;
            letter-spacing: 1px;
        }

        .btn-submit-pill:hover {
            background: var(--neon);
            color: var(--black);
            transform: scale(1.02);
        }

        .btn-submit-pill:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .success-card { text-align: center; }
        .success-icon {
            font-size: 4rem;
            color: var(--neon);
            margin-bottom: 1.5rem;
            font-weight: 900;
        }

        @media (max-width: 1024px) {
            .audit-grid { grid-template-columns: 1fr; }
            .audit-hero { padding: 120px 0 60px; }
        }

        @media (max-width: 600px) {
            .form-row { grid-template-columns: 1fr; }
            .audit-form-card { padding: 2rem 1.5rem; }
        }
    </style>
</BaseLayout>
