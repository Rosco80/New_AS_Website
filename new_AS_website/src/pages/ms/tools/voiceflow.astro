---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "Agensi Pembangunan Voiceflow Malaysia — Pakar Ejen AI Tersuai";
const description = "Pembangunan Voiceflow profesional untuk PKS Malaysia. Ejen suara AI tersuai, bot sembang peka konteks, dan integrasi platform yang mendalam. Tempah audit percuma.";

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Pembangunan Ejen AI Voiceflow Malaysia",
    "description": "Bot sembang AI tersuai dan ejen suara yang dibina dengan Voiceflow untuk pasukan perkhidmatan pelanggan Malaysia.",
    "provider": { "@type": "Organization", "name": "Autoflow Solutions" },
    "areaServed": { "@type": "Country", "name": "MY" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Bolehkah ejen Voiceflow mengendalikan nuansa Manglish dan Bahasa Melayu?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ya, kami melaraskan ejen AI kami untuk memahami nuansa pelbagai bahasa dalam komunikasi Malaysia, termasuk Bahasa Inggeris, BM, dan istilah 'Manglish' percakapan."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Voiceflow",
    "operatingSystem": "Semua",
    "applicationCategory": "AplikasiPerniagaan",
    "offers": {
      "@type": "Offer",
      "price": "0.00",
      "priceCurrency": "MYR"
    }
  }
];
---

<BaseLayout title={title} description={description} schemaData={schemaData}>
    <header class="hero" style="min-height: 80vh;">
        <div class="hero-left">
            <span class="label-micro" style="border: 1px solid var(--black); padding: 4px 8px; border-radius: var(--radius-pill); margin-bottom: var(--space-md);">Fokus Alatan: Voiceflow</span>
            <h1 class="text-display">AGENSI VOICEFLOW<br>MALAYSIA.</h1>
            <h2 class="text-h2" style="font-size: 1.5rem; margin-bottom: 2rem; color: var(--black); line-height: 1.2;">Ejen AI Canggih untuk Perniagaan Asia Tenggara</h2>
            <p class="text-body-lg" style="margin-bottom: 2.5rem;">Kami membina ejen AI yang paling canggih di Malaysia menggunakan Voiceflow. Peka konteks, mempunyai kawalan keselamatan (guardrailed), dan disepadukan ke dalam sistem perniagaan teras anda.</p>
            <div class="hero-btns" style="display: flex; gap: 1rem;">
                <a href="/ms/services#request" class="btn btn-solid">Bincangkan Ejen AI Anda (RM)</a>
                <a href="/ai-self-audit" target="_blank" class="btn btn-neon">Audit Kendiri AI Percuma</a>
            </div>
        </div>
        <div class="hero-right" style="background-color: #f0fff4;">
            <div style="padding: 3rem; width: 100%;">
                <div class="ui-card" style="position: relative; width: 100%; transform: none; box-shadow: 20px 20px 0 var(--black); background: #fff;">
                    <div class="card-header">
                        <span class="label-micro">EJEN_VOICEFLOW_v4_MY</span>
                        <div class="status" style="width: 8px; height: 8px; background: #6aff8d; border-radius: 50%;"></div>
                    </div>
                    <div style="margin: 1.5rem 0;">
                        <p class="label-micro" style="color: var(--gray-dark);">Prompt: "Bertindak sebagai wakil Perkhidmatan Pelanggan Malaysia..."</p>
                        <div style="padding: 1rem; background: #f9f9f9; border-radius: 4px; margin-top: 10px;">
                            <p style="font-size: 0.85rem; color: #444;">"Selamat datang! Ya, kami mempunyai stok di cawangan Mid Valley kami. Boleh saya bantu tempah satu unit untuk bos?"</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="density-section">
        <div class="container">
            <div class="section-header">
                <span class="label-micro">Kelebihan Perbualan</span>
                <h2 class="text-display" style="margin-top: 1rem;">AI YANG BERCAKAP<br>BAHASA TEMPATAN.</h2>
                <p class="text-body-lg" style="margin-top: 1.5rem;">Konteks adalah segala-galanya. Kami membina ejen AI yang memahami konteks khusus Malaysia — daripada nuansa pelbagai bahasa sehingga waktu perniagaan tempatan dan kaedah pembayaran (DuitNow/GrabPay).</p>
            </div>
            
            <div class="blueprint-grid">
                <div class="blueprint-cell">
                    <span class="cell-id">01</span>
                    <h3 class="text-h3">Peka Konteks</h3>
                    <p class="text-body" style="margin-top: 1rem;">Ejen yang dilatih menggunakan dokumen perniagaan Malaysia anda yang khusus untuk memberikan jawapan yang tepat dan selamat untuk jenama anda setiap kali.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">02</span>
                    <h3 class="text-h3">Utamakan WhatsApp</h3>
                    <p class="text-body" style="margin-top: 1rem;">Laksanakan kecerdaan yang sama di seluruh laman web MY anda, WhatsApp Business, dan Facebook Messenger di mana pelanggan anda berada.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">03</span>
                    <h3 class="text-h3">Penyerahan Lancar</h3>
                    <p class="text-body" style="margin-top: 1rem;">Ejen yang tahu bila mahu menyerahkan perbualan kepada rakan sepasukan manusia dalam pasukan perkhidmatan pelanggan Malaysia anda.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">04</span>
                    <h3 class="text-h3">Penyelarasan Mendalam API</h3>
                    <p class="text-body" style="margin-top: 1rem;">Ejen AI anda bukan sekadar bercakap — mereka akan bertindak. Daripada menyemak inventori MY di Shopee/Lazada sehingga mengemas kini CRM tempatan anda secara langsung.</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
