---
import BaseLayout from '../../layouts/BaseLayout.astro';

const values = [
    {
        num: "01",
        title: "Hasil > Publisiti",
        body: "Kami tidak membina \"eksperimen AI.\" Kami membina saluran produksi yang kukuh dan memberikan ROI yang boleh diukur dari hari pertama."
    },
    {
        num: "02",
        title: "Ketelusan secara Lalai",
        body: "Tiada sistem tersembunyi. Kami membina sistem yang anda miliki dan fahami sepenuhnya, memastikan perniagaan anda kekal tangkas dan bebas."
    },
    {
        num: "03",
        title: "Empati Radikal",
        body: "Kami mengkaji kekangan anda seolah-olah ia milik kami sendiri. Kami bukan sekadar vendor; kami adalah jabatan automasi luaran anda."
    }
];

const reviews = [
    {
        client: "Firmin Rieu",
        title: "Pemilik / Chef, Le Gourmandin",
        location: "Malaysia",
        text: "Sejak menggunakan Chatbot AI Autoflow Solutions, kami melihat peningkatan ketara dalam kepuasan pelanggan dan pengurangan beban kerja manual yang besar. Selain itu, tempahan dalam talian kami juga meningkat."
    },
    {
        client: "Matteo Rossi",
        title: "Pengurus Operasi, We Patrol",
        location: "London, UK",
        text: "AI mengendalikan jadual bulanan kami dalam beberapa minit berbanding berjam-jam. Ia mengesan percanggahan secara automatik dan mencari pengganti syif. Mengurangkan masa pentadbiran sebanyak 70%."
    },
    {
        client: "YT Yap",
        title: "Pemilik, Yap Chan Kor",
        location: "Malaysia",
        text: "Pembantu AI kami mengendalikan tempahan, menjawab soalan rawatan, dan menghantar peringatan. Mengurangkan ketidakhadiran sebanyak 40% dan membebaskan kakitangan kaunter hadapan sepenuhnya."
    },
    {
        client: "Giovanni Carnevale",
        title: "Pengasas, Studio Giovanni Carnevale",
        location: "Itali",
        text: "AI kini mengendalikan pemprosesan invois, kemasukan data, dan semakan pematuhan secara automatik. Kami telah mengurangkan tugasan manual sebanyak 60% dan boleh fokus pada kerja penasihat strategik."
    },
    {
        client: "Michael Boken",
        title: "Pengasas",
        location: "Colombia",
        text: "Ujian reciprocator automatik kini menganalisis corak getaran dan petunjuk haus dalam masa nyata. Ketepatan pengesanan meningkat 85%, menjimatkan masa pemeriksaan manual selama berminggu-minggu."
    },
    {
        client: "Adrianne Carter",
        title: "CEO & Pengasas",
        location: "England",
        text: "AI menjana laporan jualan mingguan, ringkasan kewangan, dan papan pemuka prestasi secara automatik. Saya telah menjimatkan 15+ jam setiap bulan untuk fokus pada strategi dan perhubungan pelanggan."
    }
];

const reviewSchema = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Autoflow Solutions Malaysia",
    "url": "https://autoflow-solutions.com/ms",
    "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": String(reviews.length),
        "bestRating": "5",
        "worstRating": "1"
    },
    "review": reviews.map(r => ({
        "@type": "Review",
        "author": { "@type": "Person", "name": r.client },
        "reviewBody": r.text,
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" }
    }))
};
---

<BaseLayout 
    title="Mengenai Autoflow Solutions — Agensi Automasi AI Ditubuhkan di Malaysia, 2021"
    description="Ditubuhkan pada 2021 untuk membawa automasi gred korporat kepada PKS Malaysia. Ketahui tentang Falsafah Leveraj Manusia dan pasukan di sebalik empat Enjin utama."
    schemaData={reviewSchema}
>
    <main>
        <section class="origin-hero">
            <div class="hero-content">
                <span class="label-micro" style="margin-bottom: 1.5rem;">Kisah Asal-Usul Kami</span>
                <h1 class="text-display" style="margin-bottom: 2rem;">Lahir daripada<br>Kekangan.</h1>
                <p class="text-body-lg" style="max-width: 650px; margin-bottom: 1rem;">
                    Pada tahun 2021, kami melihat pemilik PKS yang hebat tenggelam dalam hamparan kerja (spreadsheet) sementara \"Revolusi AI\" hanya berkhidmat untuk gergasi Silicon Valley.
                </p>
                <p class="text-body-lg" style="max-width: 650px;">
                    Autoflow Solutions ditubuhkan untuk merapatkan jurang tersebut—menukar automasi elit menjadi infrastruktur yang boleh dicapai oleh perniagaan yang sebenarnya memacu ekonomi.
                </p>

                <div class="manifesto-card">
                    <div style="border-bottom: 2px solid var(--black); padding-bottom: 12px; margin-bottom: 16px; display: flex; justify-content: space-between;">
                        <span class="label-micro">MEMO_DALAMAN.EXE</span>
                        <div style="width: 10px; height: 10px; background: var(--black); border-radius: 50%;"></div>
                    </div>
                    <h3 class="text-h3" style="margin-bottom: 1rem;">Falsafah Leveraj Manusia</h3>
                    <p class="text-body" style="color: var(--black);">
                        Kami tidak percaya pada menggantikan manusia. Kami percaya pada menggantikan <strong>pergerakan berulang</strong>. Apabila anda membuang tugasan robotik daripada hari seseorang manusia, anda membuka potensi kreatif dan strategik yang sebenarnya memajukan syarikat.
                    </p>
                    <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--gray-light);">
                        <span class="label-micro">Status: Dipacu Misi</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="values-section">
            <div class="container">
                <div style="max-width: 600px;">
                    <span class="label-micro" style="color: var(--neon);">Kod Sintaks</span>
                    <h2 class="text-h2" style="margin-top: 1rem;">Nilai Teras.</h2>
                </div>

                <div class="values-grid">
                    {values.map((v) => (
                        <div class="value-cell">
                            <div class="num">{v.num}</div>
                            <h4 class="text-h3" style="color: var(--white); margin-bottom: 1rem;">{v.title}</h4>
                            <p class="text-body" style="color: var(--gray-light);">{v.body}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <section class="reviews-section">
            <div class="container">
                <div style="text-align: center; margin-bottom: var(--space-xl);">
                    <h2 class="text-h2" style="font-size: 3rem; margin-bottom: 10px;">Dipercayai oleh PKS di seluruh dunia</h2>
                    <div style="display: flex; align-items: center; justify-content: center; gap: 10px; font-weight: 700; font-size: 1.25rem;">
                        4.9/5 
                        <span style="color: #FACC15; font-size: 1.5rem;">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                    </div>
                </div>

                <div class="reviews-grid">
                    {reviews.map((review) => {
                        const initials = review.client.split(' ').map(n => n[0]).join('').substring(0, 2);
                        return (
                            <div class="review-card">
                                <div class="review-header">
                                    <div class="review-avatar">{initials}</div>
                                    <div class="review-meta">
                                        <strong>{review.client}</strong>
                                        <span>{review.title}</span>
                                        <span>{review.location}</span>
                                    </div>
                                </div>
                                <div class="review-quote">"{review.text}"</div>
                            </div>
                        )
                    })}
                </div>
            </div>
        </section>
    </main>

    <style>
        .origin-hero {
            position: relative;
            min-height: 100vh;
            padding-top: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--neon);
            background-image: radial-gradient(var(--black) 1.5px, transparent 1.5px);
            background-size: 36px 36px;
            border-bottom: 2px solid var(--black);
        }

        .hero-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            max-width: 900px;
            padding: var(--space-xl) var(--space-md);
            z-index: 2;
        }

        .manifesto-card {
            background: var(--white);
            border: 2px solid var(--black);
            padding: var(--space-md);
            box-shadow: 16px 16px 0 var(--black);
            max-width: 500px;
            margin-top: var(--space-lg);
            transform: rotate(1deg);
        }

        .values-section {
            padding: var(--space-xl) 0;
            background-color: var(--black);
            color: var(--white);
        }

        .values-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2px;
            background-color: var(--gray-dark);
            border: 1px solid var(--gray-dark);
            margin-top: var(--space-lg);
        }

        .value-cell {
            background-color: var(--black);
            padding: var(--space-lg) var(--space-md);
            transition: background 0.3s ease;
        }

        .value-cell:hover { background-color: #111; }
        .value-cell .num { font-size: 4rem; font-weight: 900; color: var(--neon); line-height: 1; margin-bottom: var(--space-sm); opacity: 0.5; }

        .reviews-section {
            padding: var(--space-xl) 0;
            background-image: 
                linear-gradient(var(--gray-light) 1px, transparent 1px),
                linear-gradient(90deg, var(--gray-light) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        .reviews-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-lg);
            margin: 0 auto;
        }

        .review-card {
            background: var(--white);
            border: 2px solid var(--black);
            padding: var(--space-lg);
            box-shadow: 12px 12px 0 var(--black);
            display: flex;
            flex-direction: column;
            gap: var(--space-md);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .review-card:hover {
            transform: translate(-4px, -4px);
            box-shadow: 16px 16px 0 #c4ef17;
        }

        .review-header {
            display: flex;
            align-items: center;
            gap: 16px;
            border-bottom: 2px solid var(--black);
            padding-bottom: var(--space-sm);
        }

        .review-avatar {
            width: 50px;
            height: 50px;
            background: var(--black);
            color: var(--neon);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .review-meta {
            display: flex;
            flex-direction: column;
        }

        .review-meta strong {
            font-size: 1.1rem;
        }

        .review-meta span {
            font-size: 0.85rem;
            color: var(--gray-dark);
            font-weight: 600;
        }

        .review-quote {
            font-size: 1.1rem;
            font-weight: 600;
            line-height: 1.5;
            color: var(--black);
        }

        @media (max-width: 1024px) {
            .values-grid { grid-template-columns: 1fr; }
            .reviews-grid { grid-template-columns: repeat(2, 1fr); padding: 0 var(--space-md); }
        }

        @media (max-width: 768px) {
            .reviews-grid { grid-template-columns: 1fr; }
            .review-card { padding: var(--space-md); }
        }
    </style>
</BaseLayout>
