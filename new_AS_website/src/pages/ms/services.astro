---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
    {
        id: "01",
        title: "Pengendalian<br>Prospek",
        price: "RM 300",
        setup: "RM 3,000",
        description: "Tangkap, layakkan, dan halakan pertanyaan daripada WhatsApp, sembang web, dan borang. Jangan terlepas satu prospek pun.",
        statLabel: "MASA MAKLUM BALAS",
        statValue: "< 3 Saat",
        capabilities: ["WhatsApp & Sembang Web", "Respons FAQ", "Kelayakan Prospek", "Pemulihan Pertanyaan Terlepas"]
    },
    {
        id: "02",
        title: "Automasi<br>Aliran Kerja",
        price: "RM 540",
        setup: "RM 5,400",
        description: "Aliran kerja pejabat belakang yang menyegerakkan CRM, mencetus onboarding, dan mengendalikan makluman dalaman.",
        statLabel: "BIASA DIJIMATKAN",
        statValue: "20+ jam / seminggu",
        capabilities: ["Penyelarasan CRM", "Aliran Kerja Onboarding", "Penjanaan Dokumen", "Makluman Dalaman"]
    },
    {
        id: "03",
        title: "Pelaksanaan<br>Tugasan AI",
        price: "RM 600",
        setup: "RM 6,000+",
        description: "Pekerja autonomi untuk menjawab panggilan suara, penyelidikan berulang, dan tindakan rentas sistem.",
        statLabel: "KADAR AUTONOMI",
        statValue: "100% Tanpa Tangan",
        capabilities: ["Pengendalian Panggilan Suara", "Penyelidikan & Kemasukan Data", "Tindakan Rentas Sistem", "Jejak Audit Penuh"]
    }
];

const serviceSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Perkhidmatan Automasi AI oleh Autoflow Solutions — Malaysia",
    "description": "Empat enjin automasi AI yang direka khusus untuk PKS Malaysia.",
    "itemListElement": services.map((s, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
            "@type": "Service",
            "name": s.title,
            "description": s.description,
            "areaServed": "MY",
            "provider": {
                "@type": "Organization",
                "name": "Autoflow Solutions",
                "url": "https://autoflow-solutions.com"
            }
        }
    }))
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Berapa lama masa yang diperlukan untuk melaksanakan sistem automasi AI?",
            "acceptedAnswer": { "@type": "Answer", "text": "Kebanyakan projek mengambil masa 2–4 minggu dari taklimat awal hingga pelancaran produksi. Anda akan menerima pelan pelaksanaan lengkap dalam masa 48 jam selepas taklimat awal anda." }
        },
        {
            "@type": "Question",
            "name": "Adakah saya memerlukan pengetahuan teknikal untuk menggunakan sistem automasi anda?",
            "acceptedAnswer": { "@type": "Answer", "text": "Tidak. Sistem kami dibina dan diselenggara sepenuhnya oleh kami. Anda hanya menggunakan papan pemuka dan aliran kerja yang ringkas — tiada kod diperlukan di pihak anda." }
        },
        {
            "@type": "Question",
            "name": "Apakah alatan dan platform yang boleh diintegrasikan dengan automasi anda?",
            "acceptedAnswer": { "@type": "Answer", "text": "Kami berintegrasi dengan Salesforce, HubSpot, Zoho, Google Workspace, WhatsApp Business, dan banyak lagi melalui Make.com, n8n, dan middleware API kustom." }
        }
    ]
};
---


<BaseLayout 
    title="Perkhidmatan Automasi AI Malaysia — Empat Enjin Utama"
    description="Empat sistem automasi khusus: pengangkapan prospek AI, automasi pejabat belakang, ejen suara, dan pelaksanaan tugasan autonomi. Fokus PKS Malaysia."
    schemaData={[serviceSchema, faqSchema]}
>
    <div class="cursor-follower" id="cursorFollower">
        <div class="cursor-core"></div>
    </div>

    <script is:inline>
        const follower = document.getElementById('cursorFollower');
        if (follower) {
            let mouseX = window.innerWidth / 2, mouseY = window.innerHeight / 2;
            let currentX = mouseX, currentY = mouseY;
            
            document.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
            });
            
            function animate() {
                currentX += (mouseX - currentX) * 0.08;
                currentY += (mouseY - currentY) * 0.08;
                follower.style.left = currentX + 'px';
                follower.style.top = currentY + 'px';
                requestAnimationFrame(animate);
            }
            animate();
        }
    </script>

    <header class="services-hero">
        <div class="container">
            <span class="label-micro" style="margin-bottom: 1rem;">ARSENIL KAMI</span>
            <h1 class="text-display" style="margin-bottom: 2rem;">SENI BINA<br>PENYELESAIAN.</h1>
            <p class="text-body-lg" style="max-width: 600px;">Kami menggantikan proses yang rosak dengan sistem autonomi yang menangkap prospek, menghapuskan beban kerja admin, dan meningkatkan skala perniagaan anda.</p>
        </div>
    </header>

    <section class="density-section" style="background-color: var(--black); color: var(--white); padding: 4rem 0;">
        <div class="container">
            <div class="grid-2" style="gap: 4rem;">
                <div>
                    <h3 class="text-h3" style="color: var(--neon); margin-bottom: 1rem;">Masalah & Kos Tiada Tindakan</h3>
                    <p class="text-body" style="color: var(--gray-light); margin-bottom: 1rem;">Apabila prospek tidak dijawab dengan serta-merta, mereka beralih ke pesaing. Apabila data tidak disegerakkan, kakitangan membuang masa menyalin maklumat secara manual dan bukan melakukan kerja bernilai tinggi.</p>
                    <p class="text-body" style="color: var(--gray-light);">Kosnya? Pembaziran bajet pemasaran, kos gaji meningkat, dan had pada pertumbuhan anda.</p>
                </div>
                <div>
                    <h3 class="text-h3" style="color: var(--neon); margin-bottom: 1rem;">Untuk Siapa & Hasil Jangkaan</h3>
                    <p class="text-body" style="color: var(--gray-light); margin-bottom: 1rem;">Sistem kami dibina untuk <strong>PKS Perkhidmatan Profesional</strong> (perakaunan, guaman, perundingan, klinik) yang bergantung pada perbualan bernilai tinggi dan data bersih.</p>
                    <p class="text-body" style="color: var(--gray-light);">Anda boleh jangkakan pengurangan beban operasi, CRM yang sentiasa tepat, dan pengendalian prospek 24/7.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="services-list" style="padding-top: 4rem;">
        <div class="container">
            <div class="services-grid">
                {services.map((svc) => (
                    <div class="service-card">
                        <div class="neon-bar"></div>
                        <div class="service-id-large">{svc.id}</div>
                        <h2 class="service-title">{svc.title}</h2>
                        <div class="price-container" style="margin-bottom: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--gray-light); min-height: 80px;">
                            <div style="display: flex; align-items: baseline; gap: 4px;">
                                <span style="font-size: 2rem; font-weight: 900;">{svc.price}</span>
                                {svc.price !== "Custom" && svc.price !== "Hubungi" && <span style="font-size: 0.8rem; font-weight: 700; opacity: 0.6;">/bln</span>}
                            </div>
                            {svc.setup && <div style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--gray-dark);">+ {svc.setup} Setup</div>}
                            {svc.price !== "Custom" && svc.price !== "Hubungi" && <div style="font-size: 0.6rem; color: var(--gray-dark); opacity: 0.6; font-weight: 600; margin-top: 4px;">Retainer untuk pembetulan & pelarasan kecil. Kos API ditanggung oleh pelanggan melalui akaun mereka sendiri.</div>}
                        </div>
                        <p style="font-size: 0.85rem; color: var(--gray-dark); margin-bottom: 2rem;">{svc.description}</p>
                        
                        <div class="stat-box">
                            <span class="stat-label">{svc.statLabel}</span>
                            <div class="stat-value">{svc.statValue}</div>
                        </div>

                        <div class="card-overlay">
                            <span class="label-micro" style="border-color: var(--neon); color: var(--neon); margin-bottom: 1rem; font-size: 0.6rem;">Ciri-ciri Utama</span>
                            <ul class="capability-list">
                                {svc.capabilities.map((cap) => (
                                    <li>{cap}</li>
                                ))}
                            </ul>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="trust-bar">
        <div class="container" style="text-align: center; width: 100%; margin: 0 auto; margin-bottom: var(--space-xl); position: relative; z-index: 3;">
            <h2 class="h1" style="margin-bottom: 0; display: inline-block; font-size: 3.5rem; text-transform: uppercase;">Rakan Kongsi <span class="text-gradient">Dipercayai</span></h2>
        </div>
        <div class="marquee-logos-container">
            <div class="marquee-logos">
                <!-- Group 1 -->
                <a href="https://cloud.google.com/products/gemini" target="_blank" rel="noopener"><img src="/partners%20logos/9fa23e7d-googleantigravitylogo-whitebackground-removebg-preview.png" alt="Antigravity" /></a>
                <a href="https://www.gohighlevel.com" target="_blank" rel="noopener"><img src="/partners%20logos/go-high-level-logo-white-removebg-preview.png" alt="HighLevel" /></a>
                <a href="https://www.voiceflow.com" target="_blank" rel="noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_43PM__1_-removebg-preview.png" alt="Voiceflow" /></a>
                <a href="https://n8n.io" target="_blank" rel="noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_42PM-removebg-preview.png" alt="n8n" /></a>
                <a href="https://www.make.com/en/register?pc=asagency" target="_blank" rel="sponsored noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_43PM-removebg-preview.png" alt="Make" /></a>
                <a href="https://code.visualstudio.com" target="_blank" rel="noopener"><img src="/partners%20logos/vs-code-logo-removebg-preview.png" alt="VS Code" /></a>
                <a href="https://claude.ai" target="_blank" rel="noopener"><img src="/partners%20logos/claude_code-removebg-preview.png" alt="Claude" /></a>
                <a href="https://www.zoho.com" target="_blank" rel="noopener"><img src="/partners%20logos/ZOHO.svg-removebg-preview.png" alt="Zoho" /></a>
                
                <!-- Group 2 -->
                <a href="https://cloud.google.com/products/gemini" target="_blank" rel="noopener"><img src="/partners%20logos/9fa23e7d-googleantigravitylogo-whitebackground-removebg-preview.png" alt="Antigravity" /></a>
                <a href="https://www.gohighlevel.com" target="_blank" rel="noopener"><img src="/partners%20logos/go-high-level-logo-white-removebg-preview.png" alt="HighLevel" /></a>
                <a href="https://www.voiceflow.com" target="_blank" rel="noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_43PM__1_-removebg-preview.png" alt="Voiceflow" /></a>
                <a href="https://n8n.io" target="_blank" rel="noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_42PM-removebg-preview.png" alt="n8n" /></a>
                <a href="https://www.make.com/en/register?pc=asagency" target="_blank" rel="sponsored noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_43PM-removebg-preview.png" alt="Make" /></a>
                <a href="https://code.visualstudio.com" target="_blank" rel="noopener"><img src="/partners%20logos/vs-code-logo-removebg-preview.png" alt="VS Code" /></a>
                <a href="https://claude.ai" target="_blank" rel="noopener"><img src="/partners%20logos/claude_code-removebg-preview.png" alt="Claude" /></a>
                <a href="https://www.zoho.com" target="_blank" rel="noopener"><img src="/partners%20logos/ZOHO.svg-removebg-preview.png" alt="Zoho" /></a>
            </div>
        </div>
    </section>

    <section id="request" class="request-section">
        <div class="container request-container">
            <div>
                <span style="color: var(--neon); font-size: 0.8rem; font-weight: 800; text-transform: uppercase; margin-bottom: 2rem; display: block; letter-spacing: 1px;">Mulakan Projek</span>
                <h2 style="font-size: 4rem; line-height: 1; font-weight: 900; margin-bottom: 2rem; letter-spacing: -2px;">Beritahu Kami<br>Apa Yang Rosak.</h2>
                <p class="text-body-lg" style="color: var(--gray-light); font-weight: 500; font-size: 1.1rem; max-width: 450px; margin-bottom: 2.5rem;">Hantar ringkasan anda. Jurutera kami akan semak dan balas dengan pelan pembinaan yang jelas — tiada panggilan jualan, tiada janji kosong.</p>
                
                <div style="display: flex; flex-direction: column; gap: 1rem; max-width: 350px;">
                    <a href="/ms/tools/automation-roi-calculator" class="btn btn-solid" style="background-color: var(--neon); color: var(--black);">Kira ROI Dahulu</a>
                    <a href="https://ai-self-audit.autoflow-solutions.com/" class="btn btn-outline" style="border-color: var(--white); color: var(--white);">Atau Mula Audit AI Percuma</a>
                </div>
                
                <p class="text-body" style="color: rgba(255,255,255,0.5); font-size: 0.9rem; margin-top: 3rem;">Belum bersedia? Gunakan alat di atas untuk lihat di mana automasi paling berbaloi.</p>
            </div>
            
            <div class="form-card">
                <form id="build-brief-form" novalidate>
                    <div class="input-group">
                        <label>Enjin Sasaran</label>
                        <select name="target_engine" required>
                            <option value="">Pilihan mana yang paling sesuai?</option>
                            <option value="The Engagement Engine (Chat/Lead Capture)">Enjin Interaksi (Chat/Lead Capture)</option>
                            <option value="The Operations Engine (Back-Office/CRM)">Enjin Operasi (Pejabat Belakang/CRM)</option>
                            <option value="The Voice Engine (Voice Assistants)">Enjin Suara (Pembantu Suara)</option>
                            <option value="The Execution Engine (Digital Workers)">Enjin Pelaksanaan (Pekerja Digital)</option>
                            <option value="Not Sure / Custom Build">Tidak Pasti / Perlukan Bina Kustom</option>
                        </select>
                    </div>
                    <div class="form-row">
                        <div class="input-group">
                            <label>Nama Penuh</label>
                            <input type="text" name="full_name" placeholder="John Doe" required>
                        </div>
                        <div class="input-group">
                            <label>Emel Kerja</label>
                            <input type="email" name="email" placeholder="john@syarikat.com" required>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="input-group">
                            <label>Laman Web Syarikat</label>
                            <input type="url" name="website" placeholder="https://syarikatanda.com" required>
                        </div>
                        <div class="input-group">
                            <label>Berapa ramai ahli pasukan anda?</label>
                            <select name="team_size" required>
                                <option value="">Pilih saiz pasukan</option>
                                <option value="Solo / Just me">Seorang / Saya sahaja</option>
                                <option value="2-10">2–10</option>
                                <option value="11-50">11–50</option>
                                <option value="50+">50+</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="input-group">
                            <label>Bila anda ingin bermula?</label>
                            <select name="timeline" required>
                                <option value="">Pilih masa</option>
                                <option value="ASAP">Segera — ini sedang menjejaskan kami</option>
                                <option value="1-3 months">Dalam 1–3 bulan</option>
                                <option value="Exploring">Meneroka buat masa ini</option>
                            </select>
                        </div>
                        <div class="input-group">
                            <label>Teknologi Sedia Ada</label>
                            <input type="text" name="tech_stack" placeholder="cth: Salesforce, Shopify, Excel...">
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Kekangan Utama</label>
                        <textarea name="bottleneck" rows="3" placeholder="Huraikan tugasan manual yang anda mahu jurutera kami automasikan..." required></textarea>
                    </div>
                    <button type="submit" class="btn-submit-pill">Mulakan Penilaian</button>
                    <div id="form-status" style="display:none; margin-top:1rem; padding:1rem; border-radius:8px; text-align:center; font-size:0.9rem;"></div>
                </form>
            </div>

            <script>
            (function() {
                const N8N_WEBHOOK = 'https://n8n.soryle.space/webhook/form-sumission';
                const FORMSPREE   = 'https://formspree.io/f/mqeyoabe';

                document.getElementById('build-brief-form').addEventListener('submit', async function(e) {
                    e.preventDefault();
                    const form   = e.target;
                    const btn    = form.querySelector('button[type="submit"]');
                    const status = document.getElementById('form-status');

                    if (!form.checkValidity()) {
                        form.reportValidity();
                        return;
                    }

                    btn.disabled    = true;
                    btn.textContent = 'Menghantar…';
                    status.style.display = 'none';

                    const data = {
                        target_engine: form.target_engine.value,
                        full_name:     form.full_name.value,
                        email:         form.email.value,
                        website:       form.website.value,
                        team_size:     form.team_size.value,
                        timeline:      form.timeline.value,
                        tech_stack:    form.tech_stack.value,
                        bottleneck:    form.bottleneck.value,
                        source_page:   window.location.pathname,
                        locale:        'ms',
                        submitted_at:  new Date().toISOString()
                    };

                    const formData = new FormData(form);

                    try {
                        await Promise.all([
                            fetch(N8N_WEBHOOK, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(data)
                            }),
                            fetch(FORMSPREE, {
                                method: 'POST',
                                headers: { 'Accept': 'application/json' },
                                body: formData
                            })
                        ]);
                        form.reset();
                        btn.textContent = 'Dihantar!';
                        status.style.cssText = 'display:block; background:rgba(212,255,0,0.1); border:1px solid #D4FF00; color:#D4FF00; margin-top:1rem; padding:1rem; border-radius:8px; text-align:center; font-size:0.9rem;';
                        status.textContent = "Brifing diterima. Kami akan semak dan menghubungi anda tidak lama lagi.";
                    } catch (err) {
                        btn.disabled    = false;
                        btn.textContent = 'Mulakan Penilaian';
                        status.style.cssText = 'display:block; background:rgba(255,80,80,0.1); border:1px solid #ff5050; color:#ff5050; margin-top:1rem; padding:1rem; border-radius:8px; text-align:center; font-size:0.9rem;';
                        status.textContent = 'Ralat berlaku. Sila cuba lagi atau hubungi kami terus melalui emel.';
                    }
                });
            })();
            </script>
        </div>
    </section>

    <div class="marquee-footer">
        <div class="marquee-text">
            SEDIA UNTUK BERKEMBANG? • HUBUNGI JUALAN • TIADA JANJI KOSONG • DIBINA UNTUK TAHAN LAMA • SEDIA UNTUK BERKEMBANG? • HUBUNGI JUALAN • TIADA JANJI KOSONG • DIBINA UNTUK TAHAN LAMA •
        </div>
    </div>

    <style>
        .services-hero {
            padding: 160px 0 60px;
            background-image: radial-gradient(var(--gray-light, #E5E5E5) 1px, transparent 1px);
            background-size: 30px 30px;
            position: relative;
            z-index: 1;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 0;
            margin-bottom: var(--space-xl);
            border-left: 1px solid var(--gray-light, #E5E5E5);
            border-right: 1px solid var(--gray-light, #E5E5E5);
            position: relative;
            z-index: 1;
        }

        .service-card {
            border: 1px solid var(--gray-light, #E5E5E5);
            padding: var(--space-md, 2rem);
            position: relative;
            display: flex;
            flex-direction: column;
            min-height: 600px;
            background: var(--white, #fff);
            transition: all 0.3s ease;
            overflow: hidden;
        }

        .neon-bar {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: var(--neon, #D4FF00);
            transform: scaleX(0);
            transition: transform 0.3s ease;
            transform-origin: left;
        }

        .service-card:hover {
            background: var(--gray-bg, #F9F9F9);
            z-index: 2;
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        }

        .service-card:hover .neon-bar {
            transform: scaleX(1);
        }

        .service-id-large {
            font-size: 4rem;
            font-weight: 900;
            line-height: 1;
            margin-bottom: var(--space-md, 2rem);
            opacity: 0.6;
            transition: opacity 0.3s ease;
            color: #D4FF00;
            text-shadow: 0 0 20px rgba(212, 255, 0, 0.3);
        }

        .service-card:hover .service-id-large {
            opacity: 1;
        }
        
        .service-title { 
            font-size: 1.5rem; 
            margin-bottom: 1rem; 
            letter-spacing: -0.01em;
            text-transform: uppercase;
        }

        .service-price { 
            font-weight: 800; 
            font-size: 0.75rem; 
            color: var(--gray-dark, #333);
            margin-bottom: var(--space-md, 2rem);
            display: block;
            border-top: 1px solid var(--gray-light, #E5E5E5);
            padding-top: 1rem;
        }

        .stat-box {
            padding-top: 1.5rem;
            margin-top: auto;
        }

        .stat-label { font-size: 0.6rem; font-weight: 800; text-transform: uppercase; margin-bottom: 0.5rem; display: block; color: var(--gray-dark, #333); }
        .stat-value { font-size: 1.25rem; font-weight: 900; line-height: 1; }

        .card-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: var(--black, #050505);
            color: var(--white, #fff);
            padding: var(--space-md, 2rem);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .service-card:hover .card-overlay {
            opacity: 1;
            pointer-events: auto;
        }

        .capability-list { list-style: none; }
        .capability-list li {
            padding: 8px 0;
            border-bottom: 1px solid var(--gray-dark, #333);
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        .capability-list li::before { content: ""; width: 4px; height: 4px; background: var(--neon, #D4FF00); }

        .request-section {
            padding: var(--space-xl, 8rem) 0;
            background: var(--black, #050505);
            color: var(--white, #fff);
            position: relative;
            z-index: 1;
        }

        .request-container {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: var(--space-xl, 8rem);
        }

        @media (max-width: 1024px) {
            .request-container {
                grid-template-columns: 1fr;
                gap: 4rem;
            }
        }

        .form-card {
            background: var(--white, #fff);
            padding: var(--space-lg, 4rem);
