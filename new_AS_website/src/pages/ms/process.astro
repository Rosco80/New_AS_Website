---
import BaseLayout from '../../layouts/BaseLayout.astro';

const steps = [
    {
        title: "Audit Kekangan",
        tag: "PERINGKAT_01",
        description: "Kami tidak membuat telkaan. Kami memerhati pasukan anda bekerja, memetakan setiap helaian kerja (spreadsheet), emel manual, dan titik kemasukan data berulang untuk mengenal pasti di mana AI dapat menjimatkan masa anda paling banyak."
    },
    {
        title: "Rangka Tindakan",
        tag: "PERINGKAT_02",
        description: "Kami merancang seni bina automasi kustom. Ini bukan sekadar senarai alatan—ia adalah pelan hala tuju teknikal yang memastikan sistem anda berhubung antara satu sama lain dengan lancar."
    },
    {
        title: "Binaan Berimpak Tinggi",
        tag: "PERINGKAT_03",
        description: "Jurutera kami membina ejen dan rangkaian automasi anda. Kami mengutamakan persekitaran produksi yang stabil berbanding eksperimen yang rapuh, memastikan kebolehpercayaan dari hari pertama."
    },
    {
        title: "Penalaan Berterusan",
        tag: "PERINGKAT_04",
        description: "Selepas pelancaran, kami memantau dan mengoptimumkan. Apabila perniagaan anda berkembang, kami melaraskan model dan aliran kerja untuk mengendalikan beban baharu tanpa perlu menambah kakitangan."
    }
];
---

<BaseLayout title="Proses Kami">
    <main>
        <!-- Hero Section -->
        <section class="process-hero">
            <div class="container">
                <span class="label-micro" style="color: var(--neon);">Kecemerlangan Operasi</span>
                <h1 class="text-display" style="color: var(--white); margin: 1.5rem 0;">Daripada Kelam-Kabut<br>kepada Autopilot.</h1>
                <p class="text-body-lg" style="max-width: 600px; color: var(--gray-light);">
                    Kebanyakan agensi menjual masa. Kami menjual hasil. Berikut adalah bagaimana kami mengubah aliran kerja tradisional kepada sistem autonomi berprestasi tinggi.
                </p>
            </div>
        </section>

        <!-- Process Steps -->
        <section class="steps-section">
            <div class="container">
                <div class="steps-vertical">
                    {steps.map((step, index) => (
                        <div class="step-row">
                            <div class="step-num-col">
                                <div class="step-num">{index + 1}</div>
                                <div class="step-line"></div>
                            </div>
                            <div class="step-content-box">
                                <span class="label-micro process-tag">{step.tag}</span>
                                <h3 class="text-h2" style="margin: 1rem 0;">{step.title}</h3>
                                <p class="text-body-lg" style="color: var(--gray-dark);">{step.description}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Values/Why Section -->
        <section class="why-section">
            <div class="container grid-3">
                <div class="why-card">
                    <span class="label-micro">01</span>
                    <h4 class="text-h3">Pemilikan</h4>
                    <p class="text-body">Kami membina di atas sistem anda. Anda memiliki kod, arahan (prompts), dan data tersebut. Selamanya.</p>
                </div>
                <div class="why-card">
                    <span class="label-micro">02</span>
                    <h4 class="text-h3">Utamakan Keselamatan</h4>
                    <p class="text-body">Prinsip patuh SOC2 diterapkan pada setiap rangkaian RAG dan automasi yang kami hasilkan.</p>
                </div>
                <div class="why-card">
                    <span class="label-micro">03</span>
                    <h4 class="text-h3">Berpandukan ROI</h4>
                    <p class="text-body">Jika ia tidak menjimatkan sekurang-kurangnya 10 jam seminggu atau $2k kos operasi, kami tidak akan membinanya.</p>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="process-cta">
            <div class="container" style="text-align: center;">
                <h2 class="text-h2" style="margin-bottom: 2rem;">Sedia untuk automasi?</h2>
                <a href="/ms/services#request" class="btn btn-neon">Tempah Audit Kekangan Anda</a>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    .process-hero {
        background-color: var(--black);
        padding: 160px 0 100px;
        border-bottom: 2px solid var(--neon);
    }

    .steps-section {
        padding: var(--space-xl) 0;
        background: var(--white);
    }

    .steps-vertical {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
    }

    .step-row {
        display: flex;
        gap: var(--space-lg);
        min-height: 250px;
    }

    .step-num-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 60px;
    }

    .step-num {
        width: 60px;
        height: 60px;
        background: var(--black);
        color: var(--neon);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .step-line {
        width: 4px;
        background: var(--black);
        flex-grow: 1;
        margin: 10px 0;
    }

    .step-row:last-child .step-line {
        display: none;
    }

    .step-content-box {
        padding-bottom: var(--space-xl);
    }

    .process-tag {
        background: var(--black);
        color: var(--white);
        padding: 4px 8px;
        border-radius: 4px;
        font-family: monospace;
    }

    .why-section {
        padding: var(--space-xl) 0;
        background: var(--gray-light);
    }

    .grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-lg);
    }

    .why-card {
        background: var(--white);
        padding: var(--space-lg);
        border-top: 4px solid var(--neon);
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .why-card .label-micro {
        color: var(--gray-dark);
        opacity: 0.5;
    }

    .process-cta {
        padding: var(--space-xl) 0;
        background: var(--black);
        color: var(--white);
    }

    @media (max-width: 768px) {
        .grid-3 { grid-template-columns: 1fr; }
        .step-row { min-height: auto; }
    }
</style>
