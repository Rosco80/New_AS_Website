---
import BaseLayout from '../layouts/BaseLayout.astro';

const auditSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Autoflow Solutions AI Self-Audit",
  "operatingSystem": "Web-based",
  "applicationCategory": "BusinessApplication",
  "description": "A comprehensive self-service audit tool to evaluate your business's readiness for AI agents and systems automation.",
  "offers": {
    "@type": "Offer",
    "price": "0.00",
    "priceCurrency": "USD"
  },
  "provider": {
    "@type": "Organization",
    "name": "Autoflow Solutions"
  }
};
---

<BaseLayout title="AI Self-Audit | Evaluate Your Automation Readiness" schema={auditSchema}>
    <main class="audit-landing">
        <header class="hero-section">
            <div class="container text-center">
                <span class="label-micro animate-fade-in" style="margin-bottom: 1.5rem;">The Assessment Engine</span>
                <h1 class="text-display animate-scale-in" style="margin-bottom: 2rem;">STOP WONDERING.<br>START AUTOMATING.</h1>
                <p class="text-body-lg animate-fade-in" style="max-width: 750px; margin: 0 auto 3rem;">Evaluate your business's automation potential in 5 minutes. Get a professional readiness score and a custom roadmap for your AI transition.</p>
                <div class="cta-container animate-fade-in">
                    <a href="https://ai-self-audit.autoflow-solutions.com/" class="btn-neon-large" target="_blank" rel="noopener">START FREE AUDIT →</a>
                </div>
            </div>
        </header>

        <section class="value-pillars">
            <div class="container grid-pillars">
                <div class="blueprint-card">
                    <span class="pillar-num">01</span>
                    <h3 class="text-h3">Capabilities Mapping</h3>
                    <p class="text-body-sm">Identify which operational bottlenecks in your business are prime targets for AI Agents and Digital Workers.</p>
                </div>
                <div class="blueprint-card active">
                    <span class="pillar-num">02</span>
                    <h3 class="text-h3">ROI Projection</h3>
                    <p class="text-body-sm">Calculate potential time and cost savings by automating manual data entry, scheduling, and customer inquiries.</p>
                </div>
                <div class="blueprint-card">
                    <span class="pillar-num">03</span>
                    <h3 class="text-h3">Applied Leverage</h3>
                    <p class="text-body-sm">Receive a priority list of automation projects ranked by complexity and business impact.</p>
                </div>
            </div>
        </section>

        <section class="preview-section">
            <div class="container">
                <div class="preview-grid">
                    <div class="text-content">
                        <span class="label-micro">SYSTEM_OUTPUT.LOG</span>
                        <h2 class="text-h2" style="margin: 1.5rem 0;">A Professional<br>Grade Roadmap.</h2>
                        <p class="text-body" style="margin-bottom: 2rem;">No generic advice. Our audit engine analyzes your specific tech stack and team structure to provide a technical blueprint for Applied Leverage.</p>
                        <ul class="check-list">
                            <li>Readiness Scoring (0-100)</li>
                            <li>Integration Feasibility Analysis</li>
                            <li>Digital Worker Specification Sheet</li>
                            <li>30-60-90 Day Transition Plan</li>
                        </ul>
                    </div>
                    <div class="visual-content">
                        <div class="audit-card-preview">
                            <div class="neon-bar"></div>
                            <div class="preview-header">
                                <span class="badge">SCORE: 84/100</span>
                                <span class="type">STATUS: READY_FOR_LEVERAGE</span>
                            </div>
                            <div class="preview-graph">
                                <div class="bar" style="height: 60%;"></div>
                                <div class="bar active" style="height: 90%;"></div>
                                <div class="bar" style="height: 40%;"></div>
                                <div class="bar" style="height: 75%;"></div>
                            </div>
                            <p class="preview-text">"High probability of 40% reduction in operations overhead within Q3 via Automation Pipelines."</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="final-cta">
            <div class="container text-center">
                <div class="cta-box">
                    <h2 class="text-h2" style="margin-bottom: 1.5rem;">Join 500+ Businesses Already Building Future-Proof Systems.</h2>
                    <a href="https://ai-self-audit.autoflow-solutions.com/" class="btn btn-outline-neon" target="_blank" rel="noopener">LAUNCH AUDIT ENGINE</a>
                </div>
            </div>
        </section>
    </main>

    <style>
        .audit-landing {
            background-color: var(--black);
            color: var(--white);
            overflow-x: hidden;
        }

        .hero-section {
            padding: 200px 0 100px;
            background-image: radial-gradient(var(--gray-dark) 1px, transparent 1px);
            background-size: 50px 50px;
            border-bottom: 2px solid var(--gray-dark);
        }

        .btn-neon-large {
            display: inline-block;
            background: var(--neon);
            color: var(--black);
            padding: 20px 48px;
            font-size: 1.2rem;
            font-weight: 900;
            text-decoration: none;
            border-radius: 99px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 0 20px rgba(196, 239, 23, 0.3);
        }

        .btn-neon-large:hover {
            transform: scale(1.05) translateY(-5px);
            box-shadow: 0 15px 30px rgba(196, 239, 23, 0.5);
            background: var(--white);
        }

        .grid-pillars {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            margin-top: -50px;
            perspective: 1000px;
        }

        .blueprint-card {
            background: rgba(10,10,15,0.95);
            border: 2px solid var(--gray-dark);
            padding: 3rem 2rem;
            position: relative;
            transition: all 0.4s ease;
        }

        .blueprint-card.active {
            border-color: var(--neon);
            box-shadow: 10px 10px 0 var(--neon);
            transform: translateY(-10px);
        }

        .blueprint-card:hover { border-color: var(--neon); }

        .pillar-num {
            position: absolute;
            top: 1rem;
            right: 1.5rem;
            font-family: var(--font-display);
            font-size: 3rem;
            color: var(--gray-dark);
            font-weight: 900;
            opacity: 0.5;
        }

        .preview-section {
            padding: 120px 0;
            background-image: linear-gradient(var(--gray-dark) 1px, transparent 1px), linear-gradient(90deg, var(--gray-dark) 1px, transparent 1px);
            background-size: 80px 80px;
        }

        .preview-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6rem;
            align-items: center;
        }

        .check-list {
            list-style: none;
            padding: 0;
        }

        .check-list li {
            padding: 12px 0;
            display: flex;
            align-items: center;
            gap: 15px;
            font-weight: 700;
            border-bottom: 1px solid var(--gray-dark);
        }

        .check-list li::before {
            content: "✓";
            color: var(--neon);
            font-weight: 900;
        }

        .audit-card-preview {
            background: var(--white);
            color: var(--black);
            padding: 3rem;
            position: relative;
            box-shadow: 30px 30px 0 #1a1a1a;
            transform: rotate(2deg);
        }

        .neon-bar {
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 10px;
            background: var(--neon);
        }

        .preview-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 2rem;
            font-weight: 900;
            font-size: 0.8rem;
        }

        .badge { background: var(--black); color: var(--neon); padding: 4px 12px; }

        .preview-graph {
            display: flex;
            align-items: flex-end;
            gap: 15px;
            height: 200px;
            margin-bottom: 2rem;
            border-bottom: 2px solid var(--black);
            padding-bottom: 8px;
        }

        .preview-graph .bar {
            flex: 1;
            background: var(--gray-dark);
            min-height: 20px;
        }

        .preview-graph .bar.active { background: var(--neon); }

        .final-cta {
            padding: 100px 0 160px;
        }

        .cta-box {
            background: var(--gray-dark);
            padding: 5rem 3rem;
            border: 2px solid var(--neon);
            max-width: 900px;
            margin: 0 auto;
        }

        @media (max-width: 1024px) {
            .grid-pillars { grid-template-columns: 1fr; margin-top: 40px; }
            .preview-grid { grid-template-columns: 1fr; gap: 4rem; }
            .hero-section { padding: 140px 0 80px; }
        }
    </style>
</BaseLayout>
