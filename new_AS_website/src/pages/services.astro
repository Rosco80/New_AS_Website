---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
    {
        id: "01",
        title: "Engagement<br>Engine",
        price: "$299",
        setup: "$749",
        description: "24/7 inquiry capture, qualification, and booking handoff across web and WhatsApp. Never miss a lead again.",
        statLabel: "RESPONSE TIME",
        statValue: "< 3 Seconds",
        capabilities: ["WhatsApp & Web Chat", "FAQ Handling", "Lead Qualification", "Missed Inquiry Recovery"]
    },
    {
        id: "02",
        title: "Operations<br>Engine",
        price: "$549",
        setup: "$1,399",
        description: "Back-office workflow automation that removes repetitive admin. The commercial center of your autonomous business.",
        statLabel: "TIME SAVED",
        statValue: "20+ hrs / week",
        capabilities: ["CRM Sync & Updates", "Onboarding Workflows", "Document Generation", "Internal Notifications"]
    },
    {
        id: "03",
        title: "Voice<br>Engine",
        price: "$699",
        setup: "$1,599",
        description: "An always-on AI front desk that answers calls, qualifies inquiries, and routes or books instantly.",
        statLabel: "CALL RESOLUTION",
        statValue: "80% Automated",
        capabilities: ["Inbound Voice Handling", "Live Call Routing", "Appointment Booking", "Call Summary Logging"]
    },
    {
        id: "04",
        title: "Execution<br>Engine",
        price: "Custom",
        setup: "$1,599+",
        description: "Autonomous digital workers that complete multi-step business tasks. Managed retainer available.",
        statLabel: "AUTONOMY RATE",
        statValue: "100% Hands-Off",
        capabilities: ["Discovery Sprint Included", "Task Research & Data Entry", "Cross-System Actions", "Full Audit Trail"]
    },
    {
        id: "05",
        title: "Global<br>Enterprise",
        price: "Contact",
        setup: "$1,599+",
        description: "Organization-wide autonomous orchestration. For companies with 10k+ monthly interactions.",
        statLabel: "SCALE",
        statValue: "Unlimited",
        capabilities: ["Dedicated AI Strategy Lead", "Custom RAG Architectures", "On-Premise Deployment", "24/7 Priority Support"]
    }
];
const faqs = [
    {
        question: "How does the Engagement Engine capture leads 24/7?",
        answer: "Our AI systems use context-aware, multi-lingual models to engage visitors in real-time, qualifying them and booking appointments directly into your calendar even when your team is offline."
    },
    {
        question: "What makes your 'Digital Workers' different from standard bots?",
        answer: "Unlike basic bots that just follow scripts, our Execution Engine uses multi-step reasoning and tool execution to perform complex tasks like document extraction, research, and data verification autonomously."
    },
    {
        question: "Can these AI agents integrate with my existing CRM?",
        answer: "Yes, we specialize in 'API orchestration,' bridging the gap between fragmented software like Salesforce, HubSpot, and HighLevel to ensure data flows automatically without manual entry."
    }
];

const serviceSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "AI Automation Services",
    "description": "Custom AI agents and automation pipelines for SMEs.",
    "itemListElement": services.map((svc, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "item": {
            "@type": "Service",
            "name": svc.title,
            "description": svc.description,
            "provider": {
                "@type": "Organization",
                "name": "Autoflow Solutions"
            },
            "offers": {
                "@type": "Offer",
                "description": svc.price
            }
        }
    }))
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer
        }
    }))
};

const combinedPageSchema = [serviceSchema, faqSchema];
---

<BaseLayout title="Our Services" schema={combinedPageSchema}>
    <div class="cursor-follower" id="cursorFollower">
        <div class="cursor-core"></div>
    </div>

    <script is:inline>
        const follower = document.getElementById('cursorFollower');
        if (follower) {
            let mouseX = window.innerWidth / 2, mouseY = window.innerHeight / 2;
            let currentX = mouseX, currentY = mouseY;
            
            document.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
            });
            
            function animate() {
                currentX += (mouseX - currentX) * 0.08;
                currentY += (mouseY - currentY) * 0.08;
                follower.style.left = currentX + 'px';
                follower.style.top = currentY + 'px';
                requestAnimationFrame(animate);
            }
            animate();
        }
    </script>

    <header class="services-hero">
        <div class="container">
            <span class="label-micro" style="margin-bottom: 1rem;">OUR ARSENAL</span>
            <h1 class="text-display" style="margin-bottom: 2rem;">APPLIED<br>LEVERAGE.</h1>
            <p class="text-body-lg" style="max-width: 600px;">We don't sell software. We install systems that replace manual overhead with autonomous reliability.</p>
        </div>
    </header>

    <section class="services-list">
        <div class="container">
            <div class="services-grid">
                {services.map((svc) => (
                    <div class="service-card">
                        <div class="neon-bar"></div>
                        <div class="service-id-large">{svc.id}</div>
                        <h2 class="service-title" set:html={svc.title} />
                        
                        <div class="price-container" style="margin-bottom: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--gray-light); min-height: 80px;">
                            <div style="display: flex; align-items: baseline; gap: 4px;">
                                <span style="font-size: 2rem; font-weight: 900;">{svc.price}</span>
                                {svc.price !== "Custom" && svc.price !== "Contact" && <span style="font-size: 0.8rem; font-weight: 700; opacity: 0.6;">/mo</span>}
                            </div>
                            {svc.setup && <span style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--gray-dark);">+ {svc.setup} Setup</span>}
                        </div>

                        <p class="service-description">{svc.description}</p>
                        
                        <div class="stat-box">
                            <span class="stat-label">{svc.statLabel}</span>
                            <div class="stat-value">{svc.statValue}</div>
                        </div>

                        <div class="card-overlay">
                            <span class="label-micro" style="border-color: var(--neon); color: var(--neon); margin-bottom: 1rem; font-size: 0.6rem;">Core Features</span>
                            <ul class="capability-list">
                                {svc.capabilities.map((cap) => (
