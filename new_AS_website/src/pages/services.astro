                    <div class="form-row">
                        <div class="input-group">
                            <label>Company Website</label>
                            <input type="url" name="website" placeholder="https://yourcompany.com" required>
                        </div>
                        <div class="input-group">
                            <label>Current Tech Stack</label>
                            <input type="text" name="tech_stack" placeholder="e.g. Salesforce, Shopify, Excel..." required>
                        </div>
                    </div>
                    <div class="input-group">
                        <label>The Bottleneck</label>
                        <textarea name="bottleneck" rows="3" placeholder="Describe the manual task you want our engineers to kill..." required></textarea>
                    </div>
                    <button type="submit" class="btn-submit-pill">Initialize Assessment</button>
