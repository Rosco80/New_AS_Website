        .service-title { 
            font-size: 1.5rem; 
            margin-bottom: 1rem; 
            letter-spacing: -0.01em;
            text-transform: uppercase;
            min-height: 3.5rem;
            line-height: 1.1;
        }

        .service-description {
            font-size: 0.85rem; 
            color: var(--gray-dark); 
            margin-bottom: 2rem;
            min-height: 4.5rem;
        }

        .stat-box {
            padding-top: 1.5rem;
            margin-top: auto;
        }

        .stat-label { font-size: 0.6rem; font-weight: 800; text-transform: uppercase; margin-bottom: 0.5rem; display: block; color: var(--gray-dark, #333); }
        .stat-value { font-size: 1.25rem; font-weight: 900; line-height: 1; }

        .card-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: var(--black, #050505);
            color: var(--white, #fff);
            padding: var(--space-md, 2rem);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .service-card:hover .card-overlay {
            opacity: 1;
            pointer-events: auto;
        }

        .capability-list { list-style: none; }
        .capability-list li {
            padding: 8px 0;
            border-bottom: 1px solid var(--gray-dark, #333);
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        .capability-list li::before { content: ""; width: 4px; height: 4px; background: var(--neon, #D4FF00); }

        .request-section {
            padding: var(--space-xl, 8rem) 0;
            background: var(--black, #050505);
            color: var(--white, #fff);
            position: relative;
            z-index: 1;
        }

        .request-container {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: var(--space-xl, 8rem);
        }

        @media (max-width: 1024px) {
            .request-container {
                grid-template-columns: 1fr;
                gap: 4rem;
            }
        }

        .form-card {
            background: var(--white, #fff);
            padding: var(--space-lg, 4rem);
            box-shadow: 15px 15px 0 var(--neon, #D4FF00);
            color: var(--black, #050505);
        }

        .form-row {
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 1.5rem;
        }

        @media (max-width: 640px) {
            .form-row {
                grid-template-columns: 1fr;
            }
        }

        .input-group { margin-bottom: 1.5rem; }
        .input-group label { display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 8px; font-family: 'Barlow Condensed', sans-serif;}
        .input-group input, .input-group select, .input-group textarea {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid var(--black, #050505);
            font-family: inherit;
            font-weight: 600;
            font-size: 0.95rem;
            outline: none;
            transition: border-color 0.2s;
        }
        
        .input-group input:focus, .input-group select:focus, .input-group textarea:focus {
            border-color: var(--neon, #D4FF00);
        }

        .btn-submit-pill {
            background: var(--black, #050505);
            color: var(--white, #fff);
            width: 100%;
            padding: 18px;
            border-radius: 99px;
            font-weight: 800;
            font-size: 1rem;
            border: none;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
        }

        .btn-submit-pill:hover {
            background: var(--neon, #D4FF00);
            color: var(--black, #050505);
        }

        .marquee-footer {
            background: var(--neon, #D4FF00);
            border-top: 2px solid var(--black, #050505);
            border-bottom: 2px solid var(--black, #050505);
            padding: 1rem 0;
            overflow: hidden;
            white-space: nowrap;
            position: relative;
            z-index: 1;
        }

        .marquee-track {
            display: flex;
            width: max-content;
            animation: scroll 60s linear infinite;
            gap: 4rem;
        }
        .marquee-track span {
            flex-shrink: 0;
            white-space: nowrap;
            font-weight: 900;
            font-size: 1.8rem;
            text-transform: uppercase;
        }
        @keyframes scroll { 
            0% { transform: translateX(0); } 
            100% { transform: translateX(-50%); } 
        }

        .trust-bar {
            padding: var(--space-xl, 4rem) 0;
            background-color: var(--gray-bg, #F9F9F9);
            border-bottom: 2px solid var(--black, #050505);
            overflow: hidden;
        }

        .trust-title {
            text-align: center;
            font-size: 1rem;
            color: var(--gray-dark, #333);
            margin-bottom: var(--space-lg, 3rem);
            font-weight: 600;
        }

        .marquee-logos-container {
            width: 100%;
            overflow: hidden;
            white-space: nowrap;
            display: flex;
            align-items: center;
            position: relative;
        }

        /* Fade edges for smoother entry/exit */
        .marquee-logos-container::before,
        .marquee-logos-container::after {
            content: "";
            position: absolute;
            top: 0;
            width: 150px;
            height: 100%;
            z-index: 2;
        }

        .marquee-logos-container::before {
            left: 0;
            background: linear-gradient(to right, var(--gray-bg, #F9F9F9), transparent);
        }

        .marquee-logos-container::after {
            right: 0;
            background: linear-gradient(to left, var(--gray-bg, #F9F9F9), transparent);
        }

        .marquee-logos {
            display: flex;
            align-items: center;
            flex-wrap: nowrap;
            width: max-content;
            animation: scroll-logos 45s linear infinite;
        }

        .marquee-logos img {
            height: 95px !important;
            max-height: 95px !important;
            width: auto !important;
            object-fit: contain;
            display: block;
            margin-right: 6rem;
            image-rendering: -webkit-optimize-contrast; /* Crisper edges for upscaled PNGs */
            image-rendering: crisp-edges;
        }

        .marquee-logos img[alt="Zoho"],
        .marquee-logos img[alt="Claude"] {
            height: 60px !important;
            max-height: 60px !important;
        }

        .marquee-logos img[alt="Antigravity"] {
            height: 120px !important;
            max-height: 120px !important;
        }

        @keyframes scroll-logos {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); } 
        }

        .faq-section {
            padding: var(--space-xl) 0;
            background: var(--white);
            border-top: 2px solid var(--black);
        }

        .faq-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-lg);
        }

        .faq-card {
            border: 2px solid var(--black);
            padding: var(--space-md);
            background: var(--gray-bg);
            box-shadow: 8px 8px 0 var(--black);
        }

        @media (max-width: 1024px) {
            .faq-grid { grid-template-columns: 1fr; }
        }

        @media (max-width: 600px) {
            .services-hero { padding: 100px 0 40px; }
            .service-id-large { font-size: 3rem; margin-bottom: 1rem; }
            .service-card { min-height: auto; padding: var(--space-md); }
