---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "Zoho Automation Agency Malaysia — ERP & CRM Optimization";
const description = "Authorized Zoho partners for Malaysian businesses. Specialized in Zoho One, CRM, Books, and Inventory automation for SMEs. Book a free audit.";

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Zoho One Implementation Agency Malaysia",
    "description": "Expert Zoho One optimization and Deluge scripting for Malaysian professional services.",
    "provider": { "@type": "Organization", "name": "Autoflow Solutions" },
    "areaServed": { "@type": "Country", "name": "MY" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is Zoho Books compliant with Malaysian SST?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, we help Malaysian SMEs configure Zoho Books for full SST compliance, including tax-ready invoicing and quarterly reporting for RMCD."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Zoho One",
    "operatingSystem": "All",
    "applicationCategory": "BusinessApplication",
    "offers": {
      "@type": "Offer",
      "price": "0.00",
      "priceCurrency": "MYR"
    }
  }
];
---

<BaseLayout title={title} description={description} schemaData={schemaData}>
    <header class="hero" style="min-height: 80vh;">
        <div class="hero-left">
            <span class="label-micro" style="border: 1px solid var(--black); padding: 4px 8px; border-radius: var(--radius-pill); margin-bottom: var(--space-md);">Tool Focus: Zoho One</span>
            <h1 class="text-display">ZOHO AGENCY<br>MALAYSIA.</h1>
            <h2 class="text-h2" style="font-size: 1.5rem; margin-bottom: 2rem; color: var(--black); line-height: 1.2;">Unifying Your MY Business with Zoho</h2>
            <p class="text-body-lg" style="margin-bottom: 2.5rem;">We help Malaysian SMEs leverage the full power of Zoho. Professional implementation, migration, and custom Deluge scripting for the local market.</p>
            <div class="hero-btns" style="display: flex; gap: 1rem;">
                <a href="/my/services#request" class="btn btn-solid">Audit Your Zoho (RM)</a>
                <a href="https://ai-self-audit.autoflow-solutions.com/" target="_blank" class="btn btn-neon">Free AI Self Audit</a>
            </div>
        </div>
        <div class="hero-right" style="background-color: #fff0f0;">
            <div style="padding: 3rem; width: 100%;">
                <div class="ui-card" style="position: relative; width: 100%; transform: none; box-shadow: 20px 20px 0 var(--black); background: #fff;">
                    <div class="card-header">
                        <span class="label-micro">ZOHO_BOOKS_MY_SYNC</span>
                        <div class="status" style="width: 8px; height: 8px; background: #ff4242; border-radius: 50%;"></div>
                    </div>
                    <div style="margin: 1.5rem 0;">
                        <p style="font-size: 0.9rem; font-weight: 700;">Automatic Invoice Posting</p>
                        <p class="label-micro" style="color: var(--gray-dark);">SST Rate: MY Standard (6% / 10%)</p>
                        <div style="margin-top: 10px; padding: 0.5rem; background: #eee; border-radius: 4px;">
                            <p style="font-size: 0.8rem;">Status: Tax-Ready • LHDN Ready ✓</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="density-section">
        <div class="container">
            <div class="section-header">
                <span class="label-micro">The Enterprise Edge</span>
                <h2 class="text-display" style="margin-top: 1rem;">ZOHO FOR THE<br>MY ECONOMY.</h2>
                <p class="text-body-lg" style="margin-top: 1.5rem;">Zoho One provides the strongest "all-in-one" operating system for Malaysian businesses. We provide the expertise to ensure it's built for your specific local workflows.</p>
            </div>
            
            <div class="blueprint-grid">
                <div class="blueprint-cell">
                    <span class="cell-id">01</span>
                    <h3 class="text-h3">CRM & Sales</h3>
                    <p class="text-body" style="margin-top: 1rem;">Tailoring Zoho CRM for Malaysian sales cycles, ensuring PDPA compliance and local-standard lead scoring.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">02</span>
                    <h3 class="text-h3">Zoho Books (SST)</h3>
                    <p class="text-body" style="margin-top: 1rem;">Configuring Zoho Books to handle Malaysian SST and quarterly reporting automatically.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">03</span>
                    <h3 class="text-h3">Inventory Sync</h3>
                    <p class="text-body" style="margin-top: 1rem;">Automating stock movements between Zoho Inventory, Shopee, Lazada, and Shopify for MY-based fulfillment centers.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">04</span>
                    <h3 class="text-h3">Custom Deluge</h3>
                    <p class="text-body" style="margin-top: 1rem;">Expert scripting for those "impossible" Malaysian business rules that off-the-shelf integrations cannot handle.</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
