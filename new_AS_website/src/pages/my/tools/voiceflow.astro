---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "Voiceflow Development Agency Malaysia — Custom AI Agent Experts";
const description = "Professional Voiceflow development for Malaysian SMEs. Custom AI voice agents, context-aware chatbots, and deep platform integrations. Book a free audit.";

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Voiceflow AI Agent Development Malaysia",
    "description": "Custom AI chatbots and voice agents built with Voiceflow for Malaysian customer service teams.",
    "provider": { "@type": "Organization", "name": "Autoflow Solutions" },
    "areaServed": { "@type": "Country", "name": "MY" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Can Voiceflow agents handle Manglish and Malay nuances?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, we tune our AI agents to understand the multi-lingual nuances of Malaysian communication, including English, BM, and colloquial 'Manglish' terms."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Voiceflow",
    "operatingSystem": "All",
    "applicationCategory": "BusinessApplication",
    "offers": {
      "@type": "Offer",
      "price": "0.00",
      "priceCurrency": "MYR"
    }
  }
];
---

<BaseLayout title={title} description={description} schemaData={schemaData}>
    <header class="hero" style="min-height: 80vh;">
        <div class="hero-left">
            <span class="label-micro" style="border: 1px solid var(--black); padding: 4px 8px; border-radius: var(--radius-pill); margin-bottom: var(--space-md);">Tool Focus: Voiceflow</span>
            <h1 class="text-display">VOICEFLOW AGENCY<br>MALAYSIA.</h1>
            <h2 class="text-h2" style="font-size: 1.5rem; margin-bottom: 2rem; color: var(--black); line-height: 1.2;">Advanced AI Agents for Southeast Asian Businesses</h2>
            <p class="text-body-lg" style="margin-bottom: 2.5rem;">We build Malaysia's most sophisticated AI agents using Voiceflow. Context-aware, guardrailed, and integrated into your core business stack.</p>
            <div class="hero-btns" style="display: flex; gap: 1rem;">
                <a href="/my/services#request" class="btn btn-solid">Discuss Your AI Agent (RM)</a>
                <a href="/ai-self-audit" target="_blank" class="btn btn-neon">Free AI Self Audit</a>
            </div>
        </div>
        <div class="hero-right" style="background-color: #f0fff4;">
            <div style="padding: 3rem; width: 100%;">
                <div class="ui-card" style="position: relative; width: 100%; transform: none; box-shadow: 20px 20px 0 var(--black); background: #fff;">
                    <div class="card-header">
                        <span class="label-micro">VOICEFLOW_AGENT_v4_MY</span>
                        <div class="status" style="width: 8px; height: 8px; background: #6aff8d; border-radius: 50%;"></div>
                    </div>
                    <div style="margin: 1.5rem 0;">
                        <p class="label-micro" style="color: var(--gray-dark);">Prompt: "Act as a Malaysian Customer Service rep..."</p>
                        <div style="padding: 1rem; background: #f9f9f9; border-radius: 4px; margin-top: 10px;">
                            <p style="font-size: 0.85rem; color: #444;">"Selamat datang! Yes, we have stock at our Mid Valley branch. Boleh saya tolong book satu unit untuk bos?"</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="density-section">
        <div class="container">
            <div class="section-header">
                <span class="label-micro">The Conversational Edge</span>
                <h2 class="text-display" style="margin-top: 1rem;">AI THAT SPEAKS<br>LOCAL.</h2>
                <p class="text-body-lg" style="margin-top: 1.5rem;">Context is everything. We build AI agents that understand Malaysian-specific context — from multi-lingual nuances to local business hours and payment methods (DuitNow/GrabPay).</p>
            </div>
            
            <div class="blueprint-grid">
                <div class="blueprint-cell">
                    <span class="cell-id">01</span>
                    <h3 class="text-h3">Context-Aware</h3>
                    <p class="text-body" style="margin-top: 1rem;">Agents trained on your specific Malaysian business documents to provide accurate, brand-safe answers every time.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">02</span>
                    <h3 class="text-h3">WhatsApp First</h3>
                    <p class="text-body" style="margin-top: 1rem;">Deploy the same intelligence across your MY website, WhatsApp Business, and Facebook Messenger where your customers are.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">03</span>
                    <h3 class="text-h3">Seamless Handover</h3>
                    <p class="text-body" style="margin-top: 1rem;">Agents that know when to pass the conversation to a human teammate on your Malaysian customer service team.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">04</span>
                    <h3 class="text-h3">API Deep Sync</h3>
                    <p class="text-body" style="margin-top: 1rem;">Your AI agents won't just talk — they'll act. From checking MY inventory in Shopee/Lazada to updating your local CRM live.</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
