---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Private Clinic Automation Malaysia — GP, Dental & Specialist Practices";
const description = "AI automation for Malaysian private clinics and healthcare SMEs. Appointment booking, admin workflows, MOH compliance support. Start with a free audit.";

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Malaysia Private Healthcare & Clinic Automation",
  "description": "MOH-compliant patient journey automation, AI reception, and admin workflows for Malaysian medical practices.",
  "provider": {
    "@type": "Organization",
    "name": "Autoflow Solutions"
  },
  "areaServed": {
    "@type": "Country",
    "name": "MY"
  },
  "serviceType": "Healthcare AI Automation"
};
---

<BaseLayout title={title} description={description} schemaData={schemaData}>
    <header class="hero" style="min-height: 80vh;">
        <div class="hero-left">
            <span class="label-micro" style="border: 1px solid var(--black); padding: 4px 8px; border-radius: var(--radius-pill); margin-bottom: var(--space-md);">Vertical Focus: Healthcare</span>
            <h1 class="text-display">PRIVATE CLINIC<br>AUTOMATION.</h1>
            <h2 class="text-h2" style="font-size: 1.5rem; margin-bottom: 2rem; color: var(--black); line-height: 1.2;">MOH-Compliant AI & Admin Workflows</h2>
            <p class="text-body-lg" style="margin-bottom: 2.5rem;">We help Malaysian private medical practices, dental clinics, and aesthetic specialists reduce no-shows and automate patient administration.</p>
            <div class="hero-btns" style="display: flex; gap: 1rem;">
                <a href="/my/services#request" class="btn btn-solid">Request a Clinic Audit (RM)</a>
                <a href="/tools/ai-self-audit" class="btn btn-neon">Free AI Self Audit</a>
            </div>
        </div>
        <div class="hero-right" style="background-color: #f0f7ff;">
            <div style="padding: 3rem; width: 100%;">
                <div class="ui-card" style="position: relative; width: 100%; transform: none; box-shadow: 20px 20px 0 var(--black); background: #fff;">
                    <div class="card-header">
                        <span class="label-micro">PATIENT_JOURNEY_AI_MY</span>
                        <span class="status" style="display: inline-block; width: 8px; height: 8px; background: #4287f5; border-radius: 50%;"></span>
                    </div>
                    <div style="margin: 1.5rem 0;">
                        <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem;">
                            <div style="width: 40px; height: 40px; background: #eee; border-radius: 50%; display: flex; align-items: center; justify-content: center;">👤</div>
                            <div>
                                <p style="font-size: 0.8rem; font-weight: 700;">New Inquiry: KL Aesthetic Center</p>
                                <p class="label-micro" style="color: var(--gray-dark);">Type: Slot Confirmation</p>
                            </div>
                        </div>
                        <div style="padding: 1rem; border-left: 3px solid var(--neon); background: #f9f9f9; border-radius: 0 4px 4px 0;">
                            <p style="font-size: 0.85rem; font-style: italic;">"AI Agent: Hello! We have slots this Wednesday at 3pm at the Bangsar branch. Should I book it?"</p>
                        </div>
                    </div>
                    <p class="label-micro" style="color: var(--gray-dark);">✓ Slot Booked in Plato API • WhatsApp Confirmation Sent</p>
                </div>
            </div>
        </div>
    </header>

    <section class="density-section">
        <div class="container">
            <div class="section-header">
                <span class="label-micro">The Trust Factor</span>
                <h2 class="text-display" style="margin-top: 1rem;">MOH READY<br>BY DESIGN.</h2>
                <p class="text-body-lg" style="margin-top: 1.5rem;">Malaysian healthcare is strictly regulated by the Ministry of Health (MOH). We build automation that supports your administrative load without replacing clinical judgement.</p>
            </div>
            
            <div class="blueprint-grid">
                <div class="blueprint-cell">
                    <span class="cell-id">01</span>
                    <h3 class="text-h3">Admin & Pre-Care</h3>
                    <p class="text-body" style="margin-top: 1rem;">Automated digital registration forms, PDPA consent captures, and medical history syncing with your PMS (Plato, Kreloses).</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">02</span>
                    <h3 class="text-h3">24/7 AI Reception</h3>
                    <p class="text-body" style="margin-top: 1rem;">Context-aware WhatsApp and voice agents that handle bookings and FAQs in English, BM, and Mandarin.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">03</span>
                    <h3 class="text-h3">PDPA Compliance</h3>
                    <p class="text-body" style="margin-top: 1rem;">Ensuring all patient data collection and automated follow-ups are fully compliant with Malaysia's Personal Data Protection Act.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">04</span>
                    <h3 class="text-h3">Follow-up Care</h3>
                    <p class="text-body" style="margin-top: 1rem;">Automated aftercare instructions, feedback surveys, and re-booking reminders via WhatsApp/SMS integration.</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
