---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Private Clinic Automation UK — GP, Dental & Specialist Practices";
const description = "AI automation for UK private clinics and healthcare SMEs. Appointment booking, admin workflows, CQC documentation support. Start with a free audit.";

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "UK Private Healthcare & Clinic Automation",
  "description": "CQC-compliant admin workflows, AI reception, and patient journey automation for UK medical and dental practices.",
  "provider": {
    "@type": "Organization",
    "name": "Autoflow Solutions"
  },
  "areaServed": {
    "@type": "Country",
    "name": "GB"
  },
  "serviceType": "Healthcare AI Automation"
};
---

<BaseLayout title={title} description={description} schemaData={schemaData}>
    <header class="hero" style="min-height: 80vh;">
        <div class="hero-left">
            <span class="label-micro" style="border: 1px solid var(--black); padding: 4px 8px; border-radius: var(--radius-pill); margin-bottom: var(--space-md);">Vertical Focus: Healthcare</span>
            <h1 class="text-display">PRIVATE CLINIC<br>AUTOMATION.</h1>
            <h2 class="text-h2" style="font-size: 1.5rem; margin-bottom: 2rem; color: var(--black); line-height: 1.2;">CQC-Compliant AI & Admin Workflows</h2>
            <p class="text-body-lg" style="margin-bottom: 2.5rem;">We help UK private medical practices, dental clinics, and cosmetic specialists reduce no-shows and automate patient administration.</p>
            <div class="hero-btns" style="display: flex; gap: 1rem;">
                <a href="/services#request" class="btn btn-solid">Request a Clinic Audit (£)</a>
                <a href="/tools/ai-self-audit" class="btn btn-neon">Free AI Self Audit</a>
            </div>
        </div>
        <div class="hero-right" style="background-color: #f0f7ff;">
            <div style="padding: 3rem; width: 100%;">
                <div class="ui-card" style="position: relative; width: 100%; transform: none; box-shadow: 20px 20px 0 var(--black); background: #fff;">
                    <div class="card-header">
                        <span class="label-micro">PATIENT_JOURNEY_AI</span>
                        <span class="status" style="display: inline-block; width: 8px; height: 8px; background: #4287f5; border-radius: 50%;"></span>
                    </div>
                    <div style="margin: 1.5rem 0;">
                        <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem;">
                            <div style="width: 40px; height: 40px; background: #eee; border-radius: 50%; display: flex; align-items: center; justify-content: center;">👤</div>
                            <div>
                                <p style="font-size: 0.8rem; font-weight: 700;">New Inquiry: London Botox Clinic</p>
                                <p class="label-micro" style="color: var(--gray-dark);">Inquiry Type: Pricing & Availability</p>
                            </div>
                        </div>
                        <div style="padding: 1rem; border-left: 3px solid var(--neon); background: #f9f9f9; border-radius: 0 4px 4px 0;">
                            <p style="font-size: 0.85rem; font-style: italic;">"AI Agent: Hello! We have slots this Thursday at 2pm. Would you like me to book that for you?"</p>
                        </div>
                    </div>
                    <p class="label-micro" style="color: var(--gray-dark);">✓ Slot Booked in Cliniko API • SMS Confirmation Sent</p>
                </div>
            </div>
        </div>
    </header>

    <section class="density-section">
        <div class="container">
            <div class="section-header">
                <span class="label-micro">The Compliance Factor</span>
                <h2 class="text-display" style="margin-top: 1rem;">CQC READY<br>BY DESIGN.</h2>
                <p class="text-body-lg" style="margin-top: 1.5rem;">UK private healthcare is strictly regulated. We build automation that supports your CQC evidence gathering without replacing clinical judgement.</p>
            </div>
            
            <div class="blueprint-grid">
                <div class="blueprint-cell">
                    <span class="cell-id">01</span>
                    <h3 class="text-h3">Admin & Pre-Care</h3>
                    <p class="text-body" style="margin-top: 1rem;">Automated digital registration forms, consent captures, and medical history syncing with your PMS (Cliniko, Jane App).</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">02</span>
                    <h3 class="text-h3">24/7 AI Reception</h3>
                    <p class="text-body" style="margin-top: 1rem;">Context-aware voice and text agents that handle bookings and common FAQs outside of clinic hours.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">03</span>
                    <h3 class="text-h3">CQC Evidence</h3>
                    <p class="text-body" style="margin-top: 1rem;">Automatically sorting and storing policy acknowledgements and staff training records for inspection readiness.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">04</span>
                    <h3 class="text-h3">Follow-up Care</h3>
                    <p class="text-body" style="margin-top: 1rem;">Automated aftercare instructions, feedback surveys, and re-booking reminders 6 months post-treatment.</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
