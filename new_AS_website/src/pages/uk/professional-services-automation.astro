---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Professional Services Automation UK — Xero, MTD & Accountants";
const description = "Automate your UK accountancy, legal or consulting firm. Xero integration, Making Tax Digital workflows, client onboarding and reporting. Free audit.";

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "UK Professional Services Automation",
  "description": "Xero and MTD-ready automation for UK accountants, consultants, and agencies. Automated onboarding and debt recovery.",
  "provider": {
    "@type": "Organization",
    "name": "Autoflow Solutions"
  },
  "areaServed": {
    "@type": "Country",
    "name": "GB"
  },
  "serviceType": "Professional Services Automation"
};
---

<BaseLayout title={title} description={description} schemaData={schemaData}>
    <header class="hero" style="min-height: 80vh;">
        <div class="hero-left">
            <span class="label-micro" style="border: 1px solid var(--black); padding: 4px 8px; border-radius: var(--radius-pill); margin-bottom: var(--space-md);">Vertical Focus: Prof Services</span>
            <h1 class="text-display">UK BUSINESS<br>AUTOMATION.</h1>
            <h2 class="text-h2" style="font-size: 1.5rem; margin-bottom: 2rem; color: var(--black); line-height: 1.2;">Xero, MTD & Professional Workflow Experts</h2>
            <p class="text-body-lg" style="margin-bottom: 2.5rem;">We help UK accountants, consultants, and agencies automate their client onboarding and quarterly compliance workflows.</p>
            <div class="hero-btns" style="display: flex; gap: 1rem;">
                <a href="/services#request" class="btn btn-solid">Get an Estimate (£)</a>
                <a href="https://ai-self-audit.autoflow-solutions.com/" class="btn btn-neon">Free AI Self Audit</a>
            </div>
        </div>
        <div class="hero-right" style="background-color: #f5f5f5;">
            <div style="padding: 3rem; width: 100%;">
                <div class="ui-card" style="position: relative; width: 100%; transform: none; box-shadow: 20px 20px 0 var(--black); background: #fff;">
                    <div class="card-header">
                        <span class="label-micro">XERO_MTD_SYNC</span>
                        <span class="status" style="display: inline-block; width: 8px; height: 8px; background: #33b5e5; border-radius: 50%;"></span>
                    </div>
                    <div style="margin: 1.5rem 0; font-family: monospace; font-size: 0.8rem;">
                        <p style="color: green;">> [SYSTEM] Initiating MTD Workflow...</p>
                        <p style="color: #666;">> Checking HMRC Authorization token: OK</p>
                        <p style="color: #666;">> Pulling Q3 Sales Data from Xero...</p>
                        <div style="margin: 0.5rem 0; padding: 0.5rem; background: #eee;">
                            Total: £44,921.00 | VAT: £7,486.83
                        </div>
                        <p style="color: green;">> Draft Submission Prepared for Review.</p>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="density-section">
        <div class="container">
            <div class="section-header">
                <span class="label-micro">The Compliance Deadline</span>
                <h2 class="text-display" style="margin-top: 1rem;">MAKING TAX<br>DIGITAL (MTD).</h2>
                <p class="text-body-lg" style="margin-top: 1.5rem;">With MTD for Income Tax becoming mandatory from April 2026, UK SMEs and landlords need digital record-keeping now. We build the bridges between your operations and HMRC.</p>
            </div>
            
            <div class="blueprint-grid">
                <div class="blueprint-cell">
                    <span class="cell-id">01</span>
                    <h3 class="text-h3">Onboarding</h3>
                    <p class="text-body" style="margin-top: 1rem;">Automated client onboarding sequences — from initial inquiry to signed engagement letter and Xero setup.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">02</span>
                    <h3 class="text-h3">Xero & QuickBooks</h3>
                    <p class="text-body" style="margin-top: 1rem;">Depth-level integration for automated bank reconciliation alerts and management reporting pulls.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">03</span>
                    <h3 class="text-h3">Debt Collection</h3>
                    <p class="text-body" style="margin-top: 1rem;">Automated multi-channel invoice chasers (Email/SMS) that stop only when Xero marks the invoice as 'Paid'.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">04</span>
                    <h3 class="text-h3">MTD Compliance</h3>
                    <p class="text-body" style="margin-top: 1rem;">Streamlining the digital record-keeping process to ensure your firm is HMRC-compliant without the manual labor.</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
