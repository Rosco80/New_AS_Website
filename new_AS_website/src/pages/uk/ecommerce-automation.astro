---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "E-Commerce Automation Agency UK — Amazon, Shopify & More";
const description = "Automate orders, returns, Royal Mail shipping and customer follow-ups for UK e-commerce businesses. Amazon UK, Shopify, WooCommerce. Free audit.";
---

<BaseLayout title={title} description={description}>
    <header class="hero" style="min-height: 80vh;">
        <div class="hero-left">
            <span class="label-micro" style="border: 1px solid var(--black); padding: 4px 8px; border-radius: var(--radius-pill); margin-bottom: var(--space-md);">Vertical Focus: E-Commerce</span>
            <h1 class="text-display">UK E-COMMERCE<br>AUTOMATION.</h1>
            <h2 class="text-h2" style="font-size: 1.5rem; margin-bottom: 2rem; color: var(--black); line-height: 1.2;">Amazon UK & Shopify Scaling Experts</h2>
            <p class="text-body-lg" style="margin-bottom: 2.5rem;">We help UK's top online sellers automate their heavy-lifting. From Royal Mail API syncs to automated returns handling.</p>
            <div class="hero-btns" style="display: flex; gap: 1rem;">
                <a href="/services#request" class="btn btn-solid">Calculate Your Savings (£)</a>
                <a href="https://ai-self-audit.autoflow-solutions.com/" class="btn btn-neon">Free AI Self Audit</a>
            </div>
        </div>
        <div class="hero-right" style="background-color: #fff9f0;">
            <div style="padding: 3rem; width: 100%;">
                <div class="ui-card" style="position: relative; width: 100%; transform: none; box-shadow: 20px 20px 0 var(--black); background: #fff;">
                    <div class="card-header">
                        <span class="label-micro">RETURNS_MANAGER_v2</span>
                        <span class="status" style="display: inline-block; width: 8px; height: 8px; background: #ff9900; border-radius: 50%;"></span>
                    </div>
                    <div style="margin: 1.5rem 0;">
                        <div style="padding: 0.75rem; background: #fff; border: 1px dashed #ccc; margin-bottom: 1rem;">
                            <p class="label-micro">Return Request #UK-8821</p>
                            <p style="font-size: 0.85rem;">Reason: Wrong size (Large required)</p>
                        </div>
                        <div style="text-align: center; color: var(--neon); font-size: 1.2rem;">⚡</div>
                        <div style="padding: 0.75rem; background: var(--black); color: var(--white); border-radius: 4px;">
                            <p class="label-micro" style="color: var(--gray-light);">Action Taken</p>
                            <p style="font-size: 0.85rem;">Royal Mail Label Generated & Emailed</p>
                            <p style="font-size: 0.85rem;">Shopify Inventory Flagged</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="density-section">
        <div class="container">
            <div class="section-header">
                <span class="label-micro">The UK Market</span>
                <h2 class="text-display" style="margin-top: 1rem;">AMAZON &<br>SHOPIFY SYNC.</h2>
                <p class="text-body-lg" style="margin-top: 1.5rem;">UK e-commerce has some of the highest expectations for delivery speed and return ease. We provide the technical backbone to compete with the giants.</p>
            </div>
            
            <div class="blueprint-grid">
                <div class="blueprint-cell">
                    <span class="cell-id">01</span>
                    <h3 class="text-h3">Returns Automation</h3>
                    <p class="text-body" style="margin-top: 1rem;">Automated handling of the 14-day UK return window. Label generation, warehouse alerts, and refund triggers.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">02</span>
                    <h3 class="text-h3">Royal Mail/DPD API</h3>
                    <p class="text-body" style="margin-top: 1rem;">Directly syncing Shopify or Amazon UK orders with Royal Mail Click & Drop for zero-touch label printing.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">03</span>
                    <h3 class="text-h3">Inventory Recon</h3>
                    <p class="text-body" style="margin-top: 1rem;">Multi-channel inventory syncing (Amazon, eBay, Shopify) to prevent overselling on UK stock.</p>
                </div>
                <div class="blueprint-cell">
                    <span class="cell-id">04</span>
                    <h3 class="text-h3">VAT & Tax Sync</h3>
                    <p class="text-body" style="margin-top: 1rem;">Automatically pushing UK VAT details and sales data to Xero or QuickBooks for easy quarterly filing.</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
