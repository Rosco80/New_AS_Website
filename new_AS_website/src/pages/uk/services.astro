---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
    {
        id: "01",
        title: "Lead<br>Handling",
        price: "£149",
        setup: "£719",
        description: "Capture, qualify, and route inquiries from WhatsApp, web chat, and forms. Never miss a lead again.",
        statLabel: "RESPONSE TIME",
        statValue: "< 3 Seconds",
        capabilities: ["WhatsApp & Web Chat", "FAQ Handling", "Lead Qualification", "Missed Inquiry Recovery"]
    },
    {
        id: "02",
        title: "Workflow<br>Automation",
        price: "£200",
        setup: "£1,319",
        description: "Back-office workflows that sync CRMs, trigger onboarding, and handle internal alerts.",
        statLabel: "TIME SAVED",
        statValue: "20+ hrs / week",
        capabilities: ["CRM Sync & Updates", "Onboarding Workflows", "Document Generation", "Internal Notifications"]
    },
    {
        id: "03",
        title: "AI Task<br>Execution",
        price: "£249",
        setup: "£1,499+",
        description: "Autonomous workers for voice answering, repetitive research, and cross-system actions.",
        statLabel: "AUTONOMY RATE",
        statValue: "100% Hands-Off",
        capabilities: ["Voice Call Handling", "Task Research & Data Entry", "Cross-System Actions", "Full Audit Trail"]
    }
];

const serviceSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "AI Automation Services for UK SMEs",
    "description": "Four purpose-built AI automation engines for UK businesses and professional services.",
    "itemListElement": services.map((s, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
            "@type": "Service",
            "name": s.title,
            "description": s.description,
            "areaServed": "GB",
            "provider": {
                "@type": "Organization",
                "name": "Autoflow Solutions",
                "url": "https://autoflow-solutions.com"
            }
        }
    }))
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "How long does it take to implement an AI automation system in the UK?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Most UK projects go from brief submission to production deployment in 2–4 weeks. You'll receive a full implementation roadmap within 48 hours of your initial brief."
            }
        },
        {
            "@type": "Question",
            "name": "Do I need technical knowledge to use your automation systems?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "No. Our systems are built and maintained by us. You interface with dashboards and simple workflows — no code required on your end."
            }
        },
        {
            "@type": "Question",
            "name": "What tools and platforms do your automations integrate with?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "We integrate with most business software including Salesforce, HubSpot, Zoho, Google Workspace, Notion, Slack, WhatsApp, and many more via Make.com, n8n, and custom API middleware."
            }
        },
        {
            "@type": "Question",
            "name": "What is the Engagement Engine?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "The Engagement Engine is our AI-powered lead capture system. It turns website visitors into qualified leads and booked appointments 24/7, with sub-3-second response times and context-aware, multi-lingual AI."
            }
        },
        {
            "@type": "Question",
            "name": "What is the Operations Engine?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "The Operations Engine eliminates manual data entry and automates your back-office. It connects your CRM, apps, and databases through intelligent API orchestration, typically saving 20+ hours per week."
            }
        }
    ]
};
---


<BaseLayout 
    title="AI Automation Services for UK SMEs — The Four Engines"
    description="UK-specialized AI automation: lead capture, back-office streamlining, voice agents, and autonomous workers. Built for British SMEs and professional services."
    schemaData={[serviceSchema, faqSchema]}
>
    <div class="cursor-follower" id="cursorFollower">
        <div class="cursor-core"></div>
    </div>

    <script is:inline>
        const follower = document.getElementById('cursorFollower');
        if (follower) {
            let mouseX = window.innerWidth / 2, mouseY = window.innerHeight / 2;
            let currentX = mouseX, currentY = mouseY;
            
            document.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
            });
            
            function animate() {
                currentX += (mouseX - currentX) * 0.08;
                currentY += (mouseY - currentY) * 0.08;
                follower.style.left = currentX + 'px';
                follower.style.top = currentY + 'px';
                requestAnimationFrame(animate);
            }
            animate();
        }
    </script>

    <header class="services-hero">
        <div class="container">
            <span class="label-micro" style="margin-bottom: 1rem;">OUR ARSENAL</span>
            <h1 class="text-display" style="margin-bottom: 2rem;">SOLUTION<br>ARCHITECTURE.</h1>
            <p class="text-body-lg" style="max-width: 600px;">We replace broken processes with autonomous systems that capture leads, eliminate admin, and scale your output. Built for the UK economy.</p>
        </div>
    </header>

    <section class="density-section" style="background-color: var(--black); color: var(--white); padding: 4rem 0;">
        <div class="container">
            <div class="grid-2" style="gap: 4rem;">
                <div>
                    <h3 class="text-h3" style="color: var(--neon); margin-bottom: 1rem;">The Problem & Cost of Inaction</h3>
                    <p class="text-body" style="color: var(--gray-light); margin-bottom: 1rem;">When leads aren't responded to immediately, they move to a competitor. When data isn't synced, staff spend hours manually copying information instead of doing high-value work.</p>
                    <p class="text-body" style="color: var(--gray-light);">The cost? Wasted marketing spend, bloated payrolls, and a ceiling on your growth.</p>
                </div>
                <div>
                    <h3 class="text-h3" style="color: var(--neon); margin-bottom: 1rem;">Who It's For & Expected Outcomes</h3>
                    <p class="text-body" style="color: var(--gray-light); margin-bottom: 1rem;">Our systems are built for <strong>UK Professional Service SMEs</strong> (accounting, legal, consulting, clinics) who rely on high-value conversations and clean data.</p>
                    <p class="text-body" style="color: var(--gray-light);">You can expect less overhead, an always-accurate CRM, and 24/7 lead handling.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="services-list" style="padding-top: 4rem;">
        <div class="container">
            <div class="services-grid">
                {services.map((svc) => (
                    <div class="service-card">
                        <div class="neon-bar"></div>
                        <div class="service-id-large">{svc.id}</div>
                        <h2 class="service-title" set:html={svc.title} />
                        
                        <div class="price-container" style="margin-bottom: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--gray-light); min-height: 80px;">
                            <div style="display: flex; align-items: baseline; gap: 4px;">
                                <span style="font-size: 2rem; font-weight: 900;">{svc.price}</span>
                                {svc.price !== "Custom" && svc.price !== "Contact" && <span style="font-size: 0.8rem; font-weight: 700; opacity: 0.6;">/mo</span>}
                            </div>
                            {svc.setup && <div style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--gray-dark);">+ {svc.setup} Setup</div>}
                            {svc.price !== "Custom" && svc.price !== "Contact" && <div style="font-size: 0.6rem; color: var(--gray-dark); opacity: 0.6; font-weight: 600; margin-top: 4px;">Retainer for minor fixes & adjustments. API costs borne by client on their own accounts.</div>}
                        </div>

                        <p class="service-description">{svc.description}</p>
                        
                        <div class="stat-box">
                            <span class="stat-label">{svc.statLabel}</span>
                            <div class="stat-value">{svc.statValue}</div>
                        </div>

                        <div class="card-overlay">
                            <span class="label-micro" style="border-color: var(--neon); color: var(--neon); margin-bottom: 1rem; font-size: 0.6rem;">Core Features</span>
                            <ul class="capability-list">
                                {svc.capabilities.map((cap) => (
                                    <li>{cap}</li>
                                ))}
                            </ul>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="trust-bar">
        <div class="container" style="text-align: center; width: 100%; margin: 0 auto; margin-bottom: var(--space-xl); position: relative; z-index: 3;">
            <h2 class="h1" style="margin-bottom: 0; display: inline-block; font-size: 3.5rem; text-transform: uppercase;">UK Integration <span class="text-gradient">Partners</span></h2>
        </div>
        <div class="marquee-logos-container">
            <div class="marquee-logos">
                <!-- Group 1 -->
                <a href="https://cloud.google.com/products/gemini" target="_blank" rel="noopener"><img src="/partners%20logos/9fa23e7d-googleantigravitylogo-whitebackground-removebg-preview.png" alt="Antigravity" /></a>
                <a href="https://www.gohighlevel.com" target="_blank" rel="noopener"><img src="/partners%20logos/go-high-level-logo-white-removebg-preview.png" alt="HighLevel" /></a>
                <a href="https://www.voiceflow.com" target="_blank" rel="noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_43PM__1_-removebg-preview.png" alt="Voiceflow" /></a>
                <a href="https://n8n.io" target="_blank" rel="noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_42PM-removebg-preview.png" alt="n8n" /></a>
                <a href="https://www.make.com/en/register?pc=asagency" target="_blank" rel="sponsored noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_43PM-removebg-preview.png" alt="Make" /></a>
                <a href="https://code.visualstudio.com" target="_blank" rel="noopener"><img src="/partners%20logos/vs-code-logo-removebg-preview.png" alt="VS Code" /></a>
                <a href="https://claude.ai" target="_blank" rel="noopener"><img src="/partners%20logos/claude_code-removebg-preview.png" alt="Claude" /></a>
                <a href="https://www.zoho.com" target="_blank" rel="noopener"><img src="/partners%20logos/ZOHO.svg-removebg-preview.png" alt="Zoho" /></a>
                
                <!-- Group 2 -->
                <a href="https://cloud.google.com/products/gemini" target="_blank" rel="noopener"><img src="/partners%20logos/9fa23e7d-googleantigravitylogo-whitebackground-removebg-preview.png" alt="Antigravity" /></a>
                <a href="https://www.gohighlevel.com" target="_blank" rel="noopener"><img src="/partners%20logos/go-high-level-logo-white-removebg-preview.png" alt="HighLevel" /></a>
                <a href="https://www.voiceflow.com" target="_blank" rel="noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_43PM__1_-removebg-preview.png" alt="Voiceflow" /></a>
                <a href="https://n8n.io" target="_blank" rel="noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_42PM-removebg-preview.png" alt="n8n" /></a>
                <a href="https://www.make.com/en/register?pc=asagency" target="_blank" rel="sponsored noopener"><img src="/partners%20logos/Generated_Image_October_19__2025_-_9_43PM-removebg-preview.png" alt="Make" /></a>
                <a href="https://code.visualstudio.com" target="_blank" rel="noopener"><img src="/partners%20logos/vs-code-logo-removebg-preview.png" alt="VS Code" /></a>
                <a href="https://claude.ai" target="_blank" rel="noopener"><img src="/partners%20logos/claude_code-removebg-preview.png" alt="Claude" /></a>
                <a href="https://www.zoho.com" target="_blank" rel="noopener"><img src="/partners%20logos/ZOHO.svg-removebg-preview.png" alt="Zoho" /></a>
            </div>
        </div>
    </section>

    <section id="request" class="request-section">
        <div class="container request-container">
            <div>
                <span style="color: var(--neon); font-size: 0.8rem; font-weight: 800; text-transform: uppercase; margin-bottom: 2rem; display: block; letter-spacing: 1px;">Initiate Build</span>
                <h2 style="font-size: 4rem; line-height: 1; font-weight: 900; margin-bottom: 2rem; letter-spacing: -2px;">Tell Us What's<br>Broken.</h2>
                <p class="text-body-lg" style="color: var(--gray-light); font-weight: 500; font-size: 1.1rem; max-width: 450px; margin-bottom: 2.5rem;">Submit your brief. Our engineers will review it and respond with a clear build roadmap — no sales calls, no vaporware.</p>
                
                <div style="display: flex; flex-direction: column; gap: 1rem; max-width: 350px;">
                    <a href="/uk/tools/automation-roi-calculator" class="btn btn-solid" style="background-color: var(--neon); color: var(--black);">Calculate ROI First</a>
                    <a href="/uk/ai-self-audit" class="btn btn-outline" style="border-color: var(--white); color: var(--white);">Or Take the Free AI Audit</a>
                </div>
                
                <p class="text-body" style="color: rgba(255,255,255,0.5); font-size: 0.9rem; margin-top: 3rem;">Not ready to brief? Use the tools above to see where automation pays off first.</p>
            </div>
            
            <div class="form-card">
                <form id="build-brief-form" novalidate>
                    <div class="input-group">
                        <label>Target Engine</label>
                        <select name="target_engine" required>
                            <option value="">Which solution fits best?</option>
                            <option value="The Engagement Engine (Chat/Lead Capture)">The Engagement Engine (Chat/Lead Capture)</option>
                            <option value="The Operations Engine (Back-Office/CRM)">The Operations Engine (Back-Office/CRM)</option>
                            <option value="The Voice Engine (Voice Assistants)">The Voice Engine (Voice Assistants)</option>
                            <option value="The Execution Engine (Digital Workers)">The Execution Engine (Digital Workers)</option>
                            <option value="Not Sure / Custom Build">Not Sure / Needs Custom Build</option>
                        </select>
                    </div>
                    <div class="form-row">
                        <div class="input-group">
                            <label>Full Name</label>
                            <input type="text" name="full_name" placeholder="John Doe" required>
                        </div>
                        <div class="input-group">
                            <label>Work Email</label>
                            <input type="email" name="email" placeholder="john@company.com" required>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="input-group">
                            <label>Company Website</label>
                            <input type="url" name="website" placeholder="https://yourcompany.co.uk" required>
                        </div>
                        <div class="input-group">
                            <label>How big is your team?</label>
                            <select name="team_size" required>
                                <option value="">Select team size</option>
                                <option value="Solo / Just me">Solo / Just me</option>
                                <option value="2-10">2–10</option>
                                <option value="11-50">11–50</option>
                                <option value="50+">50+</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="input-group">
                            <label>When are you looking to start?</label>
                            <select name="timeline" required>
                                <option value="">Select timeline</option>
                                <option value="ASAP">ASAP — this is costing us now</option>
                                <option value="1-3 months">Within 1–3 months</option>
                                <option value="Exploring">Just exploring for now</option>
                            </select>
                        </div>
                        <div class="input-group">
                            <label>Current Tech Stack</label>
                            <input type="text" name="tech_stack" placeholder="e.g. Sage, HubSpot, Excel...">
                        </div>
                    </div>
                    <div class="input-group">
                        <label>The Bottleneck</label>
                        <textarea name="bottleneck" rows="3" placeholder="Describe the manual task you want our engineers to kill..." required></textarea>
                    </div>
                    <button type="submit" class="btn-submit-pill">Initialize UK Assessment</button>
                    <div id="form-status" style="display:none; margin-top:1rem; padding:1rem; border-radius:8px; text-align:center; font-size:0.9rem;"></div>
                </form>
            </div>

            <script>
            (function() {
                const N8N_WEBHOOK = 'https://n8n.soryle.space/webhook-test/856049b4-82e0-4320-a58d-29c81b9fb0c7';
                const FORMSPREE   = 'https://formspree.io/f/mqeyoabe';

                document.getElementById('build-brief-form').addEventListener('submit', async function(e) {
                    e.preventDefault();
                    const form   = e.target;
                    const btn    = form.querySelector('button[type="submit"]');
                    const status = document.getElementById('form-status');

                    if (!form.checkValidity()) {
                        form.reportValidity();
                        return;
                    }

                    btn.disabled    = true;
                    btn.textContent = 'Sending…';
                    status.style.display = 'none';

                    const data = {
                        target_engine: form.target_engine.value,
                        full_name:     form.full_name.value,
                        email:         form.email.value,
                        website:       form.website.value,
                        team_size:     form.team_size.value,
                        timeline:      form.timeline.value,
                        tech_stack:    form.tech_stack.value,
                        bottleneck:    form.bottleneck.value,
                        source_page:   window.location.pathname,
                        locale:        'uk',
                        submitted_at:  new Date().toISOString()
                    };

                    const formData = new FormData(form);

                    try {
                        await Promise.all([
                            fetch(N8N_WEBHOOK, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(data)
                            }),
                            fetch(FORMSPREE, {
                                method: 'POST',
                                headers: { 'Accept': 'application/json' },
                                body: formData
                            })
                        ]);
                        form.reset();
                        btn.textContent = 'Sent!';
                        status.style.cssText = 'display:block; background:rgba(212,255,0,0.1); border:1px solid #D4FF00; color:#D4FF00; margin-top:1rem; padding:1rem; border-radius:8px; text-align:center; font-size:0.9rem;';
                        status.textContent = "Brief received. We'll review and be in touch shortly.";
                    } catch (err) {
                        btn.disabled    = false;
                        btn.textContent = 'Initialize UK Assessment';
                        status.style.cssText = 'display:block; background:rgba(255,80,80,0.1); border:1px solid #ff5050; color:#ff5050; margin-top:1rem; padding:1rem; border-radius:8px; text-align:center; font-size:0.9rem;';
                        status.textContent = 'Something went wrong. Please try again or email us directly.';
                    }
                });
            })();
            </script>
        </div>
    </section>

    <div class="marquee-footer">
        <div class="marquee-text">
            UK GDPR COMPLIANT • READY TO SCALE • POST-BREXIT READY • BUILT FOR VALUE • UK GDPR COMPLIANT • READY TO SCALE • POST-BREXIT READY • BUILT FOR VALUE •
        </div>
    </div>

    <style>
        .services-hero {
            padding: 160px 0 60px;
            background-image: radial-gradient(var(--gray-light, #E5E5E5) 1px, transparent 1px);
            background-size: 30px 30px;
            position: relative;
            z-index: 1;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 0;
            margin-bottom: var(--space-xl);
            border-left: 1px solid var(--gray-light, #E5E5E5);
            border-right: 1px solid var(--gray-light, #E5E5E5);
            position: relative;
            z-index: 1;
        }

        .service-card {
            border: 1px solid var(--gray-light, #E5E5E5);
            padding: var(--space-md, 2rem);
            position: relative;
            display: flex;
            flex-direction: column;
            min-height: 600px;
            background: var(--white, #fff);
            transition: all 0.3s ease;
            overflow: hidden;
        }

        .neon-bar {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: var(--neon, #D4FF00);
            transform: scaleX(0);
            transition: transform 0.3s ease;
            transform-origin: left;
        }

        .service-card:hover {
            background: var(--gray-bg, #F9F9F9);
            z-index: 2;
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        }

        .service-card:hover .neon-bar {
            transform: scaleX(1);
        }

        .service-id-large {
            font-size: 4rem;
            font-weight: 900;
            line-height: 1;
            margin-bottom: var(--space-md, 2rem);
            opacity: 0.6;
            transition: opacity 0.3s ease;
            color: #D4FF00;
            text-shadow: 0 0 20px rgba(212, 255, 0, 0.3);
        }

        .service-card:hover .service-id-large {
            opacity: 1;
        }
        
        .service-title { 
            font-size: 1.5rem; 
            margin-bottom: 1rem; 
            letter-spacing: -0.01em;
            text-transform: uppercase;
            min-height: 3.5rem;
            line-height: 1.1;
        }

        .service-description {
            font-size: 0.85rem; 
            color: var(--gray-dark); 
            margin-bottom: 2rem;
            min-height: 4.5rem;
        }

        .stat-box {
            padding-top: 1.5rem;
            margin-top: auto;
        }

        .stat-label { font-size: 0.6rem; font-weight: 800; text-transform: uppercase; margin-bottom: 0.5rem; display: block; color: var(--gray-dark, #333); }
        .stat-value { font-size: 1.25rem; font-weight: 900; line-height: 1; }

        .card-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: var(--black, #050505);
            color: var(--white, #fff);
            padding: var(--space-md, 2rem);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .service-card:hover .card-overlay {
            opacity: 1;
            pointer-events: auto;
        }

        .capability-list { list-style: none; }
        .capability-list li {
            padding: 8px 0;
            border-bottom: 1px solid var(--gray-dark, #333);
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        .capability-list li::before { content: ""; width: 4px; height: 4px; background: var(--neon, #D4FF00); }

        .request-section {
            padding: var(--space-xl, 8rem) 0;
            background: var(--black, #050505);
            color: var(--white, #fff);
            position: relative;
            z-index: 1;
        }

        .request-container {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: var(--space-xl, 8rem);
        }

        @media (max-width: 1024px) {
            .request-container {
                grid-template-columns: 1fr;
                gap: 4rem;
            }
        }

        .form-card {
            background: var(--white, #fff);
            padding: var(--space-lg, 4rem);
            box-shadow: 15px 15px 0 var(--neon, #D4FF00);
            color: var(--black, #050505);
        }

        .form-row {
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 1.5rem;
        }

        @media (max-width: 640px) {
            .form-row {
                grid-template-columns: 1fr;
            }
        }

        .input-group { margin-bottom: 1.5rem; }
        .input-group label { display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 8px; font-family: 'Barlow Condensed', sans-serif;}
        .input-group input, .input-group select, .input-group textarea {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid var(--black, #050505);
            font-family: inherit;
            font-weight: 600;
            font-size: 0.95rem;
            outline: none;
            transition: border-color 0.2s;
        }
        
        .input-group input:focus, .input-group select:focus, .input-group textarea:focus {
            border-color: var(--neon, #D4FF00);
        }

        .btn-submit-pill {
            background: var(--black, #050505);
            color: var(--white, #fff);
            width: 100%;
            padding: 18px;
            border-radius: 99px;
