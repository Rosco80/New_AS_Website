---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PortableText from '../../../components/PortableText.jsx';
import { sanityClient } from "sanity:client";

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect('/404');
}

// Fetch live from Sanity based on the slug in the URL
const query = `*[_type == "post" && slug.current == $slug][0]`;
const post = await sanityClient.fetch(query, { slug }).catch(() => null);

const fallbackPosts = [
    {
        title: "Building Resilient Data Ingestion Pipelines.",
        date: "March 14, 2024",
        body: [{_type: "block", style: "normal", children: [{_type: "span", text: "This is a fallback post. In production, this data is fetched from Sanity CMS."}]}]
    },
    {
        title: "Why your CRM is actually a data graveyard.",
        date: "March 10, 2024",
        body: [{_type: "block", style: "normal", children: [{_type: "span", text: "This is a fallback post."}]}]
    },
    {
        title: "Saving 40 Hours a Week for a Logistics Firm.",
        date: "Feb 28, 2024",
        body: [{_type: "block", style: "normal", children: [{_type: "span", text: "This is a fallback post."}]}]
    }
];

let finalPost = post;

if (!finalPost) {
    const matchedFallback = fallbackPosts.find((p) => p.title.toLowerCase().replace(/[^a-z0-9]+/g, '-') === slug);
    if (matchedFallback) {
        finalPost = { title: matchedFallback.title, publishedAt: matchedFallback.date, body: matchedFallback.body };
    }
}

if (!finalPost) {
    return Astro.redirect('/404');
}

const dateString = finalPost.publishedAt ? new Date(finalPost.publishedAt).toLocaleDateString('en-GB', { month: 'short', day: 'numeric', year: 'numeric' }) : "";

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": finalPost.title,
  "description": finalPost.excerpt || finalPost.title,
  "datePublished": finalPost.publishedAt || new Date().toISOString(),
  "author": {
    "@type": "Organization",
    "name": "Autoflow Solutions"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Autoflow Solutions",
    "logo": {
      "@type": "ImageObject",
      "url": "https://autoflow-solutions.com/logo.png"
    }
  },
  "areaServed": "GB"
};
---

<BaseLayout 
    title={`${finalPost.title} | UK AI Automation Blog`}
    schemaData={blogPostingSchema}
>
    <header style="padding: 160px 0 60px; background-image: linear-gradient(var(--gray-light, #E5E5E5) 1px, transparent 1px), linear-gradient(90deg, var(--gray-light, #E5E5E5) 1px, transparent 1px); background-size: 40px 40px; border-bottom: 2px solid var(--black, #050505);">
        <div class="container" style="max-width: 800px; margin: 0 auto; padding: 0 20px;">
            <div style="font-weight: 800; font-size: 0.8rem; text-transform: uppercase; margin-bottom: 1rem; color: var(--neon, #D4FF00); background: var(--black, #050505); display: inline-block; padding: 5px 12px; border-radius: 4px;">{dateString || "RECENT POST"}</div>
            <h1 class="text-display" style="font-size: 3.5rem; line-height: 1.1; margin-bottom: 2rem;">{finalPost.title}</h1>
        </div>
    </header>

    <article style="padding: 80px 0; background: var(--white, #fff);">
        <div class="container" style="max-width: 800px; margin: 0 auto; padding: 0 20px;">
            {finalPost.body ? (
                <PortableText value={finalPost.body} />
            ) : (
                <p style="font-size: 1.2rem; color: var(--gray-dark, #333);">This post has no content.</p>
            )}
        </div>
    </article>

    <section class="newsletter-section" style="background: var(--neon, #D4FF00); padding: var(--space-xl, 8rem) 0; text-align: center; border-top: 2px solid var(--black, #050505); border-bottom: 2px solid var(--black, #050505);">
        <div class="container">
            <h2 class="text-h2">Don't miss a sprint.</h2>
            <p style="font-weight: 600; font-size: 1.25rem; margin-top: 10px;">Get our bi-weekly breakdown of automation wins and UK AI implementation tactics.</p>
            <form id="newsletter-form" style="max-width: 600px; margin: var(--space-md, 2rem) auto 0; display: flex; gap: 10px;">
                <input type="email" name="email" placeholder="Enter your business email" required style="flex: 1; padding: 1rem 1.5rem; border: 2px solid var(--black, #050505); border-radius: 99px; font-weight: 600; outline: none; font-family: inherit;">
                <button type="submit" style="background: var(--black, #050505); color: var(--white, #fff); padding: 1rem 2rem; border-radius: 99px; font-weight: 800; border: none; cursor: pointer; white-space: nowrap;">Subscribe Now</button>
            </form>
            <div id="newsletter-success" style="display: none; max-width: 600px; margin: 2rem auto 0; background: var(--black); color: var(--neon); padding: 1rem; border-radius: 99px; font-weight: 800;">
                ✓ You're on the list! Talk soon.
            </div>
        </div>
    </section>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement;
            const newsletterSuccess = document.getElementById('newsletter-success');
            
            if (newsletterForm) {
                newsletterForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const formData = new FormData(newsletterForm);
                    const submitBtn = newsletterForm.querySelector('button');
                    if (submitBtn) {
                        submitBtn.textContent = 'Joining...';
                        submitBtn.disabled = true;
                    }
                    
                    try {
                        await fetch('https://script.google.com/macros/s/AKfycbywia_SFpTLhBUb8fs3T-lXHaGN-9Ht-iSvReQiaVWpTfVAqMJHWMHDvGKk3gtQALf9sQ/exec', {
                            method: 'POST',
                            body: formData,
                            mode: 'no-cors'
                        });
                        
                        newsletterForm.style.display = 'none';
                        if (newsletterSuccess) newsletterSuccess.style.display = 'block';
                    } catch (error) {
                        console.error('Newsletter Error:', error);
                        if (submitBtn) {
                            submitBtn.textContent = 'Subscribe Now';
                            submitBtn.disabled = false;
                        }
                    }
                });
            }
        });
    </script>
</BaseLayout>
